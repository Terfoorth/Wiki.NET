@using Microsoft.AspNetCore.Mvc.ViewFeatures
@inject IFileVersionProvider FileVersionProvider

<!DOCTYPE html>
<html lang="en" data-bs-theme="light" data-density="comfortable">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href=@AppendVersion("css/bootstrap/bootstrap.min.css") rel="stylesheet" id="bootstrap-theme" />
    @DxResourceManager.RegisterTheme(Themes.BootstrapExternal)

    @DxResourceManager.RegisterScripts()
    <link href=@AppendVersion("css/dx.fluent.blue.light.css") rel="stylesheet" />
    <link href=@AppendVersion("_content/DevExpress.Blazor.RichEdit/dx-blazor-richedit.css") rel="stylesheet" />
    <link href=@AppendVersion("_content/DevExpress.Blazor.Viewer/css/dx-blazor-viewer-components.bs5.css") rel="stylesheet" />
    <link href=@AppendVersion("_content/DevExpress.Blazor.Reporting.Viewer/css/dx-blazor-reporting-components.bs5.css") rel="stylesheet" />
    <link href=@AppendVersion("css/site.css") rel="stylesheet" />
    <link href=@AppendVersion("Wiki-Blaze.styles.css") rel="stylesheet" />
    <link href=@AppendVersion("css/kanban.css") rel="stylesheet" />

    <HeadOutlet />
</head>
<body>
    <Routes />
    <script src="js/site.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    private string AppendVersion(string path) => FileVersionProvider.AddFileVersionToPath("/", path);
}

