@inherits DrawerStateLayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<Wiki_Blaze.Data.ApplicationUser> UserManager
@inject INotificationService NotificationService
@inject IJSRuntime JsRuntime
@inject ILogger<MainLayout> Logger
@using System.Security.Claims
@using Wiki_Blaze.Services

<div class="page">
    <Drawer CssClass="navigation-drawer" PanelWidth="240px">
        <HeaderTemplate>
            <div class="navigation-drawer-header">
                <NavLink href="@AddDrawerStateToUrl(UserStartPage)">
                    <img class="logo" src="images/knowledge-base-logo.png" alt="Knowledge Base logo" />
                </NavLink>
                <NavLink aria-label="Close menu" href="@AddDrawerStateToUrlToggled(LocalPath)">
                    <DxButton aria-label="Close menu" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="btn-icon-only" IconCssClass="@(ToggledDrawer ? "icon icon-close" : "icon icon-menu")"></DxButton>
                </NavLink>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            <div class="w-100">
                <NavMenu></NavMenu>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <div class="navigation-drawer-footer">
                <NavLink href="RTE" class="button-link">
                    <DxButton Text="RTE" RenderStyle="ButtonRenderStyle.Primary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-docs"></DxButton>
                </NavLink>
                <NavLink href="By Terfoorth" class="button-link">
                    <DxButton Text="By Terfoorth" RenderStyle="ButtonRenderStyle.Primary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-demos"></DxButton>
                </NavLink>
            </div>
        </FooterTemplate>
        <TargetContent>
            <div class="drawer-content">
                <div class="nav-buttons-container">
                    <NavLink aria-label="Open menu" href="@AddDrawerStateToUrlToggled(LocalPath)" class="menu-button">
                        <DxButton aria-label="Open menu" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="btn-icon-only" IconCssClass="icon icon-menu"></DxButton>
                    </NavLink>
                    @if (LocalPath != "/") {
                        <NavLink href="@AddDrawerStateToUrl(UserStartPage)" class="button-link">
                            <DxButton Text="Back to Home" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="back-button" IconCssClass="icon icon-back"></DxButton>
                        </NavLink>
                    }
                    <AuthorizeView>
                        <Authorized>
                            <div class="menu-button-float-end display-desktop notification-header-actions">
                                <div class="notification-dropdown-wrapper">
                                    <button type="button"
                                            class="notification-bell-button"
                                            aria-label="Benachrichtigungen"
                                            aria-haspopup="menu"
                                            aria-expanded="@IsNotificationDropdownOpen"
                                            @onclick="ToggleNotificationsDropdownAsync">
                                        <span class="oi oi-bell" aria-hidden="true"></span>
                                    </button>
                                    @if (NotificationInbox.UnreadCount > 0)
                                    {
                                        <span class="notification-badge">@NotificationInbox.UnreadCount</span>
                                    }
                                    @if (IsNotificationDropdownOpen)
                                    {
                                        <div class="notification-dropdown-menu card shadow">
                                            <div class="card-body p-2">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <strong class="small">Benachrichtigungen</strong>
                                                    <button type="button"
                                                            class="btn-close btn-sm"
                                                            aria-label="Schließen"
                                                            @onclick="CloseNotificationsDropdown"></button>
                                                </div>
                                                <div class="form-check form-switch mb-2">
                                                    <input id="notificationsOnlyUnread"
                                                           class="form-check-input"
                                                           type="checkbox"
                                                           role="switch"
                                                           checked="@NotificationsOnlyUnread"
                                                           @onchange="OnNotificationsOnlyUnreadChanged" />
                                                    <label class="form-check-label small" for="notificationsOnlyUnread">Nur ungelesen</label>
                                                </div>
                                                @if (IsNotificationLoading)
                                                {
                                                    <div class="text-center p-2">
                                                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                                    </div>
                                                }
                                                else if (!string.IsNullOrWhiteSpace(NotificationErrorMessage))
                                                {
                                                    <div class="notification-error-state small p-2">@NotificationErrorMessage</div>
                                                }
                                                else if (NotificationInbox.Items.Count == 0)
                                                {
                                                    <div class="small text-muted p-2">Keine fälligen Notifications für heute (werktags ab 08:00).</div>
                                                }
                                                else
                                                {
                                                    <div class="notification-dropdown-list">
                                                        @foreach (var notification in NotificationInbox.Items)
                                                        {
                                                            <button type="button"
                                                                    class="notification-item @(notification.IsRead ? "is-read" : "is-unread")"
                                                                    @onclick="() => OpenNotificationAsync(notification)">
                                                                <div class="notification-item-title">@notification.Title</div>
                                                                <div class="notification-item-body">@notification.Body</div>
                                                                <div class="notification-item-meta">@FormatNotificationTimestamp(notification.CreatedAtUtc)</div>
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                                <NavLink href="@AddDrawerStateToUrl("Account/Manage")" class="button-link">
                                    <DxButton Text="@context.User.Identity?.Name" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-user"></DxButton>
                                </NavLink>
                            </div>
                            <form action="@AddDrawerStateToUrl("Account/Logout")" method="post" class="display-desktop">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                <DxButton SubmitFormOnClick="true" Text="Log out" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-log-out"></DxButton>
                            </form>
                        </Authorized>
                        <NotAuthorized>
                            <NavLink href="@AddDrawerStateToUrl("Account/Login")" class="button-link menu-button-float-end display-desktop">
                                <DxButton Text="Log in" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-log-in"></DxButton>
                            </NavLink>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
                @if (IsNotificationDropdownOpen)
                {
                    <div class="notification-dropdown-backdrop" @onclick="CloseNotificationsDropdown"></div>
                }
                <div class="page-content-container">
                    @Body
                </div>
            </div>
        </TargetContent>
    </Drawer>
</div>

@code {
    string LocalPath => new Uri(NavigationManager.Uri).LocalPath;
    string UserStartPage { get; set; } = Wiki_Blaze.Data.ApplicationUser.DefaultStartPage;

    private string? currentUrl;
    private bool preferencesApplied;
    private string? currentUserId;
    private bool notificationsRefreshStarted;
    private bool IsNotificationDropdownOpen;
    private bool NotificationsOnlyUnread;
    private bool IsNotificationLoading;
    private string? NotificationErrorMessage;
    private NotificationInboxDto NotificationInbox { get; set; } = new();
    private PeriodicTimer? notificationsTimer;
    private CancellationTokenSource? notificationsCts;
    private Task? notificationsRefreshTask;
    private readonly SemaphoreSlim notificationsGate = new(1, 1);

    private sealed record EffectivePreferences(string Theme, string Density, string StartPage, string? UserId);

    private static readonly EffectivePreferences DefaultPreferences = new(
        Wiki_Blaze.Data.ApplicationUser.DefaultThemePreference,
        Wiki_Blaze.Data.ApplicationUser.DefaultDensityPreference,
        Wiki_Blaze.Data.ApplicationUser.DefaultStartPage,
        null);

    protected override void OnInitialized() {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || preferencesApplied)
        {
            return;
        }

        await ApplyUserPreferencesAsync();
        StartNotificationsRefreshLoop();
    }

    private async Task ApplyUserPreferencesAsync(AuthenticationState? authState = null)
    {
        var effectivePreferences = await LoadEffectivePreferencesAsync(authState);
        await ApplyPreferencesToUiAsync(effectivePreferences);
        await RefreshNotificationsAsync();
        preferencesApplied = true;
        StateHasChanged();
    }

    private async Task<EffectivePreferences> LoadEffectivePreferencesAsync(AuthenticationState? authState = null)
    {
        var currentAuthState = authState ?? await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = currentAuthState.User;

        if (userPrincipal.Identity?.IsAuthenticated == true)
        {
            var claimUserId = ResolveUserIdFromClaims(userPrincipal);
            Wiki_Blaze.Data.ApplicationUser? user = null;

            if (!string.IsNullOrWhiteSpace(claimUserId))
            {
                user = await UserManager.FindByIdAsync(claimUserId);
            }

            if (user is null)
            {
                user = await UserManager.GetUserAsync(userPrincipal);
            }

            if (user is not null)
            {
                return
                    new EffectivePreferences(
                        user.ThemePreference ?? Wiki_Blaze.Data.ApplicationUser.DefaultThemePreference,
                        user.DensityPreference ?? Wiki_Blaze.Data.ApplicationUser.DefaultDensityPreference,
                        user.StartPage ?? Wiki_Blaze.Data.ApplicationUser.DefaultStartPage,
                        user.Id);
            }

            if (!string.IsNullOrWhiteSpace(claimUserId))
            {
                return new EffectivePreferences(
                    Wiki_Blaze.Data.ApplicationUser.DefaultThemePreference,
                    Wiki_Blaze.Data.ApplicationUser.DefaultDensityPreference,
                    Wiki_Blaze.Data.ApplicationUser.DefaultStartPage,
                    claimUserId);
            }
        }

        return new EffectivePreferences(
                        Wiki_Blaze.Data.ApplicationUser.DefaultThemePreference,
                        Wiki_Blaze.Data.ApplicationUser.DefaultDensityPreference,
                        Wiki_Blaze.Data.ApplicationUser.DefaultStartPage,
                        null);
    }

    private async Task ApplyPreferencesToUiAsync(EffectivePreferences preferences)
    {
        UserStartPage = preferences.StartPage;
        currentUserId = preferences.UserId;
        await JsRuntime.InvokeVoidAsync("wikiBlaze.setTheme", preferences.Theme);
        await JsRuntime.InvokeVoidAsync("wikiBlaze.setDensity", preferences.Density);
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> authenticationStateTask)
    {
        _ = InvokeAsync(async () =>
        {
            var authState = await authenticationStateTask;
            preferencesApplied = true;
            await ApplyUserPreferencesAsync(authState);
        });
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        _ = InvokeAsync(async () =>
        {
            await RefreshNotificationsAsync();
            StateHasChanged();
        });
    }

    private async Task ToggleNotificationsDropdownAsync()
    {
        if (IsNotificationDropdownOpen)
        {
            CloseNotificationsDropdown();
            return;
        }

        IsNotificationDropdownOpen = true;
        await RefreshNotificationsAsync();
    }

    private void CloseNotificationsDropdown()
    {
        IsNotificationDropdownOpen = false;
    }

    private async Task OnNotificationsOnlyUnreadChanged(ChangeEventArgs args)
    {
        NotificationsOnlyUnread = GetBoolValue(args.Value);
        await RefreshNotificationsAsync();
    }

    private async Task OpenNotificationAsync(NotificationInboxItemDto notification)
    {
        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            return;
        }

        try
        {
            await NotificationService.MarkAsReadAsync(currentUserId, notification.Id);
            NotificationErrorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to mark notification {NotificationId} as read for user {UserId}.", notification.Id, currentUserId);
            NotificationErrorMessage = "Notifications konnten nicht geladen werden.";
            return;
        }

        IsNotificationDropdownOpen = false;
        await RefreshNotificationsAsync();

        var target = NormalizeNavigationTarget(notification.TargetUrl);
        NavigationManager.NavigateTo(AddDrawerStateToUrl(target));
    }

    private string FormatNotificationTimestamp(DateTime createdAtUtc)
    {
        return createdAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm");
    }

    private void StartNotificationsRefreshLoop()
    {
        if (notificationsRefreshStarted)
        {
            return;
        }

        notificationsRefreshStarted = true;
        notificationsCts = new CancellationTokenSource();
        notificationsTimer = new PeriodicTimer(TimeSpan.FromSeconds(60));
        notificationsRefreshTask = Task.Run(() => NotificationsRefreshLoopAsync(notificationsCts.Token));
    }

    private async Task NotificationsRefreshLoopAsync(CancellationToken cancellationToken)
    {
        if (notificationsTimer is null)
        {
            return;
        }

        try
        {
            while (await notificationsTimer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(RefreshNotificationsAsync);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            // Layout is being disposed.
        }
    }

    private async Task RefreshNotificationsAsync()
    {
        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            currentUserId = await ResolveCurrentUserIdAsync();
        }

        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            NotificationInbox = new NotificationInboxDto();
            NotificationErrorMessage = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var hasLock = await notificationsGate.WaitAsync(TimeSpan.Zero);
        if (!hasLock)
        {
            return;
        }

        try
        {
            IsNotificationLoading = true;
            NotificationErrorMessage = null;
            try
            {
                NotificationInbox = await NotificationService.GetInboxAsync(
                    currentUserId,
                    take: 20,
                    includeRead: !NotificationsOnlyUnread);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load notification inbox for user {UserId}.", currentUserId);
                NotificationInbox = new NotificationInboxDto();
                NotificationErrorMessage = "Notifications konnten nicht geladen werden.";
            }
        }
        finally
        {
            IsNotificationLoading = false;
            notificationsGate.Release();
        }

        await InvokeAsync(StateHasChanged);
    }

    private static bool GetBoolValue(object? value)
    {
        if (value is bool boolValue)
        {
            return boolValue;
        }

        if (value is string textValue && bool.TryParse(textValue, out var parsedValue))
        {
            return parsedValue;
        }

        return false;
    }

    private static string NormalizeNavigationTarget(string? targetUrl)
    {
        if (string.IsNullOrWhiteSpace(targetUrl))
        {
            return "/";
        }

        return targetUrl.StartsWith("/", StringComparison.Ordinal) ? targetUrl : "/";
    }

    private async Task<string?> ResolveCurrentUserIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = authState.User;
        if (userPrincipal.Identity?.IsAuthenticated != true)
        {
            return null;
        }

        var claimUserId = ResolveUserIdFromClaims(userPrincipal);
        if (!string.IsNullOrWhiteSpace(claimUserId))
        {
            return claimUserId;
        }

        try
        {
            var user = await UserManager.GetUserAsync(userPrincipal);
            return user?.Id;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to resolve current user id from UserManager.");
            return null;
        }
    }

    private static string? ResolveUserIdFromClaims(ClaimsPrincipal userPrincipal)
    {
        return userPrincipal.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? userPrincipal.FindFirst("sub")?.Value;
    }

    public void Dispose() {
        NavigationManager.LocationChanged -= OnLocationChanged;
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        notificationsCts?.Cancel();
        notificationsCts?.Dispose();
        notificationsTimer?.Dispose();
        notificationsGate.Dispose();
    }
}
