@inherits DrawerStateLayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<Wiki_Blaze.Data.ApplicationUser> UserManager
@inject IJSRuntime JsRuntime
@inject INotificationService NotificationService
@inject ILogger<MainLayout> Logger
@using System.Security.Claims
@using Wiki_Blaze.Data.Entities
@using Wiki_Blaze.Services

<div class="page">
    <Drawer CssClass="navigation-drawer" PanelWidth="240px">
        <HeaderTemplate>
            <div class="navigation-drawer-header">
                <NavLink href="@AddDrawerStateToUrl(UserStartPage)">
                    <img class="logo" src="images/knowledge-base-logo.png" alt="Knowledge Base logo" />
                </NavLink>
                <NavLink aria-label="Close menu" href="@AddDrawerStateToUrlToggled(LocalPath)">
                    <DxButton aria-label="Close menu" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="btn-icon-only" IconCssClass="@(ToggledDrawer ? "icon icon-close" : "icon icon-menu")"></DxButton>
                </NavLink>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            <div class="w-100">
                <NavMenu></NavMenu>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <div class="navigation-drawer-footer">
                <NavLink href="RTE" class="button-link">
                    <DxButton Text="RTE" RenderStyle="ButtonRenderStyle.Primary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-docs"></DxButton>
                </NavLink>
                <NavLink href="By Terfoorth" class="button-link">
                    <DxButton Text="By Terfoorth" RenderStyle="ButtonRenderStyle.Primary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-demos"></DxButton>
                </NavLink>
            </div>
        </FooterTemplate>
        <TargetContent>
            <div class="drawer-content">
                <div class="nav-buttons-container">
                    <NavLink aria-label="Open menu" href="@AddDrawerStateToUrlToggled(LocalPath)" class="menu-button">
                        <DxButton aria-label="Open menu" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="btn-icon-only" IconCssClass="icon icon-menu"></DxButton>
                    </NavLink>
                    @if (LocalPath != "/") {
                        <NavLink href="@AddDrawerStateToUrl(UserStartPage)" class="button-link">
                            <DxButton Text="Back to Home" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" CssClass="back-button" IconCssClass="icon icon-back"></DxButton>
                        </NavLink>
                    }
                    <AuthorizeView>
                        <Authorized>
                            <div class="menu-button-float-end display-desktop nav-user-actions">
                                <div class="notification-menu">
                                    <DxButton Text="Status Updates"
                                              RenderStyle="ButtonRenderStyle.Secondary"
                                              RenderStyleMode="ButtonRenderStyleMode.Text"
                                              IconCssClass="oi oi-bell"
                                              Click="ToggleNotificationsAsync" />
                                    @if (UnreadNotificationCount > 0)
                                    {
                                        <span class="notification-badge">@GetNotificationBadgeText()</span>
                                    }
                                    @if (IsNotificationDropdownOpen)
                                    {
                                        <div class="notification-dropdown shadow-sm">
                                            <div class="notification-dropdown-header">
                                                <span class="fw-semibold">Benachrichtigungen</span>
                                                <button type="button"
                                                        class="btn btn-link btn-sm p-0"
                                                        @onclick="MarkAllNotificationsAsReadAsync"
                                                        disabled="@(UnreadNotificationCount == 0)">
                                                    Alle als gelesen
                                                </button>
                                            </div>
                                            @if (VisibleNotifications.Count == 0)
                                            {
                                                <div class="notification-empty text-muted">Keine offenen Benachrichtigungen.</div>
                                            }
                                            else
                                            {
                                                foreach (var notification in VisibleNotifications)
                                                {
                                                    <button type="button"
                                                            class="notification-item @(notification.IsRead ? "notification-item-read" : "notification-item-unread")"
                                                            @onclick="() => OpenNotificationAsync(notification)">
                                                        <div class="notification-item-title">@notification.Title</div>
                                                        <div class="notification-item-message">@notification.Message</div>
                                                        <div class="notification-item-date">@notification.DueDate.ToString("dd.MM.yyyy")</div>
                                                    </button>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                                <NavLink href="@AddDrawerStateToUrl("Account/Manage")" class="button-link">
                                    <DxButton Text="@context.User.Identity?.Name" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-user"></DxButton>
                                </NavLink>
                                <form action="@AddDrawerStateToUrl("Account/Logout")" method="post" class="logout-form">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                    <DxButton SubmitFormOnClick="true" Text="Log out" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-log-out"></DxButton>
                                </form>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <NavLink href="@AddDrawerStateToUrl("Account/Login")" class="button-link menu-button-float-end display-desktop">
                                <DxButton Text="Log in" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Text" IconCssClass="icon icon-log-in"></DxButton>
                            </NavLink>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
                <div class="page-content-container">
                    @Body
                </div>
            </div>
        </TargetContent>
    </Drawer>
</div>

@code {
    string LocalPath => new Uri(NavigationManager.Uri).LocalPath;
    string UserStartPage { get; set; } = Wiki_Blaze.Data.ApplicationUser.DefaultStartPage;

    private string? currentUrl;
    private bool preferencesApplied;
    private bool applyingPreferences;
    private bool isDisposed;
    private bool notificationsInitialized;

    private string? currentNotificationUserId;
    private string? pollingNotificationUserId;
    private List<UserNotification> notifications = [];
    private bool IsNotificationDropdownOpen;
    private PeriodicTimer? notificationPollTimer;
    private CancellationTokenSource? notificationPollCts;

    private sealed record EffectivePreferences(string Theme, string Density, string StartPage);

    protected override void OnInitialized() {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        _ = InvokeAsync(InitializeNotificationsAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeNotificationsAsync();
        }

        if (preferencesApplied || applyingPreferences)
        {
            return;
        }

        await ApplyUserPreferencesAsync();
    }

    private async Task ApplyUserPreferencesAsync(AuthenticationState? authState = null)
    {
        if (applyingPreferences)
        {
            return;
        }

        applyingPreferences = true;

        try
        {
            var effectivePreferences = await LoadEffectivePreferencesAsync(authState);
            await ApplyPreferencesToUiAsync(effectivePreferences);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to apply user preferences in MainLayout.");
        }
        finally
        {
            preferencesApplied = true;
            applyingPreferences = false;
        }

        if (!isDisposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<EffectivePreferences> LoadEffectivePreferencesAsync(AuthenticationState? authState = null)
    {
        var currentAuthState = authState ?? await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = currentAuthState.User;

        if (userPrincipal.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(userPrincipal);
            if (user is not null)
            {
                return
                    new EffectivePreferences(
                        user.ThemePreference ?? Wiki_Blaze.Data.ApplicationUser.DefaultThemePreference,
                        user.DensityPreference ?? Wiki_Blaze.Data.ApplicationUser.DefaultDensityPreference,
                        user.StartPage ?? Wiki_Blaze.Data.ApplicationUser.DefaultStartPage);
            }
        }
        return new EffectivePreferences(
                        Wiki_Blaze.Data.ApplicationUser.DefaultThemePreference,
                        Wiki_Blaze.Data.ApplicationUser.DefaultDensityPreference,
                        Wiki_Blaze.Data.ApplicationUser.DefaultStartPage);


    }

    private async Task ApplyPreferencesToUiAsync(EffectivePreferences preferences)
    {
        UserStartPage = preferences.StartPage;
        await JsRuntime.InvokeVoidAsync("wikiBlaze.setTheme", preferences.Theme);
        await JsRuntime.InvokeVoidAsync("wikiBlaze.setDensity", preferences.Density);
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> authenticationStateTask)
    {
        _ = InvokeAsync(async () =>
        {
            AuthenticationState authState;
            try
            {
                authState = await authenticationStateTask;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "AuthenticationStateChanged failed in MainLayout.");
                return;
            }

            await RefreshNotificationsForCurrentUserAsync(authState);
            notificationsInitialized = !string.IsNullOrWhiteSpace(currentNotificationUserId);
            preferencesApplied = false;
            await ApplyUserPreferencesAsync(authState);
        });
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        IsNotificationDropdownOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose() {
        isDisposed = true;
        NavigationManager.LocationChanged -= OnLocationChanged;
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        StopNotificationPolling();
    }

    private int UnreadNotificationCount => notifications.Count(notification => !notification.IsRead);

    private IReadOnlyList<UserNotification> VisibleNotifications =>
        notifications.Take(20).ToList();

    private async Task ToggleNotificationsAsync()
    {
        var userId = await EnsureCurrentNotificationUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        IsNotificationDropdownOpen = !IsNotificationDropdownOpen;
        if (IsNotificationDropdownOpen)
        {
            await RefreshNotificationsForUserAsync(userId);
        }
    }

    private async Task OpenNotificationAsync(UserNotification notification)
    {
        var userId = await EnsureCurrentNotificationUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        await NotificationService.MarkAsReadAsync(userId, notification.Id);
        IsNotificationDropdownOpen = false;

        await RefreshNotificationsForUserAsync(userId);

        if (!string.IsNullOrWhiteSpace(notification.TargetUrl))
        {
            NavigationManager.NavigateTo(AddDrawerStateToUrl(notification.TargetUrl));
        }
    }

    private async Task MarkAllNotificationsAsReadAsync()
    {
        var userId = await EnsureCurrentNotificationUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        await NotificationService.MarkAllAsReadAsync(userId);
        await RefreshNotificationsForUserAsync(userId);
    }

    private string GetNotificationBadgeText()
    {
        return UnreadNotificationCount > 99 ? "99+" : UnreadNotificationCount.ToString();
    }

    private async Task RefreshNotificationsForCurrentUserAsync(AuthenticationState? authState = null, CancellationToken cancellationToken = default)
    {
        var state = authState ?? await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = await ResolveAuthenticatedUserIdAsync(state.User);

        if (string.IsNullOrWhiteSpace(userId))
        {
            currentNotificationUserId = null;
            notifications = [];
            IsNotificationDropdownOpen = false;
            StopNotificationPolling();
            return;
        }

        currentNotificationUserId = userId;
        await RefreshNotificationsForUserAsync(userId, cancellationToken);
        EnsureNotificationPolling(userId);
    }

    private async Task RefreshNotificationsForUserAsync(string userId, CancellationToken cancellationToken = default)
    {
        try
        {
            var refreshedNotifications = await NotificationService.RefreshAndGetAsync(userId, cancellationToken);
            notifications = refreshedNotifications.ToList();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to refresh notifications for user {UserId}.", userId);
        }

        if (!isDisposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void EnsureNotificationPolling(string userId)
    {
        if (notificationPollTimer is not null
            && string.Equals(pollingNotificationUserId, userId, StringComparison.Ordinal))
        {
            return;
        }

        StopNotificationPolling();

        pollingNotificationUserId = userId;
        notificationPollCts = new CancellationTokenSource();
        notificationPollTimer = new PeriodicTimer(TimeSpan.FromSeconds(60));
        var pollCts = notificationPollCts;
        var pollTimer = notificationPollTimer;

        _ = Task.Run(async () =>
        {
            try
            {
                while (await pollTimer.WaitForNextTickAsync(pollCts.Token))
                {
                    if (string.IsNullOrWhiteSpace(currentNotificationUserId)
                        || !string.Equals(currentNotificationUserId, userId, StringComparison.Ordinal))
                    {
                        break;
                    }

                    await RefreshNotificationsForUserAsync(userId, pollCts.Token);
                }
            }
            catch (OperationCanceledException)
            {
            }
            catch (ObjectDisposedException)
            {
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Notification polling loop stopped unexpectedly for user {UserId}.", userId);
            }
        });
    }

    private void StopNotificationPolling()
    {
        if (notificationPollCts is not null)
        {
            notificationPollCts.Cancel();
            notificationPollCts.Dispose();
            notificationPollCts = null;
        }

        notificationPollTimer?.Dispose();
        notificationPollTimer = null;
        pollingNotificationUserId = null;
    }

    private async Task InitializeNotificationsAsync()
    {
        if (notificationsInitialized)
        {
            return;
        }

        await RefreshNotificationsForCurrentUserAsync();
        notificationsInitialized = !string.IsNullOrWhiteSpace(currentNotificationUserId);
    }

    private async Task<string?> EnsureCurrentNotificationUserIdAsync()
    {
        if (!string.IsNullOrWhiteSpace(currentNotificationUserId))
        {
            return currentNotificationUserId;
        }

        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = await ResolveAuthenticatedUserIdAsync(state.User);
        if (string.IsNullOrWhiteSpace(userId))
        {
            return null;
        }

        currentNotificationUserId = userId;
        notificationsInitialized = true;
        EnsureNotificationPolling(userId);
        return userId;
    }

    private async Task<string?> ResolveAuthenticatedUserIdAsync(ClaimsPrincipal user)
    {
        if (user.Identity?.IsAuthenticated != true)
        {
            return null;
        }

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            userId = user.FindFirst("sub")?.Value;
        }

        if (!string.IsNullOrWhiteSpace(userId))
        {
            return userId;
        }

        var applicationUser = await UserManager.GetUserAsync(user);
        return string.IsNullOrWhiteSpace(applicationUser?.Id) ? null : applicationUser.Id;
    }
}
