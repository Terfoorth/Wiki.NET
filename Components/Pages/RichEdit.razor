@page "/richedit"
@rendermode InteractiveServer

<PageTitle>Rich Text Editor</PageTitle>

<h1>Rich Text Editor</h1>

<DxRichEdit DocumentContent="DocumentContent" CssClass="h-100 w-100 overflow-hidden" />

@code {
    byte[]? DocumentContent { get; set; }

    protected override async Task OnInitializedAsync() {
        await base.OnInitializedAsync();

        await using Stream stream =
            System.Reflection.Assembly.GetExecutingAssembly().GetManifestResourceStream("Wiki_Blaze.Documents.Example.docx")
            ?? throw new InvalidOperationException("Resource not found.");
        using MemoryStream ms = new();
        await stream.CopyToAsync(ms);
        DocumentContent = ms.ToArray();
    }
}

