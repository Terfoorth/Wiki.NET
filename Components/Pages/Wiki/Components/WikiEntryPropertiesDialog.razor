@using Wiki_Blaze.Data.Entities
@using Wiki_Blaze.Components.Pages.Wiki
@using Wiki_Blaze.Services
@using System.Globalization
@inject IWikiService WikiService

@if (IsVisible && Page is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background: rgba(0,0,0,0.4);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Eigenschaften: @Page.Title</h5>
                    <button type="button" class="btn-close" @onclick="CloseAsync"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(AlertMessage))
                    {
                        <div class="alert @(IsError ? "alert-danger" : "alert-success")" role="alert">
                            @AlertMessage
                        </div>
                    }

                    <h6 class="fw-bold mb-2">Basisdaten</h6>
                    <div class="row g-2 mb-3">
                        <div class="col-md-6"><label class="form-label">Titel</label><input class="form-control" value="@Page.Title" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Kategorie</label><input class="form-control" value="@(Page.Category?.Name ?? "-")" readonly /></div>
                        <div class="col-md-6">
                            <label class="form-label" for="wiki-status-select">Status</label>
                            <select id="wiki-status-select" class="form-select" @bind="SelectedStatus">
                                @foreach (var status in StatusOptions)
                                {
                                    <option value="@status">@GetStatusLabel(status)</option>
                                }
                            </select>
                            @if (Page.Status == WikiPageStatus.Template || SelectedStatus == WikiPageStatus.Template)
                            {
                                <small class="text-muted">Hinweis: Bei Wechsel auf <strong>Veröffentlicht</strong> erscheint der Eintrag im Dashboard und nicht mehr in der Vorlagenliste.</small>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="wiki-visibility-select">Sichtbarkeit</label>
                            <select id="wiki-visibility-select" class="form-select" @bind="SelectedVisibility">
                                @foreach (var visibility in VisibilityOptions)
                                {
                                    <option value="@visibility">@GetVisibilityLabel(visibility)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6"><label class="form-label">Erstellt am</label><input class="form-control" value="@Page.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Zuletzt geändert</label><input class="form-control" value="@Page.LastModified.ToLocalTime().ToString("dd.MM.yyyy HH:mm")" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Besitzer</label><input class="form-control" value="@(Page.OwnerDisplayName ?? "-")" readonly /></div>
                    </div>

                    <h6 class="fw-bold mb-2">Attribute</h6>
                    @if (IsLoading)
                    {
                        <div class="text-muted">Lade Attribute…</div>
                    }
                    else if (AttributeEditors.Count == 0)
                    {
                        <div class="text-muted">Keine Attribute vorhanden.</div>
                    }
                    else
                    {
                        @foreach (var editor in AttributeEditors)
                        {
                            <div class="mb-3">
                                <label class="form-label">
                                    @(editor.Name)
                                    @if (editor.IsRequired)
                                    {
                                        <span class="text-danger">*</span>
                                    }
                                    @if (editor.IsAutoGenerated)
                                    {
                                        <span class="badge bg-secondary ms-1">Auto</span>
                                    }
                                </label>
                                @if (IsDateAttribute(editor))
                                {
                                    <input type="date"
                                           class="@GetAttributeInputCss(editor)"
                                           value="@editor.Value"
                                           @onchange="(args) => HandleDateAttributeChanged(editor, args)"
                                           readonly="@(editor.IsAutoGenerated)" />
                                }
                                else
                                {
                                    <input class="@GetAttributeInputCss(editor)"
                                           @bind="editor.Value"
                                           readonly="@(editor.IsAutoGenerated)" />
                                }
                                @if (!string.IsNullOrWhiteSpace(editor.ValidationError))
                                {
                                    <div class="text-danger small mt-1">@(editor.ValidationError)</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(editor.Description))
                                {
                                    <small class="text-muted">@(editor.Description)</small>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseAsync">Schließen</button>
                    <button class="btn btn-primary" disabled="@IsSaving" @onclick="SaveAsync">Speichern</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public WikiPage? Page { get; set; }
    [Parameter] public EventCallback<WikiPage> OnSaved { get; set; }

    private readonly List<EditableAttributeValue> AttributeEditors = new();
    private bool IsLoading;
    private bool IsSaving;
    private string? AlertMessage;
    private bool IsError;
    private int? LoadedPageId;
    private byte[]? InitialRowVersion;
    private WikiPageStatus SelectedStatus;
    private WikiPageVisibility SelectedVisibility;

    private static readonly WikiPageStatus[] StatusOptions = Enum.GetValues<WikiPageStatus>();
    private static readonly WikiPageVisibility[] VisibilityOptions = Enum.GetValues<WikiPageVisibility>();

    protected override async Task OnParametersSetAsync()
    {
        if (!IsVisible || Page is null)
        {
            return;
        }

        if (LoadedPageId == Page.Id)
        {
            return;
        }

        await LoadAttributesAsync();
    }

    private async Task LoadAttributesAsync()
    {
        if (Page is null)
        {
            return;
        }

        IsLoading = true;
        AlertMessage = null;
        IsError = false;
        LoadedPageId = Page.Id;
        InitialRowVersion = Page.RowVersion?.ToArray();
        SelectedStatus = Page.Status;
        SelectedVisibility = Page.Visibility;
        ClearAttributeValidationErrors();

        try
        {
            var definitionsTask = WikiService.GetAttributeDefinitionsAsync();
            var valuesTask = WikiService.GetAttributeValuesAsync(Page.Id);
            await Task.WhenAll(definitionsTask, valuesTask);

            var definitions = await definitionsTask;
            var values = await valuesTask;
            var valueByDefinitionId = values.ToDictionary(v => v.AttributeDefinitionId);

            AttributeEditors.Clear();
            foreach (var definition in definitions.Where(definition => !string.Equals(definition.Name, "Owner", StringComparison.OrdinalIgnoreCase)))
            {
                valueByDefinitionId.TryGetValue(definition.Id, out var storedValue);
                AttributeEditors.Add(new EditableAttributeValue
                {
                    Id = storedValue?.Id ?? 0,
                    WikiPageId = Page.Id,
                    AttributeDefinitionId = definition.Id,
                    Name = definition.Name,
                    ValueType = definition.ValueType ?? "text",
                    Description = definition.Description,
                    IsRequired = definition.IsRequired,
                    IsAutoGenerated = definition.IsAutoGenerated,
                    Value = NormalizeValueForEditor(storedValue?.Value, definition.ValueType),
                    OriginalValue = NormalizeValueForEditor(storedValue?.Value, definition.ValueType)
                });
            }
        }
        catch (Exception ex)
        {
            AlertMessage = $"Fehler beim Laden der Eigenschaften: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (Page is null || IsSaving)
        {
            return;
        }

        ClearAttributeValidationErrors();
        var normalizedValues = new Dictionary<int, string?>();
        var validationErrors = new List<string>();

        foreach (var attribute in AttributeEditors.Where(attribute => !attribute.IsAutoGenerated))
        {
            var normalizedValue = attribute.Value?.Trim();
            if (IsDateAttribute(attribute) && !string.IsNullOrWhiteSpace(normalizedValue))
            {
                if (!TryNormalizeDateValue(normalizedValue, out var normalizedDate))
                {
                    var error = $"Attribut '{attribute.Name}' enthält ein ungültiges Datum.";
                    attribute.ValidationError = error;
                    validationErrors.Add(error);
                    continue;
                }

                normalizedValue = normalizedDate;
            }

            if (attribute.IsRequired && string.IsNullOrWhiteSpace(normalizedValue))
            {
                var error = $"Attribut '{attribute.Name}' ist erforderlich.";
                attribute.ValidationError = error;
                validationErrors.Add(error);
            }

            normalizedValues[attribute.AttributeDefinitionId] = normalizedValue;
        }

        if (validationErrors.Count > 0)
        {
            AlertMessage = string.Join(" ", validationErrors);
            IsError = true;
            return;
        }

        IsSaving = true;
        AlertMessage = null;

        try
        {
            var currentPage = await WikiService.GetPageByIdAsync(Page.Id);
            if (currentPage?.RowVersion is not null && InitialRowVersion is not null && !currentPage.RowVersion.SequenceEqual(InitialRowVersion))
            {
                throw new InvalidOperationException("Die Wiki-Seite wurde zwischenzeitlich geändert. Bitte laden Sie die Liste neu und versuchen Sie es erneut.");
            }

            if (currentPage is null)
            {
                throw new InvalidOperationException("Die Wiki-Seite wurde nicht gefunden.");
            }

            var metadataChanged = currentPage.Status != SelectedStatus || currentPage.Visibility != SelectedVisibility;
            if (metadataChanged)
            {
                currentPage.Status = SelectedStatus;
                currentPage.Visibility = SelectedVisibility;
                await WikiService.SavePageAsync(currentPage);
            }

            foreach (var attribute in AttributeEditors.Where(attribute => !attribute.IsAutoGenerated))
            {
                var oldValue = attribute.OriginalValue?.Trim();
                var newValue = normalizedValues.GetValueOrDefault(attribute.AttributeDefinitionId);

                if (string.Equals(oldValue, newValue, StringComparison.Ordinal))
                {
                    continue;
                }

                if (string.IsNullOrWhiteSpace(newValue))
                {
                    if (attribute.Id != 0)
                    {
                        await WikiService.DeleteAttributeValueAsync(attribute.Id);
                        attribute.Id = 0;
                    }

                    attribute.OriginalValue = null;
                    attribute.Value = null;
                    continue;
                }

                var value = new WikiPageAttributeValue
                {
                    Id = attribute.Id,
                    WikiPageId = Page.Id,
                    AttributeDefinitionId = attribute.AttributeDefinitionId,
                    Value = newValue
                };

                await WikiService.SaveAttributeValueAsync(value);
                attribute.OriginalValue = newValue;
                attribute.Value = newValue;
            }

            var reloadedPage = await WikiService.GetPageByIdAsync(Page.Id);
            if (reloadedPage is not null)
            {
                Page.Status = reloadedPage.Status;
                Page.Visibility = reloadedPage.Visibility;
                Page.LastModified = reloadedPage.LastModified;
                Page.RowVersion = reloadedPage.RowVersion;
                InitialRowVersion = reloadedPage.RowVersion?.ToArray();
            }

            var reloadedValues = await WikiService.GetAttributeValuesAsync(Page.Id);
            Page.AttributeValues = reloadedValues;

            AlertMessage = "Eigenschaften gespeichert.";
            IsError = false;
            await OnSaved.InvokeAsync(Page);
        }
        catch (InvalidOperationException ex)
        {
            AlertMessage = ex.Message;
            IsError = true;
        }
        catch (Exception ex)
        {
            AlertMessage = $"Speichern fehlgeschlagen: {ex.Message}";
            IsError = true;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private static string GetStatusLabel(WikiPageStatus status)
    {
        return WikiStatusDisplayHelper.GetLabel(status);
    }

    private static string GetVisibilityLabel(WikiPageVisibility visibility)
    {
        return visibility switch
        {
            WikiPageVisibility.Private => "Privat",
            WikiPageVisibility.Team => "Team",
            WikiPageVisibility.Public => "Öffentlich",
            _ => visibility.ToString()
        };
    }

    private static void HandleDateAttributeChanged(EditableAttributeValue editor, ChangeEventArgs args)
    {
        editor.Value = args.Value?.ToString();
    }

    private static bool IsDateAttribute(EditableAttributeValue attribute)
    {
        return string.Equals(attribute.ValueType, "date", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetAttributeInputCss(EditableAttributeValue attribute)
    {
        return string.IsNullOrWhiteSpace(attribute.ValidationError)
            ? "form-control"
            : "form-control is-invalid";
    }

    private static string? NormalizeValueForEditor(string? value, string? valueType)
    {
        var trimmed = value?.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return null;
        }

        if (!string.Equals(valueType, "date", StringComparison.OrdinalIgnoreCase))
        {
            return trimmed;
        }

        return TryNormalizeDateValue(trimmed, out var normalizedDate)
            ? normalizedDate
            : trimmed;
    }

    private static bool TryNormalizeDateValue(string value, out string normalizedDate)
    {
        normalizedDate = string.Empty;
        var styles = DateTimeStyles.AllowWhiteSpaces;

        if (DateTime.TryParseExact(value, "yyyy-MM-dd", CultureInfo.InvariantCulture, styles, out var isoDate))
        {
            normalizedDate = isoDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            return true;
        }

        if (DateTime.TryParseExact(value, "dd.MM.yyyy", CultureInfo.GetCultureInfo("de-DE"), styles, out var deDate))
        {
            normalizedDate = deDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            return true;
        }

        if (DateTime.TryParse(value, CultureInfo.InvariantCulture, styles, out var invariantDate))
        {
            normalizedDate = invariantDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            return true;
        }

        if (DateTime.TryParse(value, CultureInfo.GetCultureInfo("de-DE"), styles, out var parsedDeDate))
        {
            normalizedDate = parsedDeDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
            return true;
        }

        return false;
    }

    private void ClearAttributeValidationErrors()
    {
        foreach (var attribute in AttributeEditors)
        {
            attribute.ValidationError = null;
        }
    }

    private async Task CloseAsync()
    {
        LoadedPageId = null;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private sealed class EditableAttributeValue
    {
        public int Id { get; set; }
        public int WikiPageId { get; set; }
        public int AttributeDefinitionId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string ValueType { get; set; } = "text";
        public string? Description { get; set; }
        public bool IsRequired { get; set; }
        public bool IsAutoGenerated { get; set; }
        public string? Value { get; set; }
        public string? OriginalValue { get; set; }
        public string? ValidationError { get; set; }
    }
}
