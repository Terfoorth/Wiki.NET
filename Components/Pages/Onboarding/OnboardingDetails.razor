@page "/reportdesigner/details/{ProfileId:int}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@rendermode InteractiveServer
@attribute [Authorize]
@using Wiki_Blaze.Data.Entities
@using Wiki_Blaze.Services
@inject IOnboardingService OnboardingService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<PageTitle>Onboarding Profil Details</PageTitle>

<div class="onboarding-details-root">
    <div class="card p-3 mb-3">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
            <div>
                <h3 class="mb-0">Onboarding Profil</h3>
                <small class="text-muted">Vollansicht mit Stammdaten, Maßnahmen, Test-Checkliste und Verlauf</small>
            </div>
            <div class="d-flex gap-2">
                <DxButton Text="Zur Übersicht" RenderStyle="ButtonRenderStyle.Secondary" Click="NavigateBack" />
                <DxButton Text="Settings" RenderStyle="ButtonRenderStyle.Secondary" NavigateUrl="/reportdesigner/settings" />
            </div>
        </div>
    </div>

    @if (Profile is null)
    {
        <div class="alert alert-warning">Profil wurde nicht gefunden oder konnte nicht geladen werden.</div>
    }
    else
    {
        @if (ProfileValidationErrors.Count > 0)
        {
            <div class="alert alert-danger" role="alert">
                <div class="fw-semibold mb-1">Bitte Eingaben prüfen:</div>
                <ul class="mb-0 ps-3">
                    @foreach (var validationError in ProfileValidationErrors)
                    {
                        <li>@validationError</li>
                    }
                </ul>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ProfileActionMessage))
        {
            <div class="alert @(ProfileActionIsError ? "alert-danger" : "alert-success") d-flex justify-content-between align-items-start gap-2" role="status">
                <span>@ProfileActionMessage</span>
                <button type="button" class="btn-close" aria-label="Schliessen" @onclick="ClearProfileActionMessage"></button>
            </div>
        }

        <div class="card p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <div>
                    <h4 class="mb-1">@GetProfileDisplayName(Profile)</h4>
                    <span class="badge @GetStatusBadgeCss(Profile.Status)">@GetStatusLabel(Profile.Status)</span>
                </div>
                <div class="text-end">
                    <small class="text-muted d-block">@GetProgressPercent(Profile)% abgeschlossen</small>
                    <small class="text-muted">@GetProgressText(Profile)</small>
                </div>
            </div>
            <div class="progress mt-2">
                <div class="progress-bar" style="@($"width: {GetProgressPercent(Profile)}%")"></div>
            </div>
        </div>

        <DxTabs CssClass="card p-2 onboarding-tabs">
            <DxTabPage Text="Stammdaten">
                <div class="p-2">
                    @if (!string.IsNullOrWhiteSpace(AttachmentMessage))
                    {
                        <div class="alert alert-info">@AttachmentMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(AttachmentErrorMessage))
                    {
                        <div class="alert alert-danger">@AttachmentErrorMessage</div>
                    }

                    <div class="row g-2">
                        <div class="col-md-3">
                            <label class="form-label">Anrede</label>
                            <select class="form-select" @bind="Profile.Salutation" disabled="@(!CanEdit)">
                                @foreach (var salutation in SalutationOptions)
                                {
                                    <option value="@salutation">@GetSalutationLabel(salutation)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Vorname</label>
                            <input class="form-control" @bind="Profile.FirstName" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Nachname</label>
                            <input class="form-control" @bind="Profile.LastName" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Benutzername</label>
                            <input class="form-control" @bind="Profile.Username" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ticketnummer</label>
                            <input class="form-control" @bind="Profile.TicketNumber" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Eintrittsdatum</label>
                            <input type="date" class="form-control" @bind="Profile.EntryDate" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Austrittsdatum</label>
                            <input type="date" class="form-control" @bind="Profile.ExitDate" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Abteilung</label>
                            <input class="form-control" @bind="Profile.Department" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Stellenbezeichnung</label>
                            <input class="form-control" @bind="Profile.JobTitle" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Standort</label>
                            <input class="form-control" @bind="Profile.Location" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Vorgesetzter</label>
                            <input class="form-control" @bind="Profile.Supervisor" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-Mail</label>
                            <input class="form-control" @bind="Profile.Email" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Phone</label>
                            <input class="form-control" @bind="Profile.Phone" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Mobile</label>
                            <input class="form-control" @bind="Profile.Mobile" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hostname</label>
                            <input class="form-control" @bind="Profile.Hostname" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Gerätenummer</label>
                            <input class="form-control" @bind="Profile.DeviceNumber" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Druckerkartennummer</label>
                            <input class="form-control" @bind="Profile.PrinterCardNumber" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bearbeiter</label>
                            <select class="form-select" @bind="Profile.AssignedAgentUserId" disabled="@(!CanEdit)">
                                <option value="">-- Kein Bearbeiter --</option>
                                @foreach (var assignee in AssigneeLookup)
                                {
                                    <option value="@assignee.UserId">@assignee.DisplayName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Startdatum</label>
                            <input type="date" class="form-control" @bind="StartDateInput" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Zieldatum</label>
                            <input type="date" class="form-control" @bind="TargetDateInput" readonly="@(!CanEdit)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="Profile.Status" disabled="@(!CanEdit)">
                                @foreach (var status in ProfileStatuses)
                                {
                                    <option value="@status">@GetStatusLabel(status)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Verknüpfter Benutzer (Identity Id)</label>
                            <input class="form-control" @bind="Profile.LinkedUserId" readonly="@(!CanEdit)" />
                        </div>
                    </div>

                    <div class="attachment-panel border rounded p-3 mt-3 bg-light-subtle">
                        <h6 class="mb-2">Anhang (PDF/DOC/DOCX, max. 15 MB)</h6>
                        @if (AttachmentInfo is null)
                        {
                            <div class="small text-muted mb-2">Kein Anhang vorhanden.</div>
                        }
                        else
                        {
                            <div class="small mb-2">
                                <div><strong>Datei:</strong> @AttachmentInfo.OriginalFileName (@FormatBytes(AttachmentInfo.Size))</div>
                                <div><strong>Hochgeladen:</strong> @AttachmentInfo.UploadedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                                @if (!string.IsNullOrWhiteSpace(AttachmentInfo.UploadedByDisplayName))
                                {
                                    <div><strong>Von:</strong> @AttachmentInfo.UploadedByDisplayName</div>
                                }
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <DxButton Text="Download" RenderStyle="ButtonRenderStyle.Secondary" Click="DownloadAttachmentAsync" />
                                @if (CanEdit)
                                {
                                    <DxButton Text="Entfernen" RenderStyle="ButtonRenderStyle.Danger" Click="DeleteAttachmentAsync" />
                                }
                            </div>
                        }

                        @if (CanEdit)
                        {
                            <div class="d-flex gap-2 flex-wrap align-items-center mt-3">
                                <InputFile OnChange="OnAttachmentSelected" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
                                <DxButton Text="Upload / Ersetzen" RenderStyle="ButtonRenderStyle.Primary" Click="UploadAttachmentAsync" Enabled="@HasPendingAttachmentUpload" />
                                @if (!string.IsNullOrWhiteSpace(PendingAttachmentFileName))
                                {
                                    <small class="text-muted">@PendingAttachmentFileName</small>
                                }
                            </div>
                        }
                    </div>

                    @if (CanEdit)
                    {
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <DxButton Text="Profil speichern"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      Click="SaveProfileAsync"
                                      Enabled="@(!IsProfileSaveInProgress)" />
                            <DxButton Text="Profil duplizieren" RenderStyle="ButtonRenderStyle.Secondary" Click="DuplicateProfileAsync" />
                        </div>
                    }
                </div>
            </DxTabPage>

            <DxTabPage Text="Onboarding-Maßnahmen">
                <div class="p-2">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                        <h5 class="mb-0">Maßnahmen</h5>
                        <DxCheckBox @bind-Checked="ShowOnlyOpenMeasures"
                                    LabelText="Nur offene Einträge" />
                    </div>

                    @if (CanEdit)
                    {
                        <div class="row g-2 mb-3 border rounded p-2 bg-light-subtle">
                            <div class="col-md-4">
                                <label class="form-label">Feld</label>
                                <select class="form-select" @bind="NewMeasureCatalogItemId">
                                    @foreach (var item in MeasureCatalog)
                                    {
                                        <option value="@item.Id">@item.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Eintrag</label>
                                <input class="form-control" @bind="NewMeasureValue" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Notiz</label>
                                <input class="form-control" @bind="NewMeasureNotes" />
                            </div>
                            <div class="col-md-1 d-flex align-items-end">
                                <DxButton Text="+" RenderStyle="ButtonRenderStyle.Primary" Click="AddMeasureEntryAsync" Enabled="@CanAddMeasureEntry" />
                            </div>
                        </div>
                    }

                    @if (FilteredMeasureEntries.Count == 0)
                    {
                        <div class="small text-muted">Keine Maßnahmen vorhanden.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Feld</th>
                                        <th>Eintrag</th>
                                        <th>Notiz</th>
                                        <th>Erledigt</th>
                                        @if (CanEdit)
                                        {
                                            <th class="text-end">Aktionen</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in FilteredMeasureEntries)
                                    {
                                        <tr>
                                            <td>@entry.CatalogItem?.Name</td>
                                            <td>
                                                @if (CanEdit)
                                                {
                                                    <input class="form-control form-control-sm" @bind="entry.Value" />
                                                }
                                                else
                                                {
                                                    @entry.Value
                                                }
                                            </td>
                                            <td>
                                                @if (CanEdit)
                                                {
                                                    <input class="form-control form-control-sm" @bind="entry.Notes" />
                                                }
                                                else
                                                {
                                                    @entry.Notes
                                                }
                                            </td>
                                            <td>
                                                @if (CanEdit)
                                                {
                                                    <DxCheckBox Checked="entry.IsCompleted"
                                                                CheckedChanged="@(async (bool value) => await SetMeasureCompletedAsync(entry, value))" />
                                                }
                                                else
                                                {
                                                    <span class="badge @(entry.IsCompleted ? "bg-success" : "bg-secondary")">@(entry.IsCompleted ? "Ja" : "Nein")</span>
                                                }
                                            </td>
                                            @if (CanEdit)
                                            {
                                                <td class="text-end">
                                                    <DxButton Text="Speichern" RenderStyle="ButtonRenderStyle.Secondary" Click="@(async () => await SaveMeasureEntryAsync(entry))" />
                                                    <DxButton Text="Löschen" RenderStyle="ButtonRenderStyle.Danger" Click="@(async () => await DeleteMeasureEntryAsync(entry.Id))" />
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </DxTabPage>

            <DxTabPage Text="Test-Checkliste">
                <div class="p-2">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                        <h5 class="mb-0">Checkliste</h5>
                        <DxCheckBox @bind-Checked="ShowOnlyOpenChecklist"
                                    LabelText="Nur offene Punkte" />
                    </div>

                    @if (FilteredChecklistEntries.Count == 0)
                    {
                        <div class="small text-muted">Keine Checklistenpunkte vorhanden.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Punkt</th>
                                        <th>Status</th>
                                        <th>Erledigt</th>
                                        <th>Notiz</th>
                                        @if (CanEdit)
                                        {
                                            <th class="text-end">Aktionen</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in FilteredChecklistEntries)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@entry.CatalogItem?.Name</div>
                                                <div class="small text-muted">@entry.CatalogItem?.Description</div>
                                            </td>
                                            <td>
                                                @if (CanEdit)
                                                {
                                                    <select class="form-select form-select-sm" @onchange="@(async args => await SetChecklistResultAsync(entry, args))" value="@entry.Result">
                                                        @foreach (var result in ChecklistResults)
                                                        {
                                                            <option value="@result">@result</option>
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    <span>@entry.Result</span>
                                                }
                                            </td>
                                            <td>
                                                @if (CanEdit)
                                                {
                                                    <DxCheckBox Checked="entry.IsCompleted"
                                                                CheckedChanged="@(async (bool value) => await SetChecklistCompletedAsync(entry, value))" />
                                                }
                                                else
                                                {
                                                    <span class="badge @(entry.IsCompleted ? "bg-success" : "bg-secondary")">@(entry.IsCompleted ? "Ja" : "Nein")</span>
                                                }
                                            </td>
                                            <td>
                                                @if (CanEdit)
                                                {
                                                    <input class="form-control form-control-sm" @bind="entry.Notes" />
                                                }
                                                else
                                                {
                                                    @entry.Notes
                                                }
                                            </td>
                                            @if (CanEdit)
                                            {
                                                <td class="text-end">
                                                    <DxButton Text="Speichern" RenderStyle="ButtonRenderStyle.Secondary" Click="@(async () => await SaveChecklistEntryAsync(entry))" />
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </DxTabPage>

            <DxTabPage Text="Verlauf / Notizen">
                <div class="p-2">
                    <div class="mb-3">
                        <label class="form-label">Allgemeine Notizen</label>
                        <textarea class="form-control" rows="4" @bind="Profile.Notes" readonly="@(!CanEdit)"></textarea>
                        @if (CanEdit)
                        {
                            <div class="mt-2">
                                <DxButton Text="Notizen speichern"
                                          RenderStyle="ButtonRenderStyle.Primary"
                                          Click="SaveProfileAsync"
                                          Enabled="@(!IsProfileSaveInProgress)" />
                            </div>
                        }
                    </div>

                    <h5>Verlauf</h5>
                    @if (TimelineEntries.Count == 0)
                    {
                        <div class="small text-muted">Es sind noch keine Verlaufsinformationen vorhanden.</div>
                    }
                    else
                    {
                        <ul class="list-group">
                            @foreach (var item in TimelineEntries)
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">@item.Title</div>
                                            <div class="small text-muted">@item.Description</div>
                                        </div>
                                        <small class="text-muted">@item.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </DxTabPage>
        </DxTabs>
    }
</div>

@code {
    [Parameter]
    public int ProfileId { get; set; }

    private OnboardingProfile? Profile { get; set; }

    private bool CanEdit { get; set; }
    private bool ShowOnlyOpenMeasures { get; set; }
    private bool ShowOnlyOpenChecklist { get; set; }
    private string? CurrentUserId { get; set; }
    private string? AttachmentMessage { get; set; }
    private string? AttachmentErrorMessage { get; set; }
    private string? ProfileActionMessage { get; set; }
    private bool ProfileActionIsError { get; set; }
    private bool IsProfileSaveInProgress { get; set; }
    private List<string> ProfileValidationErrors { get; } = new();

    private List<OnboardingMeasureCatalogItem> MeasureCatalog { get; set; } = new();
    private List<OnboardingAssigneeLookupItem> AssigneeLookup { get; set; } = new();
    private OnboardingProfileAttachmentInfo? AttachmentInfo { get; set; }

    private string? PendingAttachmentFileName { get; set; }
    private string? PendingAttachmentContentType { get; set; }
    private byte[]? PendingAttachmentContent { get; set; }

    private int NewMeasureCatalogItemId { get; set; }
    private string NewMeasureValue { get; set; } = string.Empty;
    private string? NewMeasureNotes { get; set; }

    private IReadOnlyList<OnboardingProfileStatus> ProfileStatuses { get; } =
    [
        OnboardingProfileStatus.Draft,
        OnboardingProfileStatus.NotStarted,
        OnboardingProfileStatus.InProgress,
        OnboardingProfileStatus.Completed,
        OnboardingProfileStatus.Archived
    ];

    private IReadOnlyList<OnboardingChecklistResult> ChecklistResults { get; } =
    [
        OnboardingChecklistResult.Pending,
        OnboardingChecklistResult.Passed,
        OnboardingChecklistResult.Failed,
        OnboardingChecklistResult.NotApplicable
    ];

    private bool CanAddMeasureEntry => CanEdit && NewMeasureCatalogItemId > 0 && !string.IsNullOrWhiteSpace(NewMeasureValue);
    private bool HasPendingAttachmentUpload => PendingAttachmentContent is { Length: > 0 } && !string.IsNullOrWhiteSpace(PendingAttachmentFileName);

    private IReadOnlyList<OnboardingSalutation> SalutationOptions { get; } =
    [
        OnboardingSalutation.Unspecified,
        OnboardingSalutation.Mr,
        OnboardingSalutation.Mrs,
        OnboardingSalutation.Diverse
    ];

    private DateTime? StartDateInput
    {
        get => Profile?.StartDate;
        set
        {
            if (Profile is not null)
            {
                Profile.StartDate = value;
            }
        }
    }

    private DateTime? TargetDateInput
    {
        get => Profile?.TargetDate;
        set
        {
            if (Profile is not null)
            {
                Profile.TargetDate = value;
            }
        }
    }

    private List<OnboardingMeasureEntry> FilteredMeasureEntries =>
        Profile is null
            ? new List<OnboardingMeasureEntry>()
            : (ShowOnlyOpenMeasures
                ? Profile.MeasureEntries.Where(item => !item.IsCompleted)
                : Profile.MeasureEntries)
                .OrderBy(item => item.CatalogItem?.SortOrder ?? int.MaxValue)
                .ThenBy(item => item.CreatedAt)
                .ToList();

    private List<OnboardingChecklistEntry> FilteredChecklistEntries =>
        Profile is null
            ? new List<OnboardingChecklistEntry>()
            : (ShowOnlyOpenChecklist
                ? Profile.ChecklistEntries.Where(item => !item.IsCompleted)
                : Profile.ChecklistEntries)
                .OrderBy(item => item.CatalogItem?.SortOrder ?? int.MaxValue)
                .ThenBy(item => item.CreatedAt)
                .ToList();

    private List<TimelineEntry> TimelineEntries => BuildTimeline(Profile);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        CanEdit = user.IsInRole("Admin") || user.IsInRole("OnboardingManager");
        CurrentUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

        MeasureCatalog = await OnboardingService.GetMeasureCatalogAsync(includeInactive: false);
        NewMeasureCatalogItemId = MeasureCatalog.FirstOrDefault()?.Id ?? 0;
        AssigneeLookup = await OnboardingService.GetAssigneeLookupAsync();

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        ClearProfileActionMessage();
        ClearProfileValidationErrors();
        Profile = await OnboardingService.GetProfileAsync(ProfileId);
        AttachmentInfo = Profile is null
            ? null
            : await OnboardingService.GetAttachmentInfoAsync(Profile.Id);
    }

    private void NavigateBack()
    {
        NavigationManager.NavigateTo("/reportdesigner");
    }

    private async Task SaveProfileAsync()
    {
        if (!CanEdit || Profile is null)
        {
            return;
        }

        try
        {
            IsProfileSaveInProgress = true;
            ClearProfileActionMessage();
            if (!ValidateProfileForSave(Profile))
            {
                SetProfileActionError("Speichern abgebrochen: Bitte Validierungsfehler korrigieren.");
                return;
            }

            Profile = await OnboardingService.UpdateProfileAsync(Profile);
            SetProfileActionMessage("Profil wurde gespeichert.");
            ClearProfileValidationErrors();
        }
        catch (Exception ex)
        {
            SetProfileActionError($"Speichern fehlgeschlagen: {ex.Message}");
        }
        finally
        {
            IsProfileSaveInProgress = false;
        }
    }

    private async Task DuplicateProfileAsync()
    {
        if (!CanEdit || Profile is null)
        {
            return;
        }

        var duplicate = await OnboardingService.DuplicateProfileAsync(Profile.Id);
        if (duplicate is not null)
        {
            NavigationManager.NavigateTo($"/reportdesigner/details/{duplicate.Id}");
        }
    }

    private async Task OnAttachmentSelected(InputFileChangeEventArgs args)
    {
        AttachmentMessage = null;
        AttachmentErrorMessage = null;

        var file = args.File;
        if (file is null)
        {
            ClearPendingAttachment();
            return;
        }

        const long maxFileSize = 15L * 1024 * 1024;
        if (file.Size <= 0)
        {
            ClearPendingAttachment();
            AttachmentErrorMessage = "Die ausgewählte Datei ist leer.";
            return;
        }

        if (file.Size > maxFileSize)
        {
            ClearPendingAttachment();
            AttachmentErrorMessage = "Die Datei ist zu groß. Erlaubt sind maximal 15 MB.";
            return;
        }

        await using var stream = file.OpenReadStream(maxFileSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        PendingAttachmentContent = memoryStream.ToArray();
        PendingAttachmentFileName = file.Name;
        PendingAttachmentContentType = file.ContentType;
    }

    private async Task UploadAttachmentAsync()
    {
        if (!CanEdit || Profile is null || !HasPendingAttachmentUpload)
        {
            return;
        }

        try
        {
            AttachmentErrorMessage = null;
            AttachmentInfo = await OnboardingService.UploadOrReplaceAttachmentAsync(
                Profile.Id,
                PendingAttachmentFileName!,
                PendingAttachmentContentType ?? "application/octet-stream",
                PendingAttachmentContent!,
                CurrentUserId);

            AttachmentMessage = "Anhang wurde gespeichert.";
            ClearPendingAttachment();
            await LoadProfileAsync();
        }
        catch (Exception ex)
        {
            AttachmentErrorMessage = ex.Message;
        }
    }

    private async Task DownloadAttachmentAsync()
    {
        if (Profile is null)
        {
            return;
        }

        var attachmentData = await OnboardingService.GetAttachmentContentAsync(Profile.Id);
        if (attachmentData is null)
        {
            AttachmentErrorMessage = "Kein Anhang vorhanden.";
            return;
        }

        var base64 = Convert.ToBase64String(attachmentData.Content);
        await JsRuntime.InvokeVoidAsync("wikiBlaze.downloadFileFromBytes", attachmentData.OriginalFileName, base64, attachmentData.ContentType);
    }

    private async Task DeleteAttachmentAsync()
    {
        if (!CanEdit || Profile is null)
        {
            return;
        }

        var removed = await OnboardingService.DeleteAttachmentAsync(Profile.Id);
        if (!removed)
        {
            AttachmentErrorMessage = "Kein Anhang zum Entfernen vorhanden.";
            return;
        }

        AttachmentErrorMessage = null;
        AttachmentMessage = "Anhang wurde entfernt.";
        AttachmentInfo = null;
        ClearPendingAttachment();
        await LoadProfileAsync();
    }

    private void ClearPendingAttachment()
    {
        PendingAttachmentFileName = null;
        PendingAttachmentContentType = null;
        PendingAttachmentContent = null;
    }

