    }

    private bool ValidateProfileForSave(OnboardingProfile profile)
    {
        ClearProfileValidationErrors();

        if (string.IsNullOrWhiteSpace(profile.FirstName))
        {
            ProfileValidationErrors.Add("Vorname ist ein Pflichtfeld.");
        }

        if (string.IsNullOrWhiteSpace(profile.LastName))
        {
            ProfileValidationErrors.Add("Nachname ist ein Pflichtfeld.");
        }

        if (profile.ExitDate.HasValue && profile.ExitDate.Value.Date < profile.EntryDate.Date)
        {
            ProfileValidationErrors.Add("Austrittsdatum darf nicht vor dem Eintrittsdatum liegen.");
        }

        if (profile.StartDate.HasValue
            && profile.TargetDate.HasValue
            && profile.TargetDate.Value.Date < profile.StartDate.Value.Date)
        {
            ProfileValidationErrors.Add("Zieldatum darf nicht vor dem Startdatum liegen.");
        }

        return ProfileValidationErrors.Count == 0;
    }

    private void ClearProfileValidationErrors()
    {
        ProfileValidationErrors.Clear();
    }

    private sealed record TimelineEntry(DateTime Timestamp, string Title, string Description);
