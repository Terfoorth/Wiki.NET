    private static string GetProfileDisplayName(OnboardingProfile profile)
    {
        var firstName = profile.FirstName?.Trim();
        var lastName = profile.LastName?.Trim();
        var fullName = $"{firstName} {lastName}".Trim();

        if (!string.IsNullOrWhiteSpace(fullName))
        {
            return fullName;
        }

        return profile.FullName;
    }

    private static string GetSalutationLabel(OnboardingSalutation salutation)
    {
        return salutation switch
        {
            OnboardingSalutation.Mr => "Herr",
            OnboardingSalutation.Mrs => "Frau",
            OnboardingSalutation.Diverse => "Divers",
            _ => "Keine Angabe"
        };
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes <= 0)
        {
            return "0 B";
        }

        var units = new[] { "B", "KB", "MB", "GB" };
        var size = (double)bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:0.##} {units[unitIndex]}";
    }

    private static string GetStatusLabel(OnboardingProfileStatus status)
