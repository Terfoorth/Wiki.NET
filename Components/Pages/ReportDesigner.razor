@page "/reportdesigner"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.Globalization
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@using Wiki_Blaze.Data.Entities
@using Wiki_Blaze.Services
@inject IOnboardingService OnboardingService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JsRuntime

<PageTitle>Onboarding Management</PageTitle>

<div class="onboarding-root">
    <div class="card onboarding-toolbar-card mb-3">
        <DxToolbar CssClass="onboarding-toolbar" ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            <Items>
                <DxToolbarItem>
                    <Template>
                        <div class="onboarding-title-wrap">
                            <h3 class="mb-0">Onboarding Management</h3>
                            <small class="text-muted">Grid-Ansicht mit Profil-Detailpanel und vollstÃ¤ndiger Detailseite</small>
                        </div>
                    </Template>
                </DxToolbarItem>
                <DxToolbarItem Alignment="ToolbarItemAlignment.Right">
                    <Template>
                        <DxButton Text="Einstellungen" NavigateUrl="/reportdesigner/settings" RenderStyle="ButtonRenderStyle.Secondary" />
                    </Template>
                </DxToolbarItem>
                @if (CanEdit)
                {
                    <DxToolbarItem Alignment="ToolbarItemAlignment.Right">
                        <Template>
                            <DxButton Text="Neues Profil" RenderStyle="ButtonRenderStyle.Primary" Click="OpenCreateProfilePopup" />
                        </Template>
                    </DxToolbarItem>
                }
                <DxToolbarItem Alignment="ToolbarItemAlignment.Right">
                    <Template>
                        <DxButton Text="Aktualisieren" RenderStyle="ButtonRenderStyle.Secondary" Click="@(async () => await LoadProfilesAsync())" />
                    </Template>
                </DxToolbarItem>
            </Items>
        </DxToolbar>

        <div class="row g-2 mt-2 onboarding-filters">
            <div class="col-xl-4 col-md-6">
                <DxTextBox NullText="Suche nach Name, Benutzername, Ticket, E-Mail, Abteilung"
                           BindValueMode="BindValueMode.OnInput"
                           @bind-Text="SearchText" />
            </div>
            <div class="col-xl-3 col-md-6">
                <DxComboBox Data="StatusFilterItems"
                            TData="StatusFilterItem"
                            TValue="string"
                            TextFieldName="Text"
                            ValueFieldName="Value"
                            @bind-Value="SelectedStatusFilterValue" />
            </div>
            <div class="col-xl-3 col-md-6 d-flex align-items-center">
                <DxCheckBox @bind-Checked="OnlyOpenProfiles"
                            LabelText="Nur offene Profile" />
            </div>
            <div class="col-xl-2 col-md-6 d-flex justify-content-end">
                <DxButton Text="Filter anwenden" RenderStyle="ButtonRenderStyle.Secondary" Click="@(async () => await LoadProfilesAsync())" />
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(UiErrorMessage))
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-start gap-2" role="alert">
            <span>@UiErrorMessage</span>
            <button type="button" class="btn-close" aria-label="SchlieÃŸen" @onclick="() => UiErrorMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(UiInfoMessage))
    {
        <div class="alert alert-success d-flex justify-content-between align-items-start gap-2" role="status">
            <span>@UiInfoMessage</span>
            <button type="button" class="btn-close" aria-label="SchlieÃŸen" @onclick="() => UiInfoMessage = null"></button>
        </div>
    }

    <DxDrawer CssClass="onboarding-drawer"
              @bind-IsOpen="IsDrawerOpen"
              Position="DrawerPosition.Right"
              Mode="DrawerMode.Shrink"
              ApplyBackgroundShading="false"
              PanelWidth="34rem">
        <BodyTemplate>
            <div class="onboarding-panel p-3">
                @if (ActiveProfileDraft is null)
                {
                    <div class="text-muted">WÃ¤hlen Sie links ein Profil aus.</div>
                }
                else
                {
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <div>
                            <h4 class="mb-1">@GetProfileDisplayName(ActiveProfileDraft)</h4>
                            <span class="badge @GetStatusBadgeCss(ActiveProfileDraft.Status)">@GetStatusLabel(ActiveProfileDraft.Status)</span>
                        </div>
                        <DxButton Text="Detailseite"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  NavigateUrl="@($"/reportdesigner/details/{ActiveProfileDraft.Id}")" />
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <small class="text-muted">Fortschritt</small>
                            <small class="text-muted">@GetProgressPercent(ActiveProfileDraft)%</small>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="@($"width: {GetProgressPercent(ActiveProfileDraft)}%")"></div>
                        </div>
                        <small class="text-muted">@GetProgressText(ActiveProfileDraft)</small>
                    </div>

                    @if (CanEdit)
                    {
                        <div class="d-flex gap-2 flex-wrap mb-3">
                            <DxButton Text="Speichern" RenderStyle="ButtonRenderStyle.Primary" Click="SaveActiveProfileAsync" />
                            <DxButton Text="Duplizieren" RenderStyle="ButtonRenderStyle.Secondary" Click="DuplicateActiveProfileAsync" />
                            <DxButton Text="Offene To-Dos" RenderStyle="ButtonRenderStyle.Secondary" Click="ToggleOpenTodoFilter" />
                            <DxButton Text="Eintrag lÃ¶schen"
                                      RenderStyle="ButtonRenderStyle.Danger"
                                      Click="@(async () => await OpenDeleteConfirmationAsync(ActiveProfileDraft.Id))" />
                        </div>
                    }

                    <div class="onboarding-edit-grid">
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label">Anrede</label>
                                <select class="form-select" @bind="ActiveProfileDraft.Salutation" disabled="@(!CanEdit)">
                                    @foreach (var salutation in SalutationOptions)
                                    {
                                        <option value="@salutation">@GetSalutationLabel(salutation)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Vorname</label>
                                <input class="form-control" @bind="ActiveProfileDraft.FirstName" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Nachname</label>
                                <input class="form-control" @bind="ActiveProfileDraft.LastName" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Benutzername</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Username" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ticketnummer</label>
                                <input class="form-control" @bind="ActiveProfileDraft.TicketNumber" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Eintrittsdatum</label>
                                <input type="date" class="form-control" @bind="ActiveProfileDraft.EntryDate" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Austrittsdatum</label>
                                <input type="date" class="form-control" @bind="ActiveProfileDraft.ExitDate" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Startdatum (Onboarding)</label>
                                <input type="date" class="form-control" @bind="ActiveProfileDraft.StartDate" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Zieldatum (Onboarding)</label>
                                <input type="date" class="form-control" @bind="ActiveProfileDraft.TargetDate" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Abteilung</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Department" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Stellenbezeichnung</label>
                                <input class="form-control" @bind="ActiveProfileDraft.JobTitle" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Standort</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Location" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Vorgesetzter</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Supervisor" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">E-Mail</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Email" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Phone</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Phone" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Mobile</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Mobile" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Hostname</label>
                                <input class="form-control" @bind="ActiveProfileDraft.Hostname" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">GerÃ¤tenummer</label>
                                <input class="form-control" @bind="ActiveProfileDraft.DeviceNumber" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Druckerkartennummer</label>
                                <input class="form-control" @bind="ActiveProfileDraft.PrinterCardNumber" readonly="@(!CanEdit)" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Bearbeiter</label>
                                <select class="form-select" @bind="ActiveProfileDraft.AssignedAgentUserId" disabled="@(!CanEdit)">
                                    <option value="">-- Kein Bearbeiter --</option>
                                    @foreach (var assignee in AssigneeLookup)
                                    {
                                        <option value="@assignee.UserId">@assignee.DisplayName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <select class="form-select" @bind="ActiveProfileDraft.Status" disabled="@(!CanEdit)">
                                    @foreach (var status in ProfileStatuses)
                                    {
                                        <option value="@status">@GetStatusLabel(status)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">VerknÃ¼pfter Benutzer (Id)</label>
                                <input class="form-control" @bind="ActiveProfileDraft.LinkedUserId" readonly="@(!CanEdit)" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <h6>Onboarding-MaÃŸnahmen</h6>
                        @if (GetFilteredMeasureEntries(ActiveProfileDraft).Count == 0)
                        {
                            <div class="small text-muted">Keine MaÃŸnahmeneintrÃ¤ge vorhanden.</div>
                        }
                        else
                        {
                            <ul class="list-group">
                                @foreach (var entry in GetFilteredMeasureEntries(ActiveProfileDraft).Take(8))
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">@entry.CatalogItem?.Name</div>
                                            <div class="small">@entry.Value</div>
                                        </div>
                                        @if (CanEdit)
                                        {
                                            <DxCheckBox Checked="entry.IsCompleted" CheckedChanged="@(async (bool value) => await ToggleMeasureCompletedAsync(entry, value))" />
                                        }
                                        else
                                        {
                                            <span class="badge @(entry.IsCompleted ? "bg-success" : "bg-secondary")">@(entry.IsCompleted ? "Erledigt" : "Offen")</span>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <div class="mt-3">
                        <h6>Test-Checkliste</h6>
                        @if (GetFilteredChecklistEntries(ActiveProfileDraft).Count == 0)
                        {
                            <div class="small text-muted">Keine Checklistenpunkte vorhanden.</div>
                        }
                        else
                        {
                            <ul class="list-group">
                                @foreach (var entry in GetFilteredChecklistEntries(ActiveProfileDraft).Take(8))
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">@entry.CatalogItem?.Name</div>
                                            <div class="small text-muted">@entry.Result</div>
                                        </div>
                                        @if (CanEdit)
                                        {
                                            <DxCheckBox Checked="entry.IsCompleted" CheckedChanged="@(async (bool value) => await ToggleChecklistCompletedAsync(entry, value))" />
                                        }
                                        else
                                        {
                                            <span class="badge @(entry.IsCompleted ? "bg-success" : "bg-secondary")">@(entry.IsCompleted ? "Erledigt" : "Offen")</span>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>
        </BodyTemplate>

        <TargetContent>
            <div id="@GridHostId" class="onboarding-grid-host">
                <DxGrid @ref="Grid"
                        Data="Profiles"
                        KeyFieldName="Id"
                        FocusedRowEnabled="true"
                        HighlightRowOnHover="true"
                        ShowFilterRow="false"
                        ShowGroupPanel="false"
                        ShowSearchBox="false"
                        VirtualScrollingEnabled="true"
                        RowClick="OnRowClick"
                        CustomizeElement="OnGridCustomizeElement"
                        TextWrapEnabled="false"
                        CssClass="onboarding-grid">
                    <Columns>
                        <DxGridDataColumn FieldName="DisplayName" Caption="Mitarbeiter" MinWidth="220" />
                        <DxGridDataColumn FieldName="Username" Caption="Benutzername" MinWidth="150" />
                        <DxGridDataColumn FieldName="Department" Caption="Abteilung" MinWidth="140" />
                        <DxGridDataColumn FieldName="JobTitle" Caption="Stelle" MinWidth="160" />
                        <DxGridDataColumn FieldName="EntryDate" Caption="Eintritt" DisplayFormat="dd.MM.yyyy" MinWidth="120" />
                        <DxGridDataColumn FieldName="AssignedAgentDisplayName" Caption="Bearbeiter" MinWidth="170" />
                        <DxGridDataColumn FieldName="Status" Caption="Status" MinWidth="110">
                            <CellDisplayTemplate>
                                @{ var item = (OnboardingProfileListItem)context.DataItem; }
                                <span class="badge @GetStatusBadgeCss(item.Status)">@GetStatusLabel(item.Status)</span>
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn Caption="Fortschritt" MinWidth="180">
                            <CellDisplayTemplate>
                                @{ var item = (OnboardingProfileListItem)context.DataItem; }
                                <div>
                                    <div class="progress">
                                        <div class="progress-bar" role="progressbar" style="@($"width: {item.ProgressPercent}%")"></div>
                                    </div>
                                    <small class="text-muted">@item.ProgressPercent% Â· @item.OpenTodoCount offene Punkte</small>
                                </div>
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="LastModifiedAt" Caption="Letzte Ã„nderung" DisplayFormat="dd.MM.yyyy HH:mm" MinWidth="150" />
                    </Columns>
                </DxGrid>
            </div>
        </TargetContent>
    </DxDrawer>

    <DxContextMenu @ref="GridContextMenu"
                   ItemClick="OnGridContextMenuItemClick">
        <Items>
            <DxContextMenuItem Text="Detailseite Ã¶ffnen" IconCssClass="oi oi-eye" Name="open-details" />
            <DxContextMenuItem Text="Offene To-Dos" IconCssClass="oi oi-check" Name="toggle-open-todos" />
            @if (CanEdit)
            {
                <DxContextMenuItem Text="Status Ã¤ndern" IconCssClass="oi oi-loop-circular" Name="change-status-root">
                    <Items>
                        <DxContextMenuItem Text="Entwurf" Name="status-draft" />
                        <DxContextMenuItem Text="In Bearbeitung" Name="status-in-progress" />
                        <DxContextMenuItem Text="Abgeschlossen" Name="status-completed" />
                        <DxContextMenuItem Text="Archiviert" Name="status-archived" />
                    </Items>
                </DxContextMenuItem>
                <DxContextMenuItem Text="Duplizieren" IconCssClass="oi oi-copywriting" Name="duplicate" />
                <DxContextMenuItem Text="Eintrag lÃ¶schen" IconCssClass="oi oi-trash" Name="delete" BeginGroup="true" />
            }
        </Items>
    </DxContextMenu>
</div>

<DxPopup @bind-Visible="DeletePopupVisible"
         HeaderText="Eintrag endgÃ¼ltig lÃ¶schen"
         Width="30rem"
         ShowCloseButton="true"
         CloseOnOutsideClick="false">
    <BodyContentTemplate>
        <div class="p-2">
            <p class="mb-2">
                MÃ¶chten Sie das Onboarding-Profil
                <strong>@DeleteTargetDisplayName</strong>
                endgÃ¼ltig lÃ¶schen?
            </p>
            <p class="text-danger small mb-0">Diese Aktion kann nicht rÃ¼ckgÃ¤ngig gemacht werden.</p>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <DxButton Text="Abbrechen" RenderStyle="ButtonRenderStyle.Secondary" Click="CloseDeleteConfirmation" />
                <DxButton Text="EndgÃ¼ltig lÃ¶schen"
                          RenderStyle="ButtonRenderStyle.Danger"
                          Click="ConfirmDeleteProfileAsync" />
            </div>
        </div>
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="CreatePopupVisible"
         HeaderText="Neues Onboarding-Profil"
         Width="35rem"
         ShowCloseButton="true"
         CloseOnOutsideClick="false">
    <BodyContentTemplate>
        <div class="p-2">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Anrede</label>
                    <select class="form-select" @bind="CreateProfileModel.Salutation">
                        @foreach (var salutation in SalutationOptions)
                        {
                            <option value="@salutation">@GetSalutationLabel(salutation)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Vorname</label>
                    <input class="form-control" @bind="CreateProfileModel.FirstName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Nachname</label>
                    <input class="form-control" @bind="CreateProfileModel.LastName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Eintrittsdatum</label>
                    <input type="date" class="form-control" @bind="CreateProfileModel.EntryDate" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Austrittsdatum (optional)</label>
                    <input type="date" class="form-control" @bind="CreateProfileModel.ExitDate" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Startdatum (Onboarding)</label>
                    <input type="date" class="form-control" @bind="CreateProfileModel.StartDate" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Zieldatum (Onboarding)</label>
                    <input type="date" class="form-control" @bind="CreateProfileModel.TargetDate" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Benutzername</label>
                    <input class="form-control" @bind="CreateProfileModel.Username" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ticketnummer</label>
                    <input class="form-control" @bind="CreateProfileModel.TicketNumber" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Abteilung</label>
                    <input class="form-control" @bind="CreateProfileModel.Department" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Stellenbezeichnung</label>
                    <input class="form-control" @bind="CreateProfileModel.JobTitle" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Standort</label>
                    <input class="form-control" @bind="CreateProfileModel.Location" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Vorgesetzter</label>
                    <input class="form-control" @bind="CreateProfileModel.Supervisor" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">E-Mail</label>
                    <input class="form-control" @bind="CreateProfileModel.Email" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Phone</label>
                    <input class="form-control" @bind="CreateProfileModel.Phone" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Mobile</label>
                    <input class="form-control" @bind="CreateProfileModel.Mobile" />
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <DxButton Text="Abbrechen" RenderStyle="ButtonRenderStyle.Secondary" Click="CloseCreateProfilePopup" />
                <DxButton Text="Anlegen" RenderStyle="ButtonRenderStyle.Primary" Click="CreateProfileAsync" Enabled="@CanCreateProfile" />
            </div>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    private IGrid? Grid { get; set; }
    private DxContextMenu? GridContextMenu { get; set; }
    private DotNetObjectReference<ReportDesigner>? GridHostDotNetReference { get; set; }

    private string GridHostId { get; } = $"onboarding-grid-host-{Guid.NewGuid():N}";
    private bool GridHostInteropAttached { get; set; }

    private List<OnboardingProfileListItem> Profiles { get; set; } = new();
    private OnboardingProfile? ActiveProfileDraft { get; set; }
    private List<OnboardingAssigneeLookupItem> AssigneeLookup { get; set; } = new();

    private string? SearchText { get; set; }
    private string SelectedStatusFilterValue { get; set; } = "all";
    private bool OnlyOpenProfiles { get; set; }
    private bool IsDrawerOpen { get; set; }
    private bool ShowOnlyOpenTodos { get; set; }
    private bool CanEdit { get; set; }

    private string? UiInfoMessage { get; set; }
    private string? UiErrorMessage { get; set; }

    private int? ContextMenuProfileId { get; set; }

    private bool DeletePopupVisible { get; set; }
    private int? DeleteTargetProfileId { get; set; }
    private string DeleteTargetDisplayName { get; set; } = string.Empty;

    private bool CreatePopupVisible { get; set; }
    private OnboardingProfile CreateProfileModel { get; set; } = CreateNewProfileTemplate();
    private bool CanCreateProfile => CanEdit
        && !string.IsNullOrWhiteSpace(CreateProfileModel.FirstName)
        && !string.IsNullOrWhiteSpace(CreateProfileModel.LastName)
        && CreateProfileModel.EntryDate != default;

    private IReadOnlyList<OnboardingProfileStatus> ProfileStatuses { get; } =
    [
        OnboardingProfileStatus.Draft,
        OnboardingProfileStatus.InProgress,
        OnboardingProfileStatus.Completed,
        OnboardingProfileStatus.Archived
    ];

    private IReadOnlyList<OnboardingSalutation> SalutationOptions { get; } =
    [
        OnboardingSalutation.Unspecified,
        OnboardingSalutation.Mr,
        OnboardingSalutation.Mrs,
        OnboardingSalutation.Diverse
    ];

    private IReadOnlyList<StatusFilterItem> StatusFilterItems { get; } =
    [
        new StatusFilterItem("Alle Stati", "all"),
        new StatusFilterItem("Entwurf", nameof(OnboardingProfileStatus.Draft)),
        new StatusFilterItem("In Bearbeitung", nameof(OnboardingProfileStatus.InProgress)),
        new StatusFilterItem("Abgeschlossen", nameof(OnboardingProfileStatus.Completed)),
        new StatusFilterItem("Archiviert", nameof(OnboardingProfileStatus.Archived))
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        CanEdit = user.IsInRole("Admin") || user.IsInRole("OnboardingManager");
        AssigneeLookup = await OnboardingService.GetAssigneeLookupAsync();

        await LoadProfilesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || GridHostInteropAttached)
        {
            return;
        }

        try
        {
            GridHostDotNetReference = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("wikiBlaze.onboardingGrid.attach", GridHostId, GridHostDotNetReference);
            GridHostInteropAttached = true;
        }
        catch (JSDisconnectedException)
        {
            // Ignore teardown race conditions during disconnect/reload.
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (GridHostInteropAttached)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("wikiBlaze.onboardingGrid.detach", GridHostId);
            }
            catch (JSDisconnectedException)
            {
                // Ignore teardown race conditions during disconnect/reload.
            }
            catch (ObjectDisposedException)
            {
                // Ignore app shutdown disposal order.
            }
        }

        GridHostDotNetReference?.Dispose();
    }

    private async Task LoadProfilesAsync()
    {
        var selectedStatus = ParseStatusFilter(SelectedStatusFilterValue);
        Profiles = await OnboardingService.GetProfilesAsync(SearchText, selectedStatus, OnlyOpenProfiles);

        if (ContextMenuProfileId.HasValue && Profiles.All(item => item.Id != ContextMenuProfileId.Value))
        {
            ContextMenuProfileId = null;
        }

        if (ActiveProfileDraft is not null)
        {
            var refreshed = await OnboardingService.GetProfileAsync(ActiveProfileDraft.Id);
            ActiveProfileDraft = refreshed;
            IsDrawerOpen = refreshed is not null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnGridCustomizeElement(GridCustomizeElementEventArgs args)
    {
        if (args.ElementType != GridElementType.DataRow || args.VisibleIndex < 0)
        {
            return;
        }

        args.Attributes["data-onboarding-visible-index"] = args.VisibleIndex.ToString(CultureInfo.InvariantCulture);
    }

    [JSInvokable]
    public Task HandleGridBlankClick()
    {
        return InvokeAsync(() =>
        {
            IsDrawerOpen = false;
            ActiveProfileDraft = null;
            ContextMenuProfileId = null;
            StateHasChanged();
        });
    }

    [JSInvokable]
    public Task HandleGridRowContextMenu(int visibleIndex, double clientX, double clientY)
    {
        return InvokeAsync(async () =>
        {
            var item = GetProfileListItemByVisibleIndex(visibleIndex);
            if (item is null)
            {
                return;
            }

            ContextMenuProfileId = item.Id;

            if (GridContextMenu is not null)
            {
                var mouseArgs = new MouseEventArgs
                {
                    ClientX = clientX,
                    ClientY = clientY,
                    Button = 2,
                    Type = "contextmenu"
                };

                await GridContextMenu.ShowAsync(mouseArgs);
            }
        });
    }

    private async Task OnRowClick(GridRowClickEventArgs args)
    {
        var item = GetProfileListItemByVisibleIndex(args.VisibleIndex);
        if (item is null)
        {
            return;
        }

        var profile = await OnboardingService.GetProfileAsync(item.Id);
        if (profile is null)
        {
            return;
        }

        ContextMenuProfileId = item.Id;
        ActiveProfileDraft = profile;
        IsDrawerOpen = true;
        StateHasChanged();
    }

    private async Task OnGridContextMenuItemClick(ContextMenuItemClickEventArgs args)
    {
        var profileId = ContextMenuProfileId;
        if (!profileId.HasValue)
        {
            return;
        }

        try
        {
            switch (args.ItemInfo.Name)
            {
                case "open-details":
                    NavigationManager.NavigateTo($"/reportdesigner/details/{profileId.Value}");
                    break;
                case "toggle-open-todos":
                    await ToggleOpenTodosFromContextAsync(profileId.Value);
                    break;
                case "duplicate":
                    if (CanEdit)
                    {
                        await DuplicateProfileByIdAsync(profileId.Value);
                    }
                    break;
                case "delete":
                    if (CanEdit)
                    {
                        await OpenDeleteConfirmationAsync(profileId.Value);
                    }
                    break;
                default:
                    if (CanEdit && TryParseStatusMenuItem(args.ItemInfo.Name, out var targetStatus))
                    {
                        await ChangeProfileStatusAsync(profileId.Value, targetStatus);
                    }
                    break;
            }
        }
        catch (Exception ex)
        {
            SetUiError($"Aktion fehlgeschlagen: {ex.Message}");
        }
    }

    private async Task SaveActiveProfileAsync()
    {
        if (!CanEdit || ActiveProfileDraft is null)
        {
            return;
        }

        try
        {
            ClearUiMessages();
            ActiveProfileDraft = await OnboardingService.UpdateProfileAsync(ActiveProfileDraft);
            await LoadProfilesAsync();
            SetUiInfo("Profil wurde gespeichert.");
        }
        catch (Exception ex)
        {
            SetUiError($"Speichern fehlgeschlagen: {ex.Message}");
        }
    }

    private async Task DuplicateActiveProfileAsync()
    {
        if (!CanEdit || ActiveProfileDraft is null)
        {
            return;
        }

        await DuplicateProfileByIdAsync(ActiveProfileDraft.Id);
    }

    private async Task ToggleMeasureCompletedAsync(OnboardingMeasureEntry entry, bool isCompleted)
    {
        if (!CanEdit)
        {
            return;
        }

        await OnboardingService.SetMeasureEntryCompletedAsync(entry.Id, isCompleted);
        if (ActiveProfileDraft is not null)
        {
            ActiveProfileDraft = await OnboardingService.GetProfileAsync(ActiveProfileDraft.Id);
        }

        await LoadProfilesAsync();
    }

    private async Task ToggleChecklistCompletedAsync(OnboardingChecklistEntry entry, bool isCompleted)
    {
        if (!CanEdit)
        {
            return;
        }

        await OnboardingService.SetChecklistEntryCompletedAsync(entry.Id, isCompleted);
        if (ActiveProfileDraft is not null)
        {
            ActiveProfileDraft = await OnboardingService.GetProfileAsync(ActiveProfileDraft.Id);
        }

        await LoadProfilesAsync();
    }

    private void ToggleOpenTodoFilter()
    {
        ShowOnlyOpenTodos = !ShowOnlyOpenTodos;
    }

    private void OpenCreateProfilePopup()
    {
        ClearUiMessages();
        CreateProfileModel = CreateNewProfileTemplate();
        CreatePopupVisible = true;
    }

    private void CloseCreateProfilePopup()
    {
        CreatePopupVisible = false;
    }

    private async Task CreateProfileAsync()
    {
        if (!CanCreateProfile)
        {
            return;
        }

        try
        {
            ClearUiMessages();
            var created = await OnboardingService.CreateProfileAsync(CreateProfileModel);
            CreatePopupVisible = false;

            await LoadProfilesAsync();

            ActiveProfileDraft = created;
            IsDrawerOpen = true;
            SetUiInfo("Profil wurde angelegt.");
        }
        catch (Exception ex)
        {
            SetUiError($"Anlegen fehlgeschlagen: {ex.Message}");
        }
    }

    private async Task OpenDeleteConfirmationAsync(int profileId)
    {
        if (!CanEdit)
        {
            return;
        }

        ClearUiMessages();

        DeleteTargetProfileId = profileId;
        DeleteTargetDisplayName = Profiles.FirstOrDefault(item => item.Id == profileId)?.DisplayName ?? string.Empty;

        if (string.IsNullOrWhiteSpace(DeleteTargetDisplayName))
        {
            var profile = await OnboardingService.GetProfileAsync(profileId);
            DeleteTargetDisplayName = profile is null ? $"ID {profileId}" : GetProfileDisplayName(profile);
        }

        DeletePopupVisible = true;
    }

    private void CloseDeleteConfirmation()
    {
        DeletePopupVisible = false;
        DeleteTargetProfileId = null;
        DeleteTargetDisplayName = string.Empty;
    }

    private async Task ConfirmDeleteProfileAsync()
    {
        if (!CanEdit || !DeleteTargetProfileId.HasValue)
        {
            return;
        }

        var profileId = DeleteTargetProfileId.Value;

        try
        {
            ClearUiMessages();
            await OnboardingService.DeleteProfileAsync(profileId);

            if (ActiveProfileDraft?.Id == profileId)
            {
                ActiveProfileDraft = null;
                IsDrawerOpen = false;
            }

            if (ContextMenuProfileId == profileId)
            {
                ContextMenuProfileId = null;
            }

            CloseDeleteConfirmation();
            await LoadProfilesAsync();
            SetUiInfo("Profil wurde endgültig gelöscht.");
        }
        catch (Exception ex)
        {
            SetUiError($"Löschen fehlgeschlagen: {ex.Message}");
        }
    }

    private async Task ToggleOpenTodosFromContextAsync(int profileId)
    {
        if (!await TryLoadProfileIntoDrawerAsync(profileId))
        {
            SetUiError("Profil konnte nicht geladen werden.");
            return;
        }

        ToggleOpenTodoFilter();
        IsDrawerOpen = true;
    }

    private async Task DuplicateProfileByIdAsync(int profileId)
    {
        if (!CanEdit)
        {
            return;
        }

        ClearUiMessages();
        var duplicate = await OnboardingService.DuplicateProfileAsync(profileId);
        await LoadProfilesAsync();

        if (duplicate is null)
        {
            SetUiError("Profil konnte nicht dupliziert werden.");
            return;
        }

        ContextMenuProfileId = duplicate.Id;
        ActiveProfileDraft = duplicate;
        IsDrawerOpen = true;
        SetUiInfo("Profil wurde dupliziert.");
    }

    private async Task ChangeProfileStatusAsync(int profileId, OnboardingProfileStatus targetStatus)
    {
        if (!CanEdit)
        {
            return;
        }

        ClearUiMessages();
        var profile = await OnboardingService.GetProfileAsync(profileId);
        if (profile is null)
        {
            SetUiError("Profil konnte nicht geladen werden.");
            return;
        }

        if (profile.Status == targetStatus)
        {
            return;
        }

        profile.Status = targetStatus;
        ActiveProfileDraft = await OnboardingService.UpdateProfileAsync(profile);
        IsDrawerOpen = true;
        await LoadProfilesAsync();
        SetUiInfo("Status wurde aktualisiert.");
    }

    private async Task<bool> TryLoadProfileIntoDrawerAsync(int profileId)
    {
        var profile = await OnboardingService.GetProfileAsync(profileId);
        if (profile is null)
        {
            return false;
        }

        ContextMenuProfileId = profileId;
        ActiveProfileDraft = profile;
        IsDrawerOpen = true;
        return true;
    }

    private OnboardingProfileListItem? GetProfileListItemByVisibleIndex(int visibleIndex)
    {
        if (Grid is null || visibleIndex < 0)
        {
            return null;
        }

        try
        {
            return Grid.GetDataItem(visibleIndex) as OnboardingProfileListItem;
        }
        catch
        {
            return null;
        }
    }

    private static bool TryParseStatusMenuItem(string menuItemName, out OnboardingProfileStatus status)
    {
        switch (menuItemName)
        {
            case "status-draft":
                status = OnboardingProfileStatus.Draft;
                return true;
            case "status-in-progress":
                status = OnboardingProfileStatus.InProgress;
                return true;
            case "status-completed":
                status = OnboardingProfileStatus.Completed;
                return true;
            case "status-archived":
                status = OnboardingProfileStatus.Archived;
                return true;
            default:
                status = default;
                return false;
        }
    }

    private void ClearUiMessages()
    {
        UiInfoMessage = null;
        UiErrorMessage = null;
    }

    private void SetUiInfo(string message)
    {
        UiInfoMessage = message;
        UiErrorMessage = null;
    }

    private void SetUiError(string message)
    {
        UiInfoMessage = null;
        UiErrorMessage = message;
    }

    private List<OnboardingMeasureEntry> GetFilteredMeasureEntries(OnboardingProfile profile)
    {
        IEnumerable<OnboardingMeasureEntry> entries = profile.MeasureEntries.OrderBy(item => item.CatalogItem?.SortOrder ?? int.MaxValue).ThenBy(item => item.CreatedAt);
        if (ShowOnlyOpenTodos)
        {
            entries = entries.Where(item => !item.IsCompleted);
        }

        return entries.ToList();
    }

    private List<OnboardingChecklistEntry> GetFilteredChecklistEntries(OnboardingProfile profile)
    {
        IEnumerable<OnboardingChecklistEntry> entries = profile.ChecklistEntries.OrderBy(item => item.CatalogItem?.SortOrder ?? int.MaxValue).ThenBy(item => item.CreatedAt);
        if (ShowOnlyOpenTodos)
        {
            entries = entries.Where(item => !item.IsCompleted);
        }

        return entries.ToList();
    }

    private static OnboardingProfileStatus? ParseStatusFilter(string value)
    {
        if (string.Equals(value, "all", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return Enum.TryParse<OnboardingProfileStatus>(value, out var status) ? status : null;
    }

    private static string GetStatusLabel(OnboardingProfileStatus status)
    {
        return status switch
        {
            OnboardingProfileStatus.Draft => "Entwurf",
            OnboardingProfileStatus.InProgress => "In Bearbeitung",
            OnboardingProfileStatus.Completed => "Abgeschlossen",
            OnboardingProfileStatus.Archived => "Archiviert",
            _ => status.ToString()
        };
    }

    private static string GetStatusBadgeCss(OnboardingProfileStatus status)
    {
        return status switch
        {
            OnboardingProfileStatus.Draft => "bg-secondary",
            OnboardingProfileStatus.InProgress => "bg-primary",
            OnboardingProfileStatus.Completed => "bg-success",
            OnboardingProfileStatus.Archived => "bg-dark",
            _ => "bg-secondary"
        };
    }

    private static int GetProgressPercent(OnboardingProfile profile)
    {
        var measureDone = profile.MeasureEntries.Count(item => item.IsCompleted);
        var checklistDone = profile.ChecklistEntries.Count(item => item.IsCompleted);
        var total = profile.MeasureEntries.Count + profile.ChecklistEntries.Count;

        if (total == 0)
        {
            return 0;
        }

        return (int)Math.Round((measureDone + checklistDone) * 100d / total, MidpointRounding.AwayFromZero);
    }

    private static string GetProgressText(OnboardingProfile profile)
    {
        var measureDone = profile.MeasureEntries.Count(item => item.IsCompleted);
        var checklistDone = profile.ChecklistEntries.Count(item => item.IsCompleted);
        var totalMeasures = profile.MeasureEntries.Count;
        var totalChecklist = profile.ChecklistEntries.Count;

        return $"Maßnahmen: {measureDone}/{totalMeasures} · Tests: {checklistDone}/{totalChecklist}";
    }

    private static string GetProfileDisplayName(OnboardingProfile profile)
    {
        var firstName = profile.FirstName?.Trim();
        var lastName = profile.LastName?.Trim();
        var fullName = $"{firstName} {lastName}".Trim();

        if (!string.IsNullOrWhiteSpace(fullName))
        {
            return fullName;
        }

        return profile.FullName;
    }

    private static string GetSalutationLabel(OnboardingSalutation salutation)
    {
        return salutation switch
        {
            OnboardingSalutation.Mr => "Herr",
            OnboardingSalutation.Mrs => "Frau",
            OnboardingSalutation.Diverse => "Divers",
            _ => "Keine Angabe"
        };
    }

    private static OnboardingProfile CreateNewProfileTemplate()
    {
        return new OnboardingProfile
        {
            Salutation = OnboardingSalutation.Unspecified,
            Status = OnboardingProfileStatus.InProgress,
            EntryDate = DateTime.UtcNow.Date,
            StartDate = DateTime.UtcNow.Date,
            TargetDate = DateTime.UtcNow.Date.AddDays(7)
        };
    }

    private sealed record StatusFilterItem(string Text, string Value);
}
