@page "/"
@inject NavigationManager NavigationManager

<PageTitle>Welcome</PageTitle>

<div id="overviewDemoDropZone" class="card custom-drop-zone rounded-3 w-100 m-0">
    <span class="drop-file-icon mb-3"></span>
    <span class="drop-file-label">Drag and Drop File Here</span><span class="m-1">or</span>
    <DxButton Id="overviewDemoSelectButton"
              CssClass="m-1"
              RenderStyle="ButtonRenderStyle.Primary"
              Text="Select File" />
</div>
<DxUpload Name="myFile"
          Visible="true"
          UploadMode="UploadMode.Instant"
          AllowMultiFileUpload="false"
          ExternalSelectButtonCssSelector="#overviewDemoSelectButton"
          ExternalDropZoneCssSelector="#overviewDemoDropZone"
          ExternalDropZoneDragOverCssClass="custom-drop-zone-hover"
          MaxFileSize="15000000"
          UploadUrl="@GetUploadUrl("api/upload/upload")"
          SelectedFilesChanged="@SelectedFilesChanged"
          FilesUploadComplete="@FilesUploadComplete">
</DxUpload>
<div class="upload-validation-text info-text">
    Uploads are limited to a single .txt or .odt file up to 15 MB.
</div>
@if (!string.IsNullOrWhiteSpace(UploadStatusMessage))
{
    <div class="upload-validation-text info-text">@UploadStatusMessage</div>
}

@code {
    private string? UploadStatusMessage { get; set; }

    protected void SelectedFilesChanged(IEnumerable<UploadFileInfo> files)
    {
        var selectedFile = files.FirstOrDefault();
        UploadStatusMessage = selectedFile is null
            ? null
            : $"Datei '{selectedFile.Name}' wird hochgeladen...";
    }

    protected void FilesUploadComplete(FilesUploadCompleteEventArgs args)
    {
        UploadStatusMessage = args.Files.Any(file => file.Uploaded)
            ? "Upload erfolgreich. Ein neuer Wiki-Entwurf wurde erstellt."
            : "Upload fehlgeschlagen. Bitte Datei und Dateityp prüfen.";
    }
    protected string GetUploadUrl(string url)
    {
        return NavigationManager.ToAbsoluteUri(url).AbsoluteUri;
    }
}

<div class="main-content">
    <DxGridLayout CssClass="index-gridlayout">
        <Rows>
            <DxGridLayoutRow Height="auto" Areas="header"></DxGridLayoutRow>
            <DxGridLayoutRow Height="auto" Areas="tiles"></DxGridLayoutRow>
        </Rows>
        <Items>
            <DxGridLayoutItem Area="header" CssClass="title">
                <Template>
                    <div class="title-header-text">Wiki-Dashboard</div>
                    <div class="title-content-text">Welcome to your new Wiki-Dash Blazor Application</div>
                </Template>
            </DxGridLayoutItem>
            <DxGridLayoutItem Area="tiles" CssClass="tiles">
                <Template>
                    <IndexTile NavigateUrl="/wiki" Title="Wiki Dashboard" Description="Main Wiki-Entry-View" IconCssClass="icon-tree-list" />
                    <IndexTile NavigateUrl="/wiki/favorites" Title="Wiki Favorites" Description="Load bookmarkt views show in the web browser." IconCssClass="icon-pdf-viewer" />
                    <IndexTile NavigateUrl="/reportdesigner" Title="Onboarding Management" Description="Create report templates populated with external data." IconCssClass="icon-report-designer" />
                </Template>
            </DxGridLayoutItem>
        </Items>
    </DxGridLayout>
</div>
