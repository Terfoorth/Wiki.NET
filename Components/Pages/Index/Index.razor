@page "/"
@using System.Text.Json
@using System.Text
@using System.Text.Encodings.Web
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Wiki_Blaze.Components.DxKanban
@using Wiki_Blaze.Data.Entities
@using Wiki_Blaze.Services
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

@inject NavigationManager NavigationManager
@inject IWikiService WikiService
@inject IOnboardingService OnboardingService
@inject IUserIdResolver UserIdResolver
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JsRuntime
@inject NotificationRefreshSignal NotificationRefreshSignal

<PageTitle>Home Dashboard</PageTitle>

<div class="home-kanban-page">
    <div class="home-header">
        <h2 class="mb-1">Wiki.NET Home Dashboard</h2>
        <p class="text-muted mb-0">Wiki und Onboarding in einer Kanban View.</p>
    </div>


<i class="fa fa-flag fa-1x"></i>


    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <div class="card home-toolbar-card">
        <div class="d-flex gap-2 flex-wrap align-items-center justify-content-between">
            <div class="d-flex gap-2 flex-wrap">
                <DxButton Text="Wiki"
                          RenderStyle="@(ActiveView == HomeKanbanViewType.Wiki ? ButtonRenderStyle.Primary : ButtonRenderStyle.Secondary)"
                          Click="() => SetViewAsync(HomeKanbanViewType.Wiki)" />
                <DxButton Text="Onboarding"
                          RenderStyle="@(ActiveView == HomeKanbanViewType.Onboarding ? ButtonRenderStyle.Primary : ButtonRenderStyle.Secondary)"
                          Click="() => SetViewAsync(HomeKanbanViewType.Onboarding)" />
            </div>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <select class="form-select form-select-sm home-sort-select" value="@GetSortMode(ActiveView)" @onchange="OnSortChanged">
                    <option value="@BoardSortMode.Manual">Manuell (DnD)</option>
                    <option value="@BoardSortMode.LastActivity">Zuletzt aktiv</option>
                    <option value="@BoardSortMode.Title">Titel</option>
                </select>
                <DxCheckBox Checked="@GetCompactCards(ActiveView)"
                            CheckedChanged="@(async (bool value) => await OnCompactChanged(value))"
                            LabelText="Kompakt" />
                <DxButton Text="Reset Layout" RenderStyle="ButtonRenderStyle.Secondary" Click="ResetLayoutAsync" />
                <DxButton Text="Reload" RenderStyle="ButtonRenderStyle.Secondary" Click="LoadBoardsAsync" />
            </div>
        </div>
        <div class="home-toolbar-columns">
            @foreach (var column in CurrentBoard.Columns.OrderBy(c => c.SortOrder))
            {
                var columnRenderKey = GetColumnRenderKey(ActiveView, column.Key);
                <DxCheckBox @key="columnRenderKey"
                            Checked="@IsColumnVisible(ActiveView, column.Key)"
                            CheckedChanged="@(async (bool value) => await OnColumnVisibilityChangedAsync(ActiveView, column.Key, value))"
                            LabelText="@column.Title" />
            }
        </div>
    </div>

    @if (VisibleColumns.Count == 0)
    {
        <div class="alert alert-warning mb-0">Alle Spalten sind ausgeblendet. Aktiviere mindestens eine Spalte in der Toolbar.</div>
    }
    else
    {
        <div class="home-kanban-board-shell">
            <DxKanban Data="@RenderCards"
                      CardDropped="OnCardDroppedAsync"
                      ColumnsReordered="OnColumnsReorderedAsync"
                      CssClass="@GetKanbanCssClass()"
                      ColumnNameFieldName="ColumnKey"
                      AllowColumnReorder="true">
                <Columns>
                    @for (var index = 0; index < VisibleColumns.Count; index++)
                    {
                        var column = VisibleColumns[index];
                        var columnRenderKey = GetColumnRenderKey(ActiveView, column.Key);
                        <DxKanbanColumn @key="columnRenderKey"
                                        ColumnName="@column.Key"
                                        Caption="@column.Title"
                                        VisibleIndex="@index"
                                        AllowCardDrag="@(column.CardsDraggable && GetSortMode(ActiveView) == BoardSortMode.Manual)"
                                        AllowCardDrop="@(column.AcceptDrop && GetSortMode(ActiveView) == BoardSortMode.Manual)" />
                    }
                </Columns>
                <CardTemplate Context="ctx">
                    @{
                        var card = (HomeKanbanCardDto)ctx;
                    }
                    <div class="home-kanban-card @(GetCompactCards(ActiveView) ? "is-compact" : string.Empty) @(card.IsReminderActive ? (card.IsReminderOverdue ? "is-reminder-overdue" : "is-reminder-active") : string.Empty)"
                         @oncontextmenu="(args) => OnCardContextMenuAsync(args, card)"
                         @oncontextmenu:preventDefault>
                        <div class="home-kanban-card-header">
                            <div class="home-kanban-card-header-row">
                                <div class="home-kanban-card-title">@card.Title</div>
                                @if (ShowCardDragHint(card))
                                {
                                    <span class="home-kanban-drag-hint" title="Zum Verschieben den Drag-Handle links an der Karte verwenden.">&#8942;&#8942;</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(card.Subtitle))
                            {
                                <div class="home-kanban-card-subtitle">@card.Subtitle</div>
                            }
                            @if (card.IsReminderActive && !string.IsNullOrWhiteSpace(card.ReminderLabel))
                            {
                                <div class="home-kanban-reminder-badge @(card.IsReminderOverdue ? "is-overdue" : "is-due")">@card.ReminderLabel</div>
                            }
                        </div>
                        <div class="home-kanban-card-meta">
                            <div class="home-meta-row">
                                <span class="home-meta-label">Ersteller</span>
                                <span class="home-meta-value">@card.CreatorDisplayName</span>
                            </div>
                            <div class="home-meta-row">
                                <span class="home-meta-label">Besitzer/Bearbeiter</span>
                                <span class="home-meta-value">@(string.IsNullOrWhiteSpace(card.OwnerDisplayName) ? "-" : card.OwnerDisplayName)</span>
                            </div>
                            <div class="home-meta-row">
                                <span class="home-meta-label">Kategorie/Rolle</span>
                                <span class="home-meta-value">@card.CategoryOrRole</span>
                            </div>
                        </div>
                        <div class="home-kanban-card-footer">
                            <div class="home-kanban-card-activity">
                                Aktivitaet: @card.LastActivityUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </div>
                            <div class="home-kanban-card-links">
                                @if (card.EntityType == HomeKanbanCardEntityType.WikiEntry)
                                {
                                    <button type="button"
                                            class="btn btn-link p-0 link-primary home-card-action"
                                            data-no-drag="true"
                                            @onclick="() => OpenCard(card)"
                                            @onclick:stopPropagation="true"
                                            @onmousedown:stopPropagation="true"
                                            @onpointerdown:stopPropagation="true">Eintrag Ansicht</button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-link p-0 link-primary home-card-action"
                                            data-no-drag="true"
                                            @onclick="() => OpenDetailsAsync(card)"
                                            @onclick:stopPropagation="true"
                                            @onmousedown:stopPropagation="true"
                                            @onpointerdown:stopPropagation="true">Details</button>
                                }
                                <button type="button"
                                        class="btn btn-link p-0 link-secondary home-card-action"
                                        data-no-drag="true"
                                        @onclick="() => OpenCommentsAsync(card)"
                                        @onclick:stopPropagation="true"
                                        @onmousedown:stopPropagation="true"
                                        @onpointerdown:stopPropagation="true">Kommentare (@card.CommentCount)</button>
                            </div>
                        </div>
                    </div>
                </CardTemplate>
            </DxKanban>
        </div>
    }

    <div id="overviewDemoDropZone" class="card custom-drop-zone rounded-3 w-100 m-0">
        <span class="drop-file-icon mb-3"></span>
        <span class="drop-file-label">Drag and Drop File Here</span><span class="m-1">or</span>
        <DxButton Id="overviewDemoSelectButton" CssClass="m-1" RenderStyle="ButtonRenderStyle.Primary" Text="Select File" />
    </div>
    <DxUpload Name="myFile"
              Visible="@UploadVisible"
              ExternalSelectButtonCssSelector="#overviewDemoSelectButton"
              ExternalDropZoneCssSelector="#overviewDemoDropZone"
              ExternalDropZoneDragOverCssClass="custom-drop-zone-hover"
              MaxFileSize="15000000"
              UploadUrl="@GetUploadUrl("api/Upload/Upload/")"
              SelectedFilesChanged="@SelectedFilesChanged" />
</div>

<DxContextMenu @ref="WikiCardContextMenu"
               ItemClick="OnCardContextMenuItemClick">
    <Items>
        <DxContextMenuItem Text="Oeffnen" IconCssClass="oi oi-eye" Name="open" />
        <DxContextMenuItem Text="Kommentare" IconCssClass="oi oi-comment-square" Name="comments" />
        <DxContextMenuItem Text="Loeschen" IconCssClass="oi oi-trash" Name="wiki-delete" BeginGroup="true" />
    </Items>
</DxContextMenu>

<DxContextMenu @ref="OnboardingCardContextMenu"
               ItemClick="OnCardContextMenuItemClick">
    <Items>
        <DxContextMenuItem Text="Oeffnen" IconCssClass="oi oi-eye" Name="open" />
        <DxContextMenuItem Text="Kommentare" IconCssClass="oi oi-comment-square" Name="comments" />
        <DxContextMenuItem Text="Details oeffnen" IconCssClass="oi oi-info" Name="onboarding-quick-details" BeginGroup="true" />
        <DxContextMenuItem Text="Zur Detailseite" IconCssClass="oi oi-external-link" Name="onboarding-open-details-page" />
    </Items>
</DxContextMenu>

<DxPopup HeaderText="@PopupTitle" Width="92vw" Height="88vh" @bind-Visible="CommentsVisible" CloseOnOutsideClick="true">
    <BodyContentTemplate Context="commentPopupContext">
        @if (CommentCard is null)
        {
            <div class="text-muted">Kein Eintrag ausgewaehlt.</div>
        }
        else
        {
            var selectedCard = CommentCard!;
            <div class="home-comment-layout">
                <div class="home-comment-main">
                    <div class="home-comment-list-shell">
                        <div class="home-comment-list">
                            @if (Comments.Count == 0)
                            {
                                <div class="home-comment-empty text-muted">Noch keine Kommentare vorhanden.</div>
                            }
                            @foreach (var item in Comments)
                            {
                                <div class="home-comment-item">
                                    <div class="home-comment-header-row">
                                        <strong>@item.AuthorDisplayName</strong>
                                        <div class="home-comment-header-meta">
                                            <span class="text-muted">@item.CreatedAtUtc.ToLocalTime().ToString("dd.MM HH:mm")</span>
                                            @if (CanDeleteComment(item))
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-link text-danger p-0 home-comment-delete-btn"
                                                        aria-label="Kommentar loeschen"
                                                        disabled="@(DeletingCommentId == item.Id)"
                                                        @onclick="() => DeleteCommentAsync(item)">
                                                    @(DeletingCommentId == item.Id ? "Loeschen..." : "Loeschen")
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    <div class="home-comment-text">@RenderFormattedComment(item.Text)</div>
                                    @if (item.Mentions.Count > 0)
                                    {
                                        <div class="home-comment-mentions">
                                            @foreach (var mention in item.Mentions)
                                            {
                                                var mentionLabel = GetMentionLabel(mention);
                                                @if (!string.IsNullOrWhiteSpace(mention.TargetUrl))
                                                {
                                                    <a href="@mention.TargetUrl"
                                                       class="home-comment-mention-tag"
                                                       target="_blank"
                                                       rel="noopener noreferrer">@mentionLabel</a>
                                                }
                                                else
                                                {
                                                    <span class="home-comment-mention-tag">@mentionLabel</span>
                                                }
                                            }
                                        </div>
                                    }
                                    @if (item.Attachments.Count > 0)
                                    {
                                        <div class="d-flex flex-wrap gap-2 mt-2">
                                            @foreach (var attachment in item.Attachments)
                                            {
                                                @if (attachment.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <img src="@GetAttachmentPreview(attachment)"
                                                         alt="@attachment.FileName"
                                                         style="max-height:110px;max-width:160px;border-radius:6px;border:1px solid rgba(0,0,0,.1);" />
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-dark border">@attachment.FileName</span>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="home-comment-composer-shell">
                        <div class="home-comment-composer" @ref="CommentComposerDropZoneElement">
                            <div class="home-comment-toolbar" role="toolbar" aria-label="Kommentar Werkzeuge">
                                <button type="button" class="btn btn-sm btn-outline-secondary" aria-label="Fett" @onclick='() => ApplyFormattingToken("bold")'><strong>B</strong></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" aria-label="Kursiv" @onclick='() => ApplyFormattingToken("italic")'><em>I</em></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" aria-label="Code" @onclick='() => ApplyFormattingToken("code")'>Code</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" aria-label="Liste" @onclick='() => ApplyFormattingToken("list")'>Liste</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" aria-label="Emoji einfuegen" @onclick="ToggleEmojiPicker">Emoji</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" aria-label="Benutzer erwaehnen" @onclick="ToggleMentionPickerAsync">@("@")</button>
                            </div>

                            @if (ShowEmojiPicker)
                            {
                                <div class="home-comment-emoji-panel">
                                    @foreach (var emoji in EmojiPalette)
                                    {
                                        <button type="button" class="home-comment-emoji-btn" @onclick="() => AddEmoji(emoji)">@emoji</button>
                                    }
                                </div>
                            }

                            @if (ShowMentionPicker)
                            {
                                <div class="home-comment-mention-panel">
                                    <input class="form-control form-control-sm"
                                           placeholder="Benutzer suchen"
                                           aria-label="Benutzer suchen"
                                           @bind="MentionSearchText"
                                           @bind:event="oninput" />
                                    @if (!MentionLookupLoaded)
                                    {
                                        <div class="small text-muted mt-2">Benutzer werden geladen...</div>
                                    }
                                    else if (FilteredMentionLookup.Count == 0)
                                    {
                                        <div class="small text-muted mt-2">Keine passenden Benutzer gefunden.</div>
                                    }
                                    else
                                    {
                                        <div class="home-comment-mention-results">
                                            @foreach (var user in FilteredMentionLookup)
                                            {
                                                <button type="button"
                                                        class="home-comment-mention-option"
                                                        @onclick="() => SelectMention(user)">
                                                    <span class="home-comment-mention-name">@user.DisplayName</span>
                                                    @if (!string.IsNullOrWhiteSpace(user.Email))
                                                    {
                                                        <span class="home-comment-mention-mail">@user.Email</span>
                                                    }
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            <textarea class="form-control home-comment-input"
                                      rows="4"
                                      placeholder="@CommentNullText"
                                      aria-label="Kommentar Eingabe"
                                      @bind="NewCommentText"
                                      @bind:event="oninput"
                                      @onkeydown="OnCommentInputKeyDown"></textarea>

                            @if (SelectedMentions.Count > 0)
                            {
                                <div class="home-comment-chip-list">
                                    @foreach (var mention in SelectedMentions)
                                    {
                                        <span class="home-comment-chip">
                                            @($"@{mention.DisplayName}")
                                            <button type="button"
                                                    class="home-comment-chip-remove"
                                                    aria-label="@($"{mention.DisplayName} entfernen")"
                                                    @onclick="() => RemoveMention(mention.UserId)">x</button>
                                        </span>
                                    }
                                </div>
                            }

                            @if (PendingAttachmentPreviews.Count > 0)
                            {
                                <div class="home-comment-attachment-grid">
                                    @for (var index = 0; index < PendingAttachmentPreviews.Count; index++)
                                    {
                                        var preview = PendingAttachmentPreviews[index];
                                        <div class="home-comment-attachment-card">
                                            <img src="@preview.PreviewUrl"
                                                 alt="@preview.FileName"
                                                 class="home-comment-attachment-image" />
                                            <div class="home-comment-attachment-meta">
                                                <span class="home-comment-attachment-name">@preview.FileName</span>
                                                <button type="button"
                                                        class="btn btn-sm btn-link text-danger p-0"
                                                        aria-label="@($"{preview.FileName} entfernen")"
                                                        @onclick="() => RemovePendingAttachment(index)">Entfernen</button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(CommentValidationMessage))
                            {
                                <div class="alert alert-warning py-1 px-2 mt-2 mb-0" role="alert">@CommentValidationMessage</div>
                            }

                            <div class="d-flex gap-2 mt-2 flex-wrap align-items-center">
                                <InputFile OnChange="OnCommentFilesChanged"
                                           multiple
                                           accept="image/gif,image/png,image/jpeg,image/webp" />
                                <span class="small text-muted">Drag &amp; Drop oder Paste ist ebenfalls aktiv (max 4 Dateien, je 8 MB).</span>
                                <DxButton Text="@(IsSendingComment ? "Senden..." : "Senden")"
                                          RenderStyle="ButtonRenderStyle.Primary"
                                          Enabled="@CanSendComment"
                                          Click="SendCommentAsync" />
                            </div>
                        </div>
                    </div>
                </div>
                <aside class="home-comment-detail">
                    <div class="home-comment-detail-header">
                        <h6 class="mb-0">Uebersicht / Aktueller Stand</h6>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary home-comment-detail-toggle"
                                @onclick="ToggleCommentDetailPanel">@(CommentDetailsExpanded ? "Ausblenden" : "Einblenden")</button>
                    </div>
                    <div class="home-comment-detail-body @(CommentDetailsExpanded ? "is-expanded" : "is-collapsed")">
                        <div class="home-comment-detail-summary">
                            <div class="home-comment-detail-title">@selectedCard.Title</div>
                            @if (!string.IsNullOrWhiteSpace(selectedCard.Subtitle))
                            {
                                <div class="home-comment-detail-subtitle">@selectedCard.Subtitle</div>
                            }
                        </div>

                        @if (CommentScope == HomeCommentScope.Onboarding)
                        {
                            @if (IsCommentDetailLoading)
                            {
                                <div class="text-muted small">Detaildaten werden geladen...</div>
                            }
                            else if (CommentQuickDetail is null)
                            {
                                <div class="text-muted small">Keine Detaildaten verfuegbar.</div>
                            }
                            else
                            {
                                <div class="home-comment-detail-grid">
                                    <div class="home-comment-detail-row"><span>Name</span><strong>@CommentQuickDetail.FullName</strong></div>
                                    <div class="home-comment-detail-row"><span>Status</span><strong>@GetStatusLabel(CommentQuickDetail.Status)</strong></div>
                                    <div class="home-comment-detail-row"><span>Abteilung</span><strong>@(string.IsNullOrWhiteSpace(CommentQuickDetail.Department) ? "-" : CommentQuickDetail.Department)</strong></div>
                                    <div class="home-comment-detail-row"><span>Rolle</span><strong>@(string.IsNullOrWhiteSpace(CommentQuickDetail.JobTitle) ? "-" : CommentQuickDetail.JobTitle)</strong></div>
                                    <div class="home-comment-detail-row"><span>Betreuung</span><strong>@(string.IsNullOrWhiteSpace(CommentQuickDetail.AssignedAgentDisplayName) ? "-" : CommentQuickDetail.AssignedAgentDisplayName)</strong></div>
                                    <div class="home-comment-detail-row"><span>Massnahmen</span><strong>@($"{CommentQuickDetail.MeasureTotalCount - CommentQuickDetail.MeasureOpenCount}/{CommentQuickDetail.MeasureTotalCount}")</strong></div>
                                    <div class="home-comment-detail-row"><span>Tests</span><strong>@($"{CommentQuickDetail.ChecklistTotalCount - CommentQuickDetail.ChecklistOpenCount}/{CommentQuickDetail.ChecklistTotalCount}")</strong></div>
                                </div>

                                @if (CommentQuickDetail.OpenMeasureItems.Count > 0)
                                {
                                    <div class="home-comment-detail-list-title">Offene Massnahmen</div>
                                    <ul class="home-comment-detail-list">
                                        @foreach (var item in CommentQuickDetail.OpenMeasureItems)
                                        {
                                            <li>@item</li>
                                        }
                                    </ul>
                                }

                                @if (CommentQuickDetail.OpenChecklistItems.Count > 0)
                                {
                                    <div class="home-comment-detail-list-title">Offene Tests</div>
                                    <ul class="home-comment-detail-list">
                                        @foreach (var item in CommentQuickDetail.OpenChecklistItems)
                                        {
                                            <li>@item</li>
                                        }
                                    </ul>
                                }
                            }
                        }
                        else
                        {
                            <div class="home-comment-detail-grid">
                                <div class="home-comment-detail-row"><span>Ersteller</span><strong>@selectedCard.CreatorDisplayName</strong></div>
                                <div class="home-comment-detail-row"><span>Besitzer</span><strong>@(string.IsNullOrWhiteSpace(selectedCard.OwnerDisplayName) ? "-" : selectedCard.OwnerDisplayName)</strong></div>
                                <div class="home-comment-detail-row"><span>Kategorie</span><strong>@selectedCard.CategoryOrRole</strong></div>
                                <div class="home-comment-detail-row"><span>Aktivitaet</span><strong>@selectedCard.LastActivityUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong></div>
                            </div>
                        }

                        <div class="home-comment-detail-actions">
                            <button type="button" class="btn btn-sm btn-primary" @onclick="() => OpenCard(selectedCard)">Eintrag oeffnen</button>
                            @if (selectedCard.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        @onclick='() => NavigationManager.NavigateTo($"/reportdesigner/details/{selectedCard.EntryId}")'>Zur Detailseite</button>
                            }
                        </div>
                    </div>
                </aside>
            </div>
        }
    </BodyContentTemplate>
</DxPopup>
<DxPopup HeaderText="Onboarding Details" Width="840px" Height="600px" @bind-Visible="DetailsVisible" CloseOnOutsideClick="true">
    <BodyContentTemplate Context="detailPopupContext">
        @if (QuickDetail is null)
        {
            <div class="text-muted">Keine Daten verfuegbar.</div>
        }
        else
        {
            <DxFormLayout>
                <DxFormLayoutItem Caption="Name">@QuickDetail.FullName</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Abteilung">@QuickDetail.Department</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Stellenbezeichnung">@QuickDetail.JobTitle</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Status">@GetStatusLabel(QuickDetail.Status)</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Massnahmen">@($"{QuickDetail.MeasureTotalCount - QuickDetail.MeasureOpenCount}/{QuickDetail.MeasureTotalCount} erledigt")</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Tests">@($"{QuickDetail.ChecklistTotalCount - QuickDetail.ChecklistOpenCount}/{QuickDetail.ChecklistTotalCount} erledigt")</DxFormLayoutItem>
            </DxFormLayout>
            <div class="d-flex justify-content-end mt-3">
                <DxButton Text="Zur kompletten Detailseite" RenderStyle="ButtonRenderStyle.Primary" NavigateUrl="@($"/reportdesigner/details/{QuickDetail.ProfileId}")" />
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

@code {
    private const string SettingsKeyPrefix = "wikiBlaze.homeKanban.settings";
    private const int MaxCommentFileBytes = 8 * 1024 * 1024;
    private const int MaxCommentAttachmentCount = 4;
    private const int MaxCommentMentions = 10;
    private const string CommentNullText = "Kommentar schreiben";
    private static readonly HashSet<string> AllowedCommentImageTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "image/gif",
        "image/png",
        "image/jpeg",
        "image/webp"
    };
    private static readonly Regex BoldPattern = new(@"\*\*(.+?)\*\*", RegexOptions.Singleline | RegexOptions.Compiled);
    private static readonly Regex ItalicPattern = new(@"_(.+?)_", RegexOptions.Singleline | RegexOptions.Compiled);
    private static readonly Regex CodePattern = new(@"`([^`]+)`", RegexOptions.Singleline | RegexOptions.Compiled);
    private static readonly Regex UrlPattern = new(@"(https?://[^\s]+|www\.[^\s]+)", RegexOptions.IgnoreCase | RegexOptions.Compiled);
    private static readonly IReadOnlyList<string> EmojiPalette =
    [
        "\U0001F600",
        "\U0001F642",
        "\U0001F609",
        "\U0001F389",
        "\u2705",
        "\U0001F680",
        "\U0001F4A1",
        "\U0001F440"
    ];

