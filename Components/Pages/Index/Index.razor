    private List<HomeKanbanCardDto> RenderCards
    {
        get
        {
            var sortMode = GetSortMode(ActiveView);
            var visibleColumnKeys = VisibleColumns
                .Select(column => column.Key)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            return CurrentBoard.Cards
                .Where(card => visibleColumnKeys.Contains(card.ColumnKey))
                .OrderBy(card => CurrentBoard.Columns.FirstOrDefault(col => col.Key == card.ColumnKey)?.SortOrder ?? int.MaxValue)
                .ThenBy(card => sortMode == BoardSortMode.Title ? 0 : 1)
                .ThenBy(card => sortMode == BoardSortMode.Title ? card.Title : string.Empty, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(card => sortMode == BoardSortMode.LastActivity ? card.LastActivityUtc : DateTime.MinValue)
                .ThenBy(card => card.SortOrder)
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CurrentUserId = UserIdResolver.ResolveCurrentUserId(authState.User);
        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            ErrorMessage = "Benutzer konnte nicht aufgeloest werden.";
            return;
        }

        await LoadBoardsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSettingsAsync();
            StateHasChanged();
        }

        if (CommentsVisible && CommentCard is not null)
        {
            await EnsureCommentComposerInteropAsync();
        }
        else
        {
            await DisposeCommentComposerInteropAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeCommentComposerInteropAsync();
        if (CommentComposerModule is not null)
        {
            try
            {
                await CommentComposerModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore disconnect race during shutdown.
            }
        }

        CommentComposerDotNetRef?.Dispose();
    }

    private async Task LoadBoardsAsync()
    {
        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            return;
        }

        var wikiTask = WikiService.GetHomeKanbanBoardAsync(CurrentUserId);
        var onboardingTask = OnboardingService.GetHomeKanbanBoardAsync(CurrentUserId);
        await Task.WhenAll(wikiTask, onboardingTask);
        WikiBoard = await wikiTask;
        OnboardingBoard = await onboardingTask;
    }

    private async Task SetViewAsync(HomeKanbanViewType view)
    {
