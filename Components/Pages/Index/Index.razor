    private async Task OnCardDroppedAsync(GridItemsDroppedEventArgs args)
    {
        if (GetSortMode(ActiveView) != BoardSortMode.Manual || args.DroppedItems.Count == 0 || args.DroppedItems[0] is not HomeKanbanCardDto dropped)
        {
            return;
        }

        var target = args.Grid.KeyFieldName;
        if (string.IsNullOrWhiteSpace(target) || !CanMove(dropped.ColumnKey, target))
        {
            await LoadBoardsAsync();
            return;
        }

        var source = dropped.ColumnKey;
        var cards = CurrentBoard.Cards;
        var targetCard = args.TargetItem as HomeKanbanCardDto;
        cards.Remove(dropped);
        dropped.ColumnKey = target;
        if (targetCard is null)
        {
            cards.Add(dropped);
        }
        else
        {
            var idx = cards.IndexOf(targetCard);
            cards.Insert(idx, dropped);
        }

        NormalizeOrder(CurrentBoard);
        var targetIndex = cards.Where(c => c.ColumnKey == target).OrderBy(c => c.SortOrder).ToList().FindIndex(c => c.EntryId == dropped.EntryId);
        var req = new MoveCardRequest
        {
            ViewType = ActiveView,
            EntityType = dropped.EntityType,
            EntryId = dropped.EntryId,
            SourceColumnKey = source,
            TargetColumnKey = target,
            TargetIndex = Math.Max(targetIndex, 0)
        };

        var ok = ActiveView == HomeKanbanViewType.Wiki
            ? await WikiService.MoveHomeKanbanCardAsync(CurrentUserId!, req)
            : await OnboardingService.MoveHomeKanbanCardAsync(CurrentUserId!, req);

        if (!ok)
        {
            await LoadBoardsAsync();
        }
    }

    private async Task OnColumnsReorderedAsync(IReadOnlyList<string> orderedColumnKeys)
    {
        if (string.IsNullOrWhiteSpace(CurrentUserId) || orderedColumnKeys.Count == 0)
        {
            return;
        }

        var normalized = NormalizeColumnOrder(CurrentBoard.Columns, orderedColumnKeys);
        var current = CurrentBoard.Columns
            .OrderBy(column => column.SortOrder)
            .Select(column => column.Key)
            .ToList();

        if (current.SequenceEqual(normalized, StringComparer.OrdinalIgnoreCase))
        {
            return;
        }

        ApplyColumnOrder(CurrentBoard.Columns, normalized);
        await SaveColumnOrderAsync(ActiveView, normalized);
        await LoadBoardsAsync();
    }

    private async Task OpenDetailsAsync(HomeKanbanCardDto card)
    {
        if (card.EntityType != HomeKanbanCardEntityType.OnboardingProfile)
        {
            return;
        }

        QuickDetail = await OnboardingService.GetQuickDetailAsync(card.EntryId);
        DetailsVisible = QuickDetail is not null;
    }

    private async Task OpenCommentsAsync(HomeKanbanCardDto card)
    {
        if (CommentsVisible)
        {
            CommentsVisible = false;
            await InvokeAsync(StateHasChanged);
        }

        ErrorMessage = null;
        CommentCard = card;
        CommentScope = card.EntityType == HomeKanbanCardEntityType.WikiEntry ? HomeCommentScope.Wiki : HomeCommentScope.Onboarding;
        CommentQuickDetail = null;
        CommentDetailsExpanded = true;
        IsCommentDetailLoading = CommentScope == HomeCommentScope.Onboarding;
        CommentsVisible = true;
        ResetCommentComposerState();

        Task<OnboardingQuickDetailDto?>? detailTask = null;
        if (CommentScope == HomeCommentScope.Onboarding)
        {
            detailTask = OnboardingService.GetQuickDetailAsync(card.EntryId);
        }

        await Task.WhenAll(EnsureMentionLookupAsync(), ReloadCommentsAsync());

        if (detailTask is not null)
        {
            try
            {
                CommentQuickDetail = await detailTask;
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Detaildaten konnten nicht geladen werden: {ex.Message}";
            }
            finally
            {
                IsCommentDetailLoading = false;
            }
        }
        else
        {
            IsCommentDetailLoading = false;
        }
    }

