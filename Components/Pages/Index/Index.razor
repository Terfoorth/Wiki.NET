    private void AddEmoji(string emoji)
    {
        if (string.IsNullOrWhiteSpace(emoji))
        {
            return;
        }

        NewCommentText = $"{NewCommentText}{emoji}";
    }

    private void ApplyFormattingToken(string mode)
    {
        var token = mode switch
        {
            "bold" => "**Fett**",
            "italic" => "_Kursiv_",
            "code" => "`Code`",
            "list" => "\n- Punkt",
            _ => string.Empty
        };

        if (string.IsNullOrWhiteSpace(token))
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(NewCommentText) && !char.IsWhiteSpace(NewCommentText[^1]))
        {
            NewCommentText += " ";
        }

        NewCommentText += token;
    }

    private void SelectMention(OnboardingAssigneeLookupItem user)
    {
        if (SelectedMentions.Any(mention => string.Equals(mention.UserId, user.UserId, StringComparison.Ordinal)))
        {
            return;
        }

        if (SelectedMentions.Count >= MaxCommentMentions)
        {
            CommentValidationMessage = $"Maximal {MaxCommentMentions} Mentions pro Kommentar sind erlaubt.";
            return;
        }

        var displayName = string.IsNullOrWhiteSpace(user.DisplayName) ? user.UserName ?? user.UserId : user.DisplayName;
        SelectedMentions.Add(new CommentMentionInputDto
        {
            UserId = user.UserId,
            DisplayName = displayName,
            Email = user.Email
        });

        if (!string.IsNullOrWhiteSpace(NewCommentText) && !char.IsWhiteSpace(NewCommentText[^1]))
        {
            NewCommentText += " ";
        }

        NewCommentText += $"@{displayName} ";
        MentionSearchText = string.Empty;
        CommentValidationMessage = null;
    }

    private void RemoveMention(string userId)
    {
        SelectedMentions.RemoveAll(mention => string.Equals(mention.UserId, userId, StringComparison.Ordinal));
    }

    private void RemovePendingAttachment(int index)
    {
        if (index < 0 || index >= PendingCommentFiles.Count)
        {
            return;
        }

        PendingCommentFiles.RemoveAt(index);
        PendingAttachmentPreviews.RemoveAt(index);
        CommentValidationMessage = null;
    }

    private bool CanDeleteComment(HomeEntryCommentDto comment)
    {
        return !string.IsNullOrWhiteSpace(CurrentUserId)
               && string.Equals(comment.AuthorId, CurrentUserId, StringComparison.Ordinal);
    }

    private async Task DeleteCommentAsync(HomeEntryCommentDto comment)
    {
        if (!CanDeleteComment(comment) || DeletingCommentId.HasValue)
        {
            return;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Kommentar wirklich loeschen?");
        if (!confirmed)
        {
            return;
        }

        DeletingCommentId = comment.Id;
        CommentValidationMessage = null;

        try
        {
            if (comment.Scope == HomeCommentScope.Wiki)
            {
                await WikiService.DeleteHomeCommentAsync(CurrentUserId, comment.Id);
            }
            else
            {
                await OnboardingService.DeleteHomeCommentAsync(CurrentUserId, comment.Id);
            }

            await ReloadCommentsAsync();
            await LoadBoardsAsync();
            NotificationRefreshSignal.RequestRefresh();
        }
        catch (Exception ex)
        {
            CommentValidationMessage = $"Kommentar konnte nicht geloescht werden: {ex.Message}";
        }
        finally
        {
            DeletingCommentId = null;
        }
    }

    private async Task EnsureMentionLookupAsync()
    {
        if (MentionLookupLoaded)
        {
            return;
        }

        try
        {
            MentionLookup = await OnboardingService.GetAssigneeLookupAsync();
            MentionLookupLoaded = true;
        }
        catch (Exception ex)
        {
            CommentValidationMessage = $"Benutzerliste konnte nicht geladen werden: {ex.Message}";
            MentionLookupLoaded = false;
        }
    }

    private List<OnboardingAssigneeLookupItem> BuildFilteredMentionLookup()
    {
        if (!MentionLookupLoaded)
        {
            return new List<OnboardingAssigneeLookupItem>();
        }

        var selectedIds = SelectedMentions
            .Select(mention => mention.UserId)
            .Where(userId => !string.IsNullOrWhiteSpace(userId))
            .ToHashSet(StringComparer.Ordinal);

        var query = MentionLookup.Where(user => !selectedIds.Contains(user.UserId));
        if (!string.IsNullOrWhiteSpace(MentionSearchText))
        {
            var search = MentionSearchText.Trim();
            query = query.Where(user =>
                user.DisplayName.Contains(search, StringComparison.CurrentCultureIgnoreCase)
                || (!string.IsNullOrWhiteSpace(user.Email) && user.Email.Contains(search, StringComparison.CurrentCultureIgnoreCase))
                || (!string.IsNullOrWhiteSpace(user.UserName) && user.UserName.Contains(search, StringComparison.CurrentCultureIgnoreCase)));
        }

        return query
            .OrderBy(user => user.DisplayName, StringComparer.CurrentCultureIgnoreCase)
            .Take(12)
            .ToList();
    }

    private void ResetCommentComposerState()
    {
        NewCommentText = string.Empty;
        PendingCommentFiles.Clear();
        PendingAttachmentPreviews.Clear();
        SelectedMentions.Clear();
        MentionSearchText = string.Empty;
        ShowMentionPicker = false;
        ShowEmojiPicker = false;
        IsSendingComment = false;
        DeletingCommentId = null;
        CommentValidationMessage = null;
    }

    private async Task AddCommentFilesAsync(IReadOnlyList<IBrowserFile> files)
    {
        foreach (var file in files)
        {
            if (PendingCommentFiles.Count >= MaxCommentAttachmentCount)
            {
                CommentValidationMessage = $"Maximal {MaxCommentAttachmentCount} Dateien sind erlaubt.";
                break;
            }

            try
            {
                await using var stream = file.OpenReadStream(MaxCommentFileBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                TryAddPendingAttachment(file.Name, file.ContentType, ms.ToArray());
            }
            catch
            {
                CommentValidationMessage = $"Datei {file.Name} konnte nicht gelesen werden.";
            }
        }
    }

    [JSInvokable]
    public async Task HandleCommentPastedOrDroppedFile(string fileName, string contentType, string base64Content, long sizeBytes)
    {
        if (string.IsNullOrWhiteSpace(base64Content))
        {
            return;
        }

        if (sizeBytes <= 0 || sizeBytes > MaxCommentFileBytes)
        {
            CommentValidationMessage = $"Datei {fileName} ist zu gross oder leer (max. 8 MB).";
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var content = Convert.FromBase64String(base64Content);
            TryAddPendingAttachment(fileName, contentType, content);
        }
        catch
        {
            CommentValidationMessage = $"Datei {fileName} konnte nicht verarbeitet werden.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private bool TryAddPendingAttachment(string fileName, string contentType, byte[] content)
    {
        if (PendingCommentFiles.Count >= MaxCommentAttachmentCount)
        {
            CommentValidationMessage = $"Maximal {MaxCommentAttachmentCount} Dateien sind erlaubt.";
            return false;
        }

        if (content.Length == 0 || content.Length > MaxCommentFileBytes)
        {
            CommentValidationMessage = $"Datei {fileName} ist zu gross oder leer (max. 8 MB).";
            return false;
        }

        var normalizedContentType = string.IsNullOrWhiteSpace(contentType)
            ? "application/octet-stream"
            : contentType.Trim();
        if (!AllowedCommentImageTypes.Contains(normalizedContentType))
        {
            CommentValidationMessage = $"Dateityp {normalizedContentType} wird nicht unterstuetzt.";
            return false;
        }

        PendingCommentFiles.Add(new CommentAttachmentInputDto
        {
            FileName = fileName,
            ContentType = normalizedContentType,
            Content = content
        });
        PendingAttachmentPreviews.Add(new PendingCommentPreview
        {
            FileName = fileName,
            PreviewUrl = $"data:{normalizedContentType};base64,{Convert.ToBase64String(content)}"
        });

        CommentValidationMessage = null;
        return true;
    }

    private MarkupString RenderFormattedComment(string text)
    {
        return new MarkupString(FormatCommentTextAsHtml(text));
    }

    private static string FormatCommentTextAsHtml(string? text)
    {
        var encoded = HtmlEncoder.Default.Encode(text ?? string.Empty);
        encoded = BoldPattern.Replace(encoded, "<strong>$1</strong>");
        encoded = ItalicPattern.Replace(encoded, "<em>$1</em>");
        encoded = CodePattern.Replace(encoded, "<code>$1</code>");
        encoded = UrlPattern.Replace(encoded, match =>
        {
            var value = match.Value;
            var href = value.StartsWith("www.", StringComparison.OrdinalIgnoreCase)
                ? $"https://{value}"
                : value;
            return $"<a href=\"{href}\" target=\"_blank\" rel=\"noopener noreferrer\">{value}</a>";
        });

        var normalizedLineBreaks = encoded.Replace("\r\n", "\n", StringComparison.Ordinal);
        return normalizedLineBreaks.Replace("\n", "<br />", StringComparison.Ordinal);
    }

    private static string GetMentionLabel(MentionToken mention)
    {
        var label = string.IsNullOrWhiteSpace(mention.DisplayText)
            ? mention.Token
            : mention.DisplayText;
        if (string.IsNullOrWhiteSpace(label))
        {
            return "@Mention";
        }

        return label.StartsWith("@", StringComparison.Ordinal)
            ? label
            : $"@{label}";
    }

    private async Task EnsureCommentComposerInteropAsync()
    {
        if (CommentComposerInteropHandle is not null)
        {
            return;
        }

        CommentComposerModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Index/Index.razor.js");
        CommentComposerDotNetRef ??= DotNetObjectReference.Create(this);
        CommentComposerInteropHandle = await CommentComposerModule.InvokeAsync<IJSObjectReference>(
            "attachCommentComposerDropPaste",
            CommentComposerDropZoneElement,
            CommentComposerDotNetRef);
    }

    private async Task DisposeCommentComposerInteropAsync()
    {
        if (CommentComposerInteropHandle is null)
        {
            return;
        }

        try
        {
            await CommentComposerInteropHandle.InvokeVoidAsync("dispose");
            await CommentComposerInteropHandle.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnect race during shutdown.
        }
        finally
        {
            CommentComposerInteropHandle = null;
        }
    }

    private async Task OnColumnVisibilityChangedAsync(HomeKanbanViewType viewType, string columnKey, bool isVisible)
    {
        var hiddenColumns = GetHiddenColumns(viewType);
        if (isVisible)
        {
            hiddenColumns.Remove(columnKey);
        }
        else
        {
            hiddenColumns.Add(columnKey);
        }

        await SaveSettingsAsync();
    }

    private async Task ResetLayoutAsync()
    {
        SetSortMode(ActiveView, BoardSortMode.Manual);
        SetCompactCards(ActiveView, false);
        GetHiddenColumns(ActiveView).Clear();

        var defaultOrder = GetDefaultColumnOrder(ActiveView);
        ApplyColumnOrder(CurrentBoard.Columns, defaultOrder);
        await SaveColumnOrderAsync(ActiveView, defaultOrder);
        await SaveSettingsAsync();
        await LoadBoardsAsync();
    }

    private bool CanMove(string source, string target)
    {
        if (ActiveView == HomeKanbanViewType.Wiki)
        {
            return source is not HomeKanbanColumnKeys.WikiTemplateUsage and not HomeKanbanColumnKeys.WikiFavoriteUsage
                && target is not HomeKanbanColumnKeys.WikiTemplateUsage and not HomeKanbanColumnKeys.WikiFavoriteUsage;
        }

        return source != HomeKanbanColumnKeys.OnboardingDrafts && target != HomeKanbanColumnKeys.OnboardingDrafts;
    }

    private static void NormalizeOrder(HomeKanbanBoardDto board)
    {
        foreach (var column in board.Columns.OrderBy(c => c.SortOrder))
        {
            var columnCards = board.Cards.Where(c => c.ColumnKey == column.Key).OrderBy(c => c.SortOrder).ToList();
            for (var i = 0; i < columnCards.Count; i++)
            {
                columnCards[i].SortOrder = (i + 1) * 10;
            }
        }
    }

    private static List<string> NormalizeColumnOrder(IReadOnlyList<HomeKanbanColumnDto> columns, IReadOnlyList<string> orderedKeys)
    {
        var valid = columns.Select(column => column.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var normalized = orderedKeys
            .Where(key => valid.Contains(key))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var columnKey in columns.OrderBy(column => column.SortOrder).Select(column => column.Key))
        {
            if (!normalized.Contains(columnKey, StringComparer.OrdinalIgnoreCase))
            {
                normalized.Add(columnKey);
            }
        }

        return normalized;
    }

    private static void ApplyColumnOrder(IReadOnlyList<HomeKanbanColumnDto> columns, IReadOnlyList<string> orderedKeys)
    {
        var sortOrder = 10;
        foreach (var key in orderedKeys)
        {
            var column = columns.FirstOrDefault(entry => string.Equals(entry.Key, key, StringComparison.OrdinalIgnoreCase));
            if (column is null)
            {
                continue;
            }

            column.SortOrder = sortOrder;
            sortOrder += 10;
        }
    }

    private async Task SaveColumnOrderAsync(HomeKanbanViewType viewType, IReadOnlyList<string> orderedKeys)
    {
        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            return;
        }

        var request = new ReorderColumnsRequest
        {
            ViewType = viewType,
            OrderedColumnKeys = orderedKeys.ToList()
        };

        if (viewType == HomeKanbanViewType.Wiki)
        {
            await WikiService.SaveHomeKanbanColumnOrderAsync(CurrentUserId, request);
        }
        else
        {
            await OnboardingService.SaveHomeKanbanColumnOrderAsync(CurrentUserId, request);
        }
    }

    private static List<string> GetDefaultColumnOrder(HomeKanbanViewType viewType)
    {
        return viewType == HomeKanbanViewType.Wiki
            ?
            [
                HomeKanbanColumnKeys.WikiDrafts,
                HomeKanbanColumnKeys.WikiLastViews,
                HomeKanbanColumnKeys.WikiTemplateUsage,
                HomeKanbanColumnKeys.WikiFavoriteUsage
            ]
            :
            [
                HomeKanbanColumnKeys.OnboardingDrafts,
                HomeKanbanColumnKeys.OnboardingNotStarted,
                HomeKanbanColumnKeys.OnboardingInProgress,
                HomeKanbanColumnKeys.OnboardingCompleted,
                HomeKanbanColumnKeys.OnboardingArchived
            ];
    }

    private string GetKanbanCssClass()
    {
        var viewCss = ActiveView == HomeKanbanViewType.Wiki ? "home-kanban-view-wiki" : "home-kanban-view-onboarding";
        return $"{viewCss} {(GetCompactCards(ActiveView) ? "home-kanban-compact" : string.Empty)}";
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            var raw = await JsRuntime.InvokeAsync<string?>("wikiBlaze.loadDashboardSettings", GetSettingsKey());
            if (!string.IsNullOrWhiteSpace(raw))
            {
                var settings = JsonSerializer.Deserialize<HomeIndexSettings>(raw);
                if (settings is not null)
                {
                    ActiveView = settings.ActiveView;
                    SetSortMode(HomeKanbanViewType.Wiki, settings.WikiSortMode);
                    SetSortMode(HomeKanbanViewType.Onboarding, settings.OnboardingSortMode);
                    SetCompactCards(HomeKanbanViewType.Wiki, settings.WikiCompactCards);
                    SetCompactCards(HomeKanbanViewType.Onboarding, settings.OnboardingCompactCards);

                    HiddenColumnsByView[HomeKanbanViewType.Wiki] = new HashSet<string>(settings.HiddenWikiColumns, StringComparer.OrdinalIgnoreCase);
                    HiddenColumnsByView[HomeKanbanViewType.Onboarding] = new HashSet<string>(settings.HiddenOnboardingColumns, StringComparer.OrdinalIgnoreCase);
                }
            }
        }
        catch
        {
            // ignore invalid settings
        }
        finally
        {
            SettingsLoaded = true;
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (!SettingsLoaded)
        {
            return;
        }

        var raw = JsonSerializer.Serialize(new HomeIndexSettings
        {
            ActiveView = ActiveView,
            WikiSortMode = GetSortMode(HomeKanbanViewType.Wiki),
            OnboardingSortMode = GetSortMode(HomeKanbanViewType.Onboarding),
            WikiCompactCards = GetCompactCards(HomeKanbanViewType.Wiki),
            OnboardingCompactCards = GetCompactCards(HomeKanbanViewType.Onboarding),
            HiddenWikiColumns = GetHiddenColumns(HomeKanbanViewType.Wiki).OrderBy(value => value).ToList(),
            HiddenOnboardingColumns = GetHiddenColumns(HomeKanbanViewType.Onboarding).OrderBy(value => value).ToList()
        });
        await JsRuntime.InvokeVoidAsync("wikiBlaze.saveDashboardSettings", GetSettingsKey(), raw);
    }

    protected void SelectedFilesChanged(IEnumerable<UploadFileInfo> files)
    {
        UploadVisible = files.Any();
        InvokeAsync(StateHasChanged);
    }

    protected string GetUploadUrl(string url)
    {
        return NavigationManager.ToAbsoluteUri(url).AbsoluteUri;
    }

    private string GetSettingsKey()
    {
        return string.IsNullOrWhiteSpace(CurrentUserId)
            ? SettingsKeyPrefix
            : $"{SettingsKeyPrefix}:{CurrentUserId}";
    }

    private BoardSortMode GetSortMode(HomeKanbanViewType viewType)
    {
        return SortModesByView.TryGetValue(viewType, out var mode) ? mode : BoardSortMode.Manual;
    }

    private void SetSortMode(HomeKanbanViewType viewType, BoardSortMode mode)
    {
        SortModesByView[viewType] = mode;
    }

    private bool GetCompactCards(HomeKanbanViewType viewType)
    {
        return CompactCardsByView.TryGetValue(viewType, out var compact) && compact;
    }

    private void SetCompactCards(HomeKanbanViewType viewType, bool compact)
    {
        CompactCardsByView[viewType] = compact;
    }

    private HashSet<string> GetHiddenColumns(HomeKanbanViewType viewType)
    {
        if (!HiddenColumnsByView.TryGetValue(viewType, out var hiddenColumns))
        {
            hiddenColumns = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            HiddenColumnsByView[viewType] = hiddenColumns;
        }

        return hiddenColumns;
    }

    private bool IsColumnVisible(HomeKanbanViewType viewType, string columnKey)
    {
        return !GetHiddenColumns(viewType).Contains(columnKey);
    }

    private static string GetStatusLabel(OnboardingProfileStatus status) => status switch
    {
        OnboardingProfileStatus.Draft => "Entwurf",
        OnboardingProfileStatus.NotStarted => "Noch nicht gestartet",
        OnboardingProfileStatus.InProgress => "In Bearbeitung",
        OnboardingProfileStatus.Completed => "Abgeschlossen",
        OnboardingProfileStatus.Archived => "Archiviert",
        _ => status.ToString()
    };

    private static string GetAttachmentPreview(CommentAttachmentDto attachment)
    {
        return $"data:{attachment.ContentType};base64,{Convert.ToBase64String(attachment.Content)}";
    }

    private bool ShowCardDragHint(HomeKanbanCardDto card)
    {
        if (GetSortMode(ActiveView) != BoardSortMode.Manual)
        {
            return false;
        }

        var column = CurrentBoard.Columns.FirstOrDefault(entry =>
            string.Equals(entry.Key, card.ColumnKey, StringComparison.OrdinalIgnoreCase));
        return column?.CardsDraggable == true;
    }

    private static string GetColumnRenderKey(HomeKanbanViewType viewType, string columnKey)
    {
        return $"{viewType}:{columnKey}";
    }

    private sealed class PendingCommentPreview
    {
        public string FileName { get; set; } = string.Empty;
        public string PreviewUrl { get; set; } = string.Empty;
    }

    private sealed class HomeIndexSettings
    {
        public HomeKanbanViewType ActiveView { get; set; } = HomeKanbanViewType.Wiki;
        public BoardSortMode WikiSortMode { get; set; } = BoardSortMode.Manual;
        public BoardSortMode OnboardingSortMode { get; set; } = BoardSortMode.Manual;
        public bool WikiCompactCards { get; set; }
        public bool OnboardingCompactCards { get; set; }
        public List<string> HiddenWikiColumns { get; set; } = new();
        public List<string> HiddenOnboardingColumns { get; set; } = new();
    }

    private enum BoardSortMode
    {
        Manual,
        LastActivity,
        Title
    }
}

