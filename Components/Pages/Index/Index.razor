@page "/"
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Wiki_Blaze.Components.DxKanban
@using Wiki_Blaze.Data.Entities
@using Wiki_Blaze.Services
@attribute [Authorize]
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject IWikiService WikiService
@inject IOnboardingService OnboardingService
@inject IUserIdResolver UserIdResolver
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JsRuntime

<PageTitle>Home Dashboard</PageTitle>

<div class="home-kanban-page">
    <div class="home-header">
        <h2 class="mb-1">Wiki.NET Home Dashboard</h2>
        <p class="text-muted mb-0">Wiki und Onboarding in einer Kanban View.</p>
    </div>


<i class="fa fa-flag fa-1x"></i>


    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <div class="card home-toolbar-card">
        <div class="d-flex gap-2 flex-wrap align-items-center justify-content-between">
            <div class="d-flex gap-2 flex-wrap">
                <DxButton Text="Wiki"
                          RenderStyle="@(ActiveView == HomeKanbanViewType.Wiki ? ButtonRenderStyle.Primary : ButtonRenderStyle.Secondary)"
                          Click="() => SetViewAsync(HomeKanbanViewType.Wiki)" />
                <DxButton Text="Onboarding"
                          RenderStyle="@(ActiveView == HomeKanbanViewType.Onboarding ? ButtonRenderStyle.Primary : ButtonRenderStyle.Secondary)"
                          Click="() => SetViewAsync(HomeKanbanViewType.Onboarding)" />
            </div>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <select class="form-select form-select-sm home-sort-select" value="@GetSortMode(ActiveView)" @onchange="OnSortChanged">
                    <option value="@BoardSortMode.Manual">Manuell (DnD)</option>
                    <option value="@BoardSortMode.LastActivity">Zuletzt aktiv</option>
                    <option value="@BoardSortMode.Title">Titel</option>
                </select>
                <DxCheckBox Checked="@GetCompactCards(ActiveView)"
                            CheckedChanged="@(async (bool value) => await OnCompactChanged(value))"
                            LabelText="Kompakt" />
                <DxButton Text="Reset Layout" RenderStyle="ButtonRenderStyle.Secondary" Click="ResetLayoutAsync" />
                <DxButton Text="Reload" RenderStyle="ButtonRenderStyle.Secondary" Click="LoadBoardsAsync" />
            </div>
        </div>
        <div class="home-toolbar-columns">
            @foreach (var column in CurrentBoard.Columns.OrderBy(c => c.SortOrder))
            {
                var columnRenderKey = GetColumnRenderKey(ActiveView, column.Key);
                <DxCheckBox @key="columnRenderKey"
                            Checked="@IsColumnVisible(ActiveView, column.Key)"
                            CheckedChanged="@(async (bool value) => await OnColumnVisibilityChangedAsync(ActiveView, column.Key, value))"
                            LabelText="@column.Title" />
            }
        </div>
    </div>

    @if (VisibleColumns.Count == 0)
    {
        <div class="alert alert-warning mb-0">Alle Spalten sind ausgeblendet. Aktiviere mindestens eine Spalte in der Toolbar.</div>
    }
    else
    {
        <div class="home-kanban-board-shell">
            <DxKanban Data="@RenderCards"
                      CardDropped="OnCardDroppedAsync"
                      ColumnsReordered="OnColumnsReorderedAsync"
                      CssClass="@GetKanbanCssClass()"
                      ColumnNameFieldName="ColumnKey"
                      AllowColumnReorder="true">
                <Columns>
                    @for (var index = 0; index < VisibleColumns.Count; index++)
                    {
                        var column = VisibleColumns[index];
                        var columnRenderKey = GetColumnRenderKey(ActiveView, column.Key);
                        <DxKanbanColumn @key="columnRenderKey"
                                        ColumnName="@column.Key"
                                        Caption="@column.Title"
                                        VisibleIndex="@index"
                                        AllowCardDrag="@(column.CardsDraggable && GetSortMode(ActiveView) == BoardSortMode.Manual)"
                                        AllowCardDrop="@(column.AcceptDrop && GetSortMode(ActiveView) == BoardSortMode.Manual)" />
                    }
                </Columns>
                <CardTemplate Context="ctx">
                    @{
                        var card = (HomeKanbanCardDto)ctx;
                    }
                    <div class="home-kanban-card @(GetCompactCards(ActiveView) ? "is-compact" : string.Empty) @(card.IsReminderActive ? (card.IsReminderOverdue ? "is-reminder-overdue" : "is-reminder-active") : string.Empty)"
                         @oncontextmenu="(args) => OnCardContextMenuAsync(args, card)"
                         @oncontextmenu:preventDefault>
                        <div class="home-kanban-card-header">
                            <div class="home-kanban-card-header-row">
                                <div class="home-kanban-card-title">@card.Title</div>
                                @if (ShowCardDragHint(card))
                                {
                                    <span class="home-kanban-drag-hint" title="Zum Verschieben den Drag-Handle links an der Karte verwenden.">&#8942;&#8942;</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(card.Subtitle))
                            {
                                <div class="home-kanban-card-subtitle">@card.Subtitle</div>
                            }
                            @if (card.IsReminderActive && !string.IsNullOrWhiteSpace(card.ReminderLabel))
                            {
                                <div class="home-kanban-reminder-badge @(card.IsReminderOverdue ? "is-overdue" : "is-due")">@card.ReminderLabel</div>
                            }
                        </div>
                        <div class="home-kanban-card-meta">
                            <div class="home-meta-row">
                                <span class="home-meta-label">Ersteller</span>
                                <span class="home-meta-value">@card.CreatorDisplayName</span>
                            </div>
                            <div class="home-meta-row">
                                <span class="home-meta-label">Besitzer/Bearbeiter</span>
                                <span class="home-meta-value">@(string.IsNullOrWhiteSpace(card.OwnerDisplayName) ? "-" : card.OwnerDisplayName)</span>
                            </div>
                            <div class="home-meta-row">
                                <span class="home-meta-label">Kategorie/Rolle</span>
                                <span class="home-meta-value">@card.CategoryOrRole</span>
                            </div>
                        </div>
                        <div class="home-kanban-card-footer">
                            <div class="home-kanban-card-activity">
                                Aktivitaet: @card.LastActivityUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </div>
                            <div class="home-kanban-card-links">
                                @if (card.EntityType == HomeKanbanCardEntityType.WikiEntry)
                                {
                                    <button type="button"
                                            class="btn btn-link p-0 link-primary home-card-action"
                                            data-no-drag="true"
                                            @onclick="() => OpenCard(card)"
                                            @onclick:stopPropagation="true"
                                            @onmousedown:stopPropagation="true"
                                            @onpointerdown:stopPropagation="true">Eintrag Ansicht</button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn btn-link p-0 link-primary home-card-action"
                                            data-no-drag="true"
                                            @onclick="() => OpenDetailsAsync(card)"
                                            @onclick:stopPropagation="true"
                                            @onmousedown:stopPropagation="true"
                                            @onpointerdown:stopPropagation="true">Details</button>
                                }
                                <button type="button"
                                        class="btn btn-link p-0 link-secondary home-card-action"
                                        data-no-drag="true"
                                        @onclick="() => OpenCommentsAsync(card)"
                                        @onclick:stopPropagation="true"
                                        @onmousedown:stopPropagation="true"
                                        @onpointerdown:stopPropagation="true">Kommentare (@card.CommentCount)</button>
                            </div>
                        </div>
                    </div>
                </CardTemplate>
            </DxKanban>
        </div>
    }

    <div id="overviewDemoDropZone" class="card custom-drop-zone rounded-3 w-100 m-0">
        <span class="drop-file-icon mb-3"></span>
        <span class="drop-file-label">Drag and Drop File Here</span><span class="m-1">or</span>
        <DxButton Id="overviewDemoSelectButton" CssClass="m-1" RenderStyle="ButtonRenderStyle.Primary" Text="Select File" />
    </div>
    <DxUpload Name="myFile"
              Visible="@UploadVisible"
              ExternalSelectButtonCssSelector="#overviewDemoSelectButton"
              ExternalDropZoneCssSelector="#overviewDemoDropZone"
              ExternalDropZoneDragOverCssClass="custom-drop-zone-hover"
              MaxFileSize="15000000"
              UploadUrl="@GetUploadUrl("api/Upload/Upload/")"
              SelectedFilesChanged="@SelectedFilesChanged" />
</div>

<DxContextMenu @ref="WikiCardContextMenu"
               ItemClick="OnCardContextMenuItemClick">
    <Items>
        <DxContextMenuItem Text="Oeffnen" IconCssClass="oi oi-eye" Name="open" />
        <DxContextMenuItem Text="Kommentare" IconCssClass="oi oi-comment-square" Name="comments" />
        <DxContextMenuItem Text="Loeschen" IconCssClass="oi oi-trash" Name="wiki-delete" BeginGroup="true" />
    </Items>
</DxContextMenu>

<DxContextMenu @ref="OnboardingCardContextMenu"
               ItemClick="OnCardContextMenuItemClick">
    <Items>
        <DxContextMenuItem Text="Oeffnen" IconCssClass="oi oi-eye" Name="open" />
        <DxContextMenuItem Text="Kommentare" IconCssClass="oi oi-comment-square" Name="comments" />
        <DxContextMenuItem Text="Details oeffnen" IconCssClass="oi oi-info" Name="onboarding-quick-details" BeginGroup="true" />
        <DxContextMenuItem Text="Zur Detailseite" IconCssClass="oi oi-external-link" Name="onboarding-open-details-page" />
    </Items>
</DxContextMenu>

<HomeCommentSidebar @bind-Visible="CommentsVisible"
                    Scope="@CurrentCommentScope"
                    EntryId="@(CommentCard?.EntryId ?? 0)"
                    Title="@CommentSidebarTitle"
                    Subtitle="@CommentCard?.Subtitle"
                    CreatorDisplayName="@CommentCard?.CreatorDisplayName"
                    OwnerDisplayName="@CommentCard?.OwnerDisplayName"
                    CategoryOrRole="@CommentCard?.CategoryOrRole"
                    LastActivityUtc="@CommentCard?.LastActivityUtc"
                    ShowContextDetails="true"
                    ShowOnboardingQuickDetail="true"
                    OnCommentsChanged="HandleHomeCommentsChangedAsync" />
<DxPopup HeaderText="Onboarding Details" Width="840px" Height="600px" @bind-Visible="DetailsVisible" CloseOnOutsideClick="true">
    <BodyContentTemplate Context="detailPopupContext">
        @if (QuickDetail is null)
        {
            <div class="text-muted">Keine Daten verfuegbar.</div>
        }
        else
        {
            <DxFormLayout>
                <DxFormLayoutItem Caption="Name">@QuickDetail.FullName</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Abteilung">@QuickDetail.Department</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Stellenbezeichnung">@QuickDetail.JobTitle</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Status">@GetStatusLabel(QuickDetail.Status)</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Massnahmen">@($"{QuickDetail.MeasureTotalCount - QuickDetail.MeasureOpenCount}/{QuickDetail.MeasureTotalCount} erledigt")</DxFormLayoutItem>
                <DxFormLayoutItem Caption="Tests">@($"{QuickDetail.ChecklistTotalCount - QuickDetail.ChecklistOpenCount}/{QuickDetail.ChecklistTotalCount} erledigt")</DxFormLayoutItem>
            </DxFormLayout>
            <div class="d-flex justify-content-end mt-3">
                <DxButton Text="Zur kompletten Detailseite" RenderStyle="ButtonRenderStyle.Primary" NavigateUrl="@($"/reportdesigner/details/{QuickDetail.ProfileId}")" />
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

@code {
    private const string SettingsKeyPrefix = "wikiBlaze.homeKanban.settings";

    private string? CurrentUserId { get; set; }
    private HomeKanbanViewType ActiveView { get; set; } = HomeKanbanViewType.Wiki;
    private readonly Dictionary<HomeKanbanViewType, BoardSortMode> SortModesByView = new()
    {
        [HomeKanbanViewType.Wiki] = BoardSortMode.Manual,
        [HomeKanbanViewType.Onboarding] = BoardSortMode.Manual
    };
    private readonly Dictionary<HomeKanbanViewType, bool> CompactCardsByView = new()
    {
        [HomeKanbanViewType.Wiki] = false,
        [HomeKanbanViewType.Onboarding] = false
    };
    private readonly Dictionary<HomeKanbanViewType, HashSet<string>> HiddenColumnsByView = new()
    {
        [HomeKanbanViewType.Wiki] = new HashSet<string>(StringComparer.OrdinalIgnoreCase),
        [HomeKanbanViewType.Onboarding] = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    };
    private bool UploadVisible { get; set; }
    private bool SettingsLoaded { get; set; }
    private string? ErrorMessage { get; set; }

    private HomeKanbanBoardDto WikiBoard { get; set; } = new() { ViewType = HomeKanbanViewType.Wiki };
    private HomeKanbanBoardDto OnboardingBoard { get; set; } = new() { ViewType = HomeKanbanViewType.Onboarding };
    private HomeKanbanBoardDto CurrentBoard => ActiveView == HomeKanbanViewType.Wiki ? WikiBoard : OnboardingBoard;

    private List<HomeKanbanColumnDto> VisibleColumns => CurrentBoard.Columns
        .OrderBy(column => column.SortOrder)
        .Where(column => IsColumnVisible(ActiveView, column.Key))
        .ToList();

    private bool CommentsVisible { get; set; }
    private HomeKanbanCardDto? CommentCard { get; set; }
    private DxContextMenu? WikiCardContextMenu { get; set; }
    private DxContextMenu? OnboardingCardContextMenu { get; set; }
    private HomeKanbanCardDto? ContextMenuCard { get; set; }

    private bool DetailsVisible { get; set; }
    private OnboardingQuickDetailDto? QuickDetail { get; set; }

    private HomeCommentScope CurrentCommentScope =>
        CommentCard?.EntityType == HomeKanbanCardEntityType.OnboardingProfile
            ? HomeCommentScope.Onboarding
            : HomeCommentScope.Wiki;
    private string CommentSidebarTitle => CommentCard is null ? "Kommentare" : $"Kommentare - {CommentCard.Title}";
    private List<HomeKanbanCardDto> RenderCards
    {
        get
        {
            var sortMode = GetSortMode(ActiveView);
            var visibleColumnKeys = VisibleColumns
                .Select(column => column.Key)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            return CurrentBoard.Cards
                .Where(card => visibleColumnKeys.Contains(card.ColumnKey))
                .OrderBy(card => CurrentBoard.Columns.FirstOrDefault(col => col.Key == card.ColumnKey)?.SortOrder ?? int.MaxValue)
                .ThenBy(card => sortMode == BoardSortMode.Title ? 0 : 1)
                .ThenBy(card => sortMode == BoardSortMode.Title ? card.Title : string.Empty, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(card => sortMode == BoardSortMode.LastActivity ? card.LastActivityUtc : DateTime.MinValue)
                .ThenBy(card => card.SortOrder)
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CurrentUserId = UserIdResolver.ResolveCurrentUserId(authState.User);
        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            ErrorMessage = "Benutzer konnte nicht aufgeloest werden.";
            return;
        }

        await LoadBoardsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSettingsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadBoardsAsync()
    {
        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            return;
        }

        var wikiTask = WikiService.GetHomeKanbanBoardAsync(CurrentUserId);
        var onboardingTask = OnboardingService.GetHomeKanbanBoardAsync(CurrentUserId);
        await Task.WhenAll(wikiTask, onboardingTask);
        WikiBoard = await wikiTask;
        OnboardingBoard = await onboardingTask;
    }

    private async Task SetViewAsync(HomeKanbanViewType view)
    {
        ActiveView = view;
        await SaveSettingsAsync();
    }

    private async Task OnSortChanged(ChangeEventArgs args)
    {
        if (args.Value is not null && Enum.TryParse<BoardSortMode>(args.Value.ToString(), out var mode))
        {
            SetSortMode(ActiveView, mode);
            await SaveSettingsAsync();
        }
    }

    private async Task OnCompactChanged(bool value)
    {
        SetCompactCards(ActiveView, value);
        await SaveSettingsAsync();
    }

    private async Task OnCardDroppedAsync(GridItemsDroppedEventArgs args)
    {
        if (GetSortMode(ActiveView) != BoardSortMode.Manual || args.DroppedItems.Count == 0 || args.DroppedItems[0] is not HomeKanbanCardDto dropped)
        {
            return;
        }

        var target = args.Grid.KeyFieldName;
        if (string.IsNullOrWhiteSpace(target) || !CanMove(dropped.ColumnKey, target))
        {
            await LoadBoardsAsync();
            return;
        }

        var source = dropped.ColumnKey;
        var cards = CurrentBoard.Cards;
        var targetCard = args.TargetItem as HomeKanbanCardDto;
        cards.Remove(dropped);
        dropped.ColumnKey = target;
        if (targetCard is null)
        {
            cards.Add(dropped);
        }
        else
        {
            var idx = cards.IndexOf(targetCard);
            cards.Insert(idx, dropped);
        }

        NormalizeOrder(CurrentBoard);
        var targetIndex = cards.Where(c => c.ColumnKey == target).OrderBy(c => c.SortOrder).ToList().FindIndex(c => c.EntryId == dropped.EntryId);
        var req = new MoveCardRequest
        {
            ViewType = ActiveView,
            EntityType = dropped.EntityType,
            EntryId = dropped.EntryId,
            SourceColumnKey = source,
            TargetColumnKey = target,
            TargetIndex = Math.Max(targetIndex, 0)
        };

        var ok = ActiveView == HomeKanbanViewType.Wiki
            ? await WikiService.MoveHomeKanbanCardAsync(CurrentUserId!, req)
            : await OnboardingService.MoveHomeKanbanCardAsync(CurrentUserId!, req);

        if (!ok)
        {
            await LoadBoardsAsync();
        }
    }

    private async Task OnColumnsReorderedAsync(IReadOnlyList<string> orderedColumnKeys)
    {
        if (string.IsNullOrWhiteSpace(CurrentUserId) || orderedColumnKeys.Count == 0)
        {
            return;
        }

        var normalized = NormalizeColumnOrder(CurrentBoard.Columns, orderedColumnKeys);
        var current = CurrentBoard.Columns
            .OrderBy(column => column.SortOrder)
            .Select(column => column.Key)
            .ToList();

        if (current.SequenceEqual(normalized, StringComparer.OrdinalIgnoreCase))
        {
            return;
        }

        ApplyColumnOrder(CurrentBoard.Columns, normalized);
        await SaveColumnOrderAsync(ActiveView, normalized);
        await LoadBoardsAsync();
    }

    private async Task OpenDetailsAsync(HomeKanbanCardDto card)
    {
        if (card.EntityType != HomeKanbanCardEntityType.OnboardingProfile)
        {
            return;
        }

        QuickDetail = await OnboardingService.GetQuickDetailAsync(card.EntryId);
        DetailsVisible = QuickDetail is not null;
    }

    private Task OpenCommentsAsync(HomeKanbanCardDto card)
    {
        ErrorMessage = null;
        CommentCard = card;
        CommentsVisible = true;
        return Task.CompletedTask;
    }

    private async Task HandleHomeCommentsChangedAsync()
    {
        await LoadBoardsAsync();
    }

    private async Task OnCardContextMenuAsync(MouseEventArgs args, HomeKanbanCardDto card)
    {
        ContextMenuCard = card;
        var contextMenu = card.EntityType == HomeKanbanCardEntityType.WikiEntry
            ? WikiCardContextMenu
            : OnboardingCardContextMenu;

        if (contextMenu is not null)
        {
            await contextMenu.ShowAsync(args);
        }
    }

    private async Task OnCardContextMenuItemClick(ContextMenuItemClickEventArgs args)
    {
        if (ContextMenuCard is null)
        {
            return;
        }

        var card = ContextMenuCard;
        ErrorMessage = null;

        try
        {
            switch (args.ItemInfo.Name)
            {
                case "open":
                    OpenCard(card);
                    break;
                case "comments":
                    await OpenCommentsAsync(card);
                    break;
                case "onboarding-quick-details":
                    if (card.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
                    {
                        await OpenDetailsAsync(card);
                    }
                    break;
                case "onboarding-open-details-page":
                    if (card.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
                    {
                        NavigationManager.NavigateTo($"/reportdesigner/details/{card.EntryId}");
                    }
                    break;
                case "wiki-delete":
                    if (card.EntityType == HomeKanbanCardEntityType.WikiEntry)
                    {
                        await DeleteWikiCardAsync(card);
                    }
                    break;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Aktion fehlgeschlagen: {ex.Message}";
        }
    }

    private void OpenCard(HomeKanbanCardDto card)
    {
        if (card.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
        {
            NavigationManager.NavigateTo($"/reportdesigner/details/{card.EntryId}");
            return;
        }

        if (!string.IsNullOrWhiteSpace(card.PrimaryLinkUrl))
        {
            NavigationManager.NavigateTo(card.PrimaryLinkUrl);
            return;
        }

        NavigationManager.NavigateTo($"/wiki/view/{card.EntryId}?returnUrl=%2F");
    }

    private async Task DeleteWikiCardAsync(HomeKanbanCardDto card)
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"Wiki-Eintrag \"{card.Title}\" wirklich loeschen?");
        if (!confirmed)
        {
            return;
        }

        await WikiService.DeletePageAsync(card.EntryId);
        await LoadBoardsAsync();
    }

    private async Task OnColumnVisibilityChangedAsync(HomeKanbanViewType viewType, string columnKey, bool isVisible)
    {
        var hiddenColumns = GetHiddenColumns(viewType);
        if (isVisible)
        {
            hiddenColumns.Remove(columnKey);
        }
        else
        {
            hiddenColumns.Add(columnKey);
        }

        await SaveSettingsAsync();
    }

    private async Task ResetLayoutAsync()
    {
        SetSortMode(ActiveView, BoardSortMode.Manual);
        SetCompactCards(ActiveView, false);
        GetHiddenColumns(ActiveView).Clear();

        var defaultOrder = GetDefaultColumnOrder(ActiveView);
        ApplyColumnOrder(CurrentBoard.Columns, defaultOrder);
        await SaveColumnOrderAsync(ActiveView, defaultOrder);
        await SaveSettingsAsync();
        await LoadBoardsAsync();
    }

    private bool CanMove(string source, string target)
    {
        if (ActiveView == HomeKanbanViewType.Wiki)
        {
            return source is not HomeKanbanColumnKeys.WikiTemplateUsage and not HomeKanbanColumnKeys.WikiFavoriteUsage
                && target is not HomeKanbanColumnKeys.WikiTemplateUsage and not HomeKanbanColumnKeys.WikiFavoriteUsage;
        }

        return source != HomeKanbanColumnKeys.OnboardingDrafts && target != HomeKanbanColumnKeys.OnboardingDrafts;
    }

    private static void NormalizeOrder(HomeKanbanBoardDto board)
    {
        foreach (var column in board.Columns.OrderBy(c => c.SortOrder))
        {
            var columnCards = board.Cards.Where(c => c.ColumnKey == column.Key).OrderBy(c => c.SortOrder).ToList();
            for (var i = 0; i < columnCards.Count; i++)
            {
                columnCards[i].SortOrder = (i + 1) * 10;
            }
        }
    }

    private static List<string> NormalizeColumnOrder(IReadOnlyList<HomeKanbanColumnDto> columns, IReadOnlyList<string> orderedKeys)
    {
        var valid = columns.Select(column => column.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var normalized = orderedKeys
            .Where(key => valid.Contains(key))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        foreach (var columnKey in columns.OrderBy(column => column.SortOrder).Select(column => column.Key))
        {
            if (!normalized.Contains(columnKey, StringComparer.OrdinalIgnoreCase))
            {
                normalized.Add(columnKey);
            }
        }

        return normalized;
    }

    private static void ApplyColumnOrder(IReadOnlyList<HomeKanbanColumnDto> columns, IReadOnlyList<string> orderedKeys)
    {
        var sortOrder = 10;
        foreach (var key in orderedKeys)
        {
            var column = columns.FirstOrDefault(entry => string.Equals(entry.Key, key, StringComparison.OrdinalIgnoreCase));
            if (column is null)
            {
                continue;
            }

            column.SortOrder = sortOrder;
            sortOrder += 10;
        }
    }

    private async Task SaveColumnOrderAsync(HomeKanbanViewType viewType, IReadOnlyList<string> orderedKeys)
    {
        if (string.IsNullOrWhiteSpace(CurrentUserId))
        {
            return;
        }

        var request = new ReorderColumnsRequest
        {
            ViewType = viewType,
            OrderedColumnKeys = orderedKeys.ToList()
        };

        if (viewType == HomeKanbanViewType.Wiki)
        {
            await WikiService.SaveHomeKanbanColumnOrderAsync(CurrentUserId, request);
        }
        else
        {
            await OnboardingService.SaveHomeKanbanColumnOrderAsync(CurrentUserId, request);
        }
    }

    private static List<string> GetDefaultColumnOrder(HomeKanbanViewType viewType)
    {
        return viewType == HomeKanbanViewType.Wiki
            ?
            [
                HomeKanbanColumnKeys.WikiDrafts,
                HomeKanbanColumnKeys.WikiLastViews,
                HomeKanbanColumnKeys.WikiTemplateUsage,
                HomeKanbanColumnKeys.WikiFavoriteUsage
            ]
            :
            [
                HomeKanbanColumnKeys.OnboardingDrafts,
                HomeKanbanColumnKeys.OnboardingNotStarted,
                HomeKanbanColumnKeys.OnboardingInProgress,
                HomeKanbanColumnKeys.OnboardingCompleted,
                HomeKanbanColumnKeys.OnboardingArchived
            ];
    }

    private string GetKanbanCssClass()
    {
        var viewCss = ActiveView == HomeKanbanViewType.Wiki ? "home-kanban-view-wiki" : "home-kanban-view-onboarding";
        return $"{viewCss} {(GetCompactCards(ActiveView) ? "home-kanban-compact" : string.Empty)}";
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            var raw = await JsRuntime.InvokeAsync<string?>("wikiBlaze.loadDashboardSettings", GetSettingsKey());
            if (!string.IsNullOrWhiteSpace(raw))
            {
                var settings = JsonSerializer.Deserialize<HomeIndexSettings>(raw);
                if (settings is not null)
                {
                    ActiveView = settings.ActiveView;
                    SetSortMode(HomeKanbanViewType.Wiki, settings.WikiSortMode);
                    SetSortMode(HomeKanbanViewType.Onboarding, settings.OnboardingSortMode);
                    SetCompactCards(HomeKanbanViewType.Wiki, settings.WikiCompactCards);
                    SetCompactCards(HomeKanbanViewType.Onboarding, settings.OnboardingCompactCards);

                    HiddenColumnsByView[HomeKanbanViewType.Wiki] = new HashSet<string>(settings.HiddenWikiColumns, StringComparer.OrdinalIgnoreCase);
                    HiddenColumnsByView[HomeKanbanViewType.Onboarding] = new HashSet<string>(settings.HiddenOnboardingColumns, StringComparer.OrdinalIgnoreCase);
                }
            }
        }
        catch
        {
            // ignore invalid settings
        }
        finally
        {
            SettingsLoaded = true;
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (!SettingsLoaded)
        {
            return;
        }

        var raw = JsonSerializer.Serialize(new HomeIndexSettings
        {
            ActiveView = ActiveView,
            WikiSortMode = GetSortMode(HomeKanbanViewType.Wiki),
            OnboardingSortMode = GetSortMode(HomeKanbanViewType.Onboarding),
            WikiCompactCards = GetCompactCards(HomeKanbanViewType.Wiki),
            OnboardingCompactCards = GetCompactCards(HomeKanbanViewType.Onboarding),
            HiddenWikiColumns = GetHiddenColumns(HomeKanbanViewType.Wiki).OrderBy(value => value).ToList(),
            HiddenOnboardingColumns = GetHiddenColumns(HomeKanbanViewType.Onboarding).OrderBy(value => value).ToList()
        });
        await JsRuntime.InvokeVoidAsync("wikiBlaze.saveDashboardSettings", GetSettingsKey(), raw);
    }

    protected void SelectedFilesChanged(IEnumerable<UploadFileInfo> files)
    {
        UploadVisible = files.Any();
        InvokeAsync(StateHasChanged);
    }

    protected string GetUploadUrl(string url)
    {
        return NavigationManager.ToAbsoluteUri(url).AbsoluteUri;
    }

    private string GetSettingsKey()
    {
        return string.IsNullOrWhiteSpace(CurrentUserId)
            ? SettingsKeyPrefix
            : $"{SettingsKeyPrefix}:{CurrentUserId}";
    }

    private BoardSortMode GetSortMode(HomeKanbanViewType viewType)
    {
        return SortModesByView.TryGetValue(viewType, out var mode) ? mode : BoardSortMode.Manual;
    }

    private void SetSortMode(HomeKanbanViewType viewType, BoardSortMode mode)
    {
        SortModesByView[viewType] = mode;
    }

    private bool GetCompactCards(HomeKanbanViewType viewType)
    {
        return CompactCardsByView.TryGetValue(viewType, out var compact) && compact;
    }

    private void SetCompactCards(HomeKanbanViewType viewType, bool compact)
    {
        CompactCardsByView[viewType] = compact;
    }

    private HashSet<string> GetHiddenColumns(HomeKanbanViewType viewType)
    {
        if (!HiddenColumnsByView.TryGetValue(viewType, out var hiddenColumns))
        {
            hiddenColumns = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            HiddenColumnsByView[viewType] = hiddenColumns;
        }

        return hiddenColumns;
    }

    private bool IsColumnVisible(HomeKanbanViewType viewType, string columnKey)
    {
        return !GetHiddenColumns(viewType).Contains(columnKey);
    }

    private static string GetStatusLabel(OnboardingProfileStatus status) => status switch
    {
        OnboardingProfileStatus.Draft => "Entwurf",
        OnboardingProfileStatus.NotStarted => "Noch nicht gestartet",
        OnboardingProfileStatus.InProgress => "In Bearbeitung",
        OnboardingProfileStatus.Completed => "Abgeschlossen",
        OnboardingProfileStatus.Archived => "Archiviert",
        _ => status.ToString()
    };

    private bool ShowCardDragHint(HomeKanbanCardDto card)
    {
        if (GetSortMode(ActiveView) != BoardSortMode.Manual)
        {
            return false;
        }

        var column = CurrentBoard.Columns.FirstOrDefault(entry =>
            string.Equals(entry.Key, card.ColumnKey, StringComparison.OrdinalIgnoreCase));
        return column?.CardsDraggable == true;
    }

    private static string GetColumnRenderKey(HomeKanbanViewType viewType, string columnKey)
    {
        return $"{viewType}:{columnKey}";
    }

    private sealed class HomeIndexSettings
    {
        public HomeKanbanViewType ActiveView { get; set; } = HomeKanbanViewType.Wiki;
        public BoardSortMode WikiSortMode { get; set; } = BoardSortMode.Manual;
        public BoardSortMode OnboardingSortMode { get; set; } = BoardSortMode.Manual;
        public bool WikiCompactCards { get; set; }
        public bool OnboardingCompactCards { get; set; }
        public List<string> HiddenWikiColumns { get; set; } = new();
        public List<string> HiddenOnboardingColumns { get; set; } = new();
    }

    private enum BoardSortMode
    {
        Manual,
        LastActivity,
        Title
    }
}
