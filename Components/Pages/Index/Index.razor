    }

    private async Task OnCardContextMenuAsync(MouseEventArgs args, HomeKanbanCardDto card)
    {
        ContextMenuCard = card;
        var contextMenu = card.EntityType == HomeKanbanCardEntityType.WikiEntry
            ? WikiCardContextMenu
            : OnboardingCardContextMenu;

        if (contextMenu is not null)
