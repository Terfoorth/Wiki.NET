    private async Task OnCardContextMenuItemClick(ContextMenuItemClickEventArgs args)
    {
        if (ContextMenuCard is null)
        {
            return;
        }

        var card = ContextMenuCard;
        ErrorMessage = null;

        try
        {
            switch (args.ItemInfo.Name)
            {
                case "open":
                    OpenCard(card);
                    break;
                case "comments":
                    await OpenCommentsAsync(card);
                    break;
                case "onboarding-quick-details":
                    if (card.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
                    {
                        await OpenDetailsAsync(card);
                    }
                    break;
                case "onboarding-open-details-page":
                    if (card.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
                    {
                        NavigationManager.NavigateTo($"/reportdesigner/details/{card.EntryId}");
                    }
                    break;
                case "wiki-delete":
                    if (card.EntityType == HomeKanbanCardEntityType.WikiEntry)
                    {
                        await DeleteWikiCardAsync(card);
                    }
                    break;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Aktion fehlgeschlagen: {ex.Message}";
        }
    }

    private void OpenCard(HomeKanbanCardDto card)
    {
        if (card.EntityType == HomeKanbanCardEntityType.OnboardingProfile)
        {
            NavigationManager.NavigateTo($"/reportdesigner/details/{card.EntryId}");
            return;
        }

        if (!string.IsNullOrWhiteSpace(card.PrimaryLinkUrl))
        {
            NavigationManager.NavigateTo(card.PrimaryLinkUrl);
            return;
        }

        NavigationManager.NavigateTo($"/wiki/view/{card.EntryId}?returnUrl=%2F");
    }

    private async Task DeleteWikiCardAsync(HomeKanbanCardDto card)
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"Wiki-Eintrag \"{card.Title}\" wirklich loeschen?");
        if (!confirmed)
        {
            return;
        }

        await WikiService.DeletePageAsync(card.EntryId);
        await LoadBoardsAsync();
    }

    private async Task ReloadCommentsAsync()
    {
        if (CommentCard is null)
        {
            Comments = new();
            return;
        }

        Comments = CommentScope == HomeCommentScope.Wiki
            ? await WikiService.GetHomeCommentsAsync(HomeCommentScope.Wiki, CommentCard.EntryId, CurrentUserId)
            : await OnboardingService.GetHomeCommentsAsync(CommentCard.EntryId, CurrentUserId);
    }

    private async Task SendCommentAsync()
    {
        if (!CanSendComment || CommentCard is null)
        {
            return;
        }

        IsSendingComment = true;
        CommentValidationMessage = null;

        try
        {
            var req = new CreateCommentRequest
            {
                Scope = CommentScope,
                EntryId = CommentCard.EntryId,
                Text = NewCommentText.Trim(),
                Mentions = SelectedMentions.Take(MaxCommentMentions).ToList(),
                Attachments = PendingCommentFiles.ToList()
            };

            if (CommentScope == HomeCommentScope.Wiki)
            {
                await WikiService.AddHomeCommentAsync(CurrentUserId, req);
            }
            else
            {
                await OnboardingService.AddHomeCommentAsync(CurrentUserId, req);
            }

            ResetCommentComposerState();
            await ReloadCommentsAsync();
            await LoadBoardsAsync();
            NotificationRefreshSignal.RequestRefresh();
        }
        catch (Exception ex)
        {
            CommentValidationMessage = $"Kommentar konnte nicht gesendet werden: {ex.Message}";
        }
        finally
        {
            IsSendingComment = false;
        }
    }

    private async Task OnCommentFilesChanged(InputFileChangeEventArgs args)
    {
        await AddCommentFilesAsync(args.GetMultipleFiles(MaxCommentAttachmentCount));
    }

    private async Task OnCommentInputKeyDown(KeyboardEventArgs args)
    {
        if (args.CtrlKey && string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            await SendCommentAsync();
        }
    }

