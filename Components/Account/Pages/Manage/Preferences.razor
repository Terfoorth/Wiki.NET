        new("Comfortable", "comfortable"),
        new("Compact", "compact"),
    ];

    private List<OptionItem> languageOptions =
    [
        new("English", "en"),
        new("Deutsch", "de"),
        new("Français", "fr"),
        new("Espańol", "es"),
        new("Italiano", "it"),
        new("Dansk", "da"),
        new("Norsk", "no"),
        new("Nederlands", "nl"),
        new("Polski", "pl"),
        new("Portuguęs", "pt"),
        new("Suomi", "fi"),
        new("Svenska", "sv"),
        new("????????", "el"),
        new("???????", "ru"),
        new("??????????", "uk"),
        new("???", "ja"),
        new("???", "ko"),
        new("?? (??)", "zh-hans"),
        new("?? (??)", "zh-hant"),
        new("Türkçe", "tr"),
    ];

    private List<OptionItem> timeZoneOptions =
    [
        new("UTC", "UTC"),
        new("Europe/Berlin", "Europe/Berlin"),
        new("Europe/London", "Europe/London"),
        new("Europe/Paris", "Europe/Paris"),
        new("Europe/Zurich", "Europe/Zurich"),
        new("America/New_York", "America/New_York"),
        new("America/Los_Angeles", "America/Los_Angeles"),
        new("America/Chicago", "America/Chicago"),
        new("America/Denver", "America/Denver"),
        new("America/Sao_Paulo", "America/Sao_Paulo"),
        new("Asia/Tokyo", "Asia/Tokyo"),
        new("Asia/Dubai", "Asia/Dubai"),
        new("Asia/Hong_Kong", "Asia/Hong_Kong"),
        new("Asia/Singapore", "Asia/Singapore"),
        new("Asia/Seoul", "Asia/Seoul"),
        new("Australia/Sydney", "Australia/Sydney"),
        new("Australia/Melbourne", "Australia/Melbourne"),
    ];

    private List<OptionItem> startPageOptions =
    [
        new("Home", "/"),
        new("Wiki overview", "/wiki"),
        new("Wiki categories", "/wiki/categories"),
        new("Create wiki page", "/wiki/create"),
        new("Report center", "/reportviewer"),
        new("Onboarding", "/reportdesigner"),
        new("Account settings", "/Account/Manage"),
    ];

    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            message = "Error: Unable to load the current user.";
            return;
        }

        Input.ThemePreference = user.ThemePreference ?? "system";
        Input.DensityPreference = user.DensityPreference ?? "comfortable";
        Input.PreferredLanguage = user.PreferredLanguage ?? "en";
        Input.TimeZone = user.TimeZone;
        Input.StartPage = string.IsNullOrWhiteSpace(user.StartPage) ? "/" : user.StartPage;
        Input.ReceiveProductUpdates = user.ReceiveProductUpdates;
        Input.ReceiveWeeklyDigest = user.ReceiveWeeklyDigest;
        Input.ReceiveReminderEmails = user.ReceiveReminderEmails;
    }

    private async Task OnValidSubmitAsync()
    {
        if (user is null)
        {
            message = "Error: Unable to load the current user.";
            return;
        }

        user.ThemePreference = Input.ThemePreference;
        user.DensityPreference = Input.DensityPreference;
        user.PreferredLanguage = Input.PreferredLanguage;
        user.TimeZone = Input.TimeZone;
        user.StartPage = Input.StartPage;
        user.ReceiveProductUpdates = Input.ReceiveProductUpdates;
        user.ReceiveWeeklyDigest = Input.ReceiveWeeklyDigest;
        user.ReceiveReminderEmails = Input.ReceiveReminderEmails;

        var updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            message = "Error: Failed to update preferences.";
            return;
        }

        await JsRuntime.InvokeVoidAsync("wikiBlaze.setTheme", user.ThemePreference);
        await JsRuntime.InvokeVoidAsync("wikiBlaze.setDensity", user.DensityPreference);

        message = "Your preferences have been updated";
    }

    private record OptionItem(string Text, string Value);

    private sealed class InputModel
    {
        [Required]
        public string ThemePreference { get; set; } = "system";

        [Required]
        public string DensityPreference { get; set; } = "comfortable";

        [MaxLength(80)]
        public string? PreferredLanguage { get; set; }

        [MaxLength(120)]
        public string? TimeZone { get; set; }

        [Required]
        [MaxLength(80)]
        public string StartPage { get; set; } = "/";

        public bool ReceiveProductUpdates { get; set; }

        public bool ReceiveWeeklyDigest { get; set; }

        public bool ReceiveReminderEmails { get; set; } = true;
    }
}

