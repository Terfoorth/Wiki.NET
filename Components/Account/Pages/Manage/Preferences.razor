@page "/Account/Manage/Preferences"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Wiki_Blaze.Data
@inject UserManager<ApplicationUser> UserManager
@inject IJSRuntime JsRuntime

<PageTitle>Preferences</PageTitle>

<div class="block-content">
    <StatusMessage Message="@message" />
    <EditForm Model="Input" FormName="preferences" OnValidSubmit="OnValidSubmitAsync" Context="editContext">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" />
        <DxFormLayout CaptionPosition=@CaptionPosition.Vertical Context="formLayout">
            <DxFormLayoutGroup Caption="Appearance">
                <DxFormLayoutItem Caption="Theme" ColSpanMd="6">
                    <DxComboBox Data="@themeOptions"
                                TData="OptionItem"
                                TValue="string"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="Input.ThemePreference" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Density" ColSpanMd="6">
                    <DxComboBox Data="@densityOptions"
                                TData="OptionItem"
                                TValue="string"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="Input.DensityPreference" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutGroup Caption="Regional settings">
                <DxFormLayoutItem Caption="Preferred language" ColSpanMd="6">
                    <DxComboBox Data="@languageOptions"
                                TData="OptionItem"
                                TValue="string"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="Input.PreferredLanguage" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Time zone" ColSpanMd="6">
                    <DxComboBox Data="@timeZoneOptions"
                                TData="OptionItem"
                                TValue="string"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="Input.TimeZone" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutGroup Caption="Navigation">
                <DxFormLayoutItem Caption="Start page" ColSpanMd="6">
                    <DxComboBox Data="@startPageOptions"
                                TData="OptionItem"
                                TValue="string"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="Input.StartPage" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutGroup Caption="Notifications">
                <DxFormLayoutItem ColSpanMd="6">
                    <DxCheckBox @bind-Checked="Input.ReceiveProductUpdates" LabelText="Product updates" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6">
                    <DxCheckBox @bind-Checked="Input.ReceiveWeeklyDigest" LabelText="Weekly digest" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6">
                    <DxCheckBox @bind-Checked="Input.ReceiveReminderEmails" LabelText="Reminder emails" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutItem ColSpanMd="12" BeginRow="true">
                <DxButton CssClass="w-100" SubmitFormOnClick="true" Text="Save"></DxButton>
            </DxFormLayoutItem>
        </DxFormLayout>
    </EditForm>
</div>

@code {
    private ApplicationUser user = default!;
    private string message = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<OptionItem> themeOptions =
    [
        new("System (auto)", "system"),
        new("Light", "light"),
        new("Dark", "dark"),
        new("Cerulean (Bootswatch)", "bootswatch:cerulean"),
        new("Cosmo (Bootswatch)", "bootswatch:cosmo"),
        new("Cyborg (Bootswatch)", "bootswatch:cyborg"),
        new("Darkly (Bootswatch)", "bootswatch:darkly"),
        new("Flatly (Bootswatch)", "bootswatch:flatly"),
        new("Journal (Bootswatch)", "bootswatch:journal"),
        new("Litera (Bootswatch)", "bootswatch:litera"),
        new("Lumen (Bootswatch)", "bootswatch:lumen"),
        new("Lux (Bootswatch)", "bootswatch:lux"),
        new("Materia (Bootswatch)", "bootswatch:materia"),
        new("Minty (Bootswatch)", "bootswatch:minty"),
        new("Morph (Bootswatch)", "bootswatch:morph"),
        new("Pulse (Bootswatch)", "bootswatch:pulse"),
        new("Quartz (Bootswatch)", "bootswatch:quartz"),
        new("Sandstone (Bootswatch)", "bootswatch:sandstone"),
        new("Simplex (Bootswatch)", "bootswatch:simplex"),
        new("Sketchy (Bootswatch)", "bootswatch:sketchy"),
        new("Slate (Bootswatch)", "bootswatch:slate"),
        new("Solar (Bootswatch)", "bootswatch:solar"),
        new("Spacelab (Bootswatch)", "bootswatch:spacelab"),
        new("Superhero (Bootswatch)", "bootswatch:superhero"),
        new("United (Bootswatch)", "bootswatch:united"),
        new("Vapor (Bootswatch)", "bootswatch:vapor"),
        new("Yeti (Bootswatch)", "bootswatch:yeti"),
        new("Zephyr (Bootswatch)", "bootswatch:zephyr"),
    ];

    private List<OptionItem> densityOptions =
    [
        new("Comfortable", "comfortable"),
        new("Compact", "compact"),
    ];

    private List<OptionItem> languageOptions =
    [
        new("English", "en"),
        new("Deutsch", "de"),
        new("Francais", "fr"),
        new("Espanol", "es"),
        new("Italiano", "it"),
        new("Dansk", "da"),
        new("Norsk", "no"),
        new("Nederlands", "nl"),
        new("Polski", "pl"),
        new("Portugues", "pt"),
        new("Suomi", "fi"),
        new("Svenska", "sv"),
        new("Greek", "el"),
        new("Russian", "ru"),
        new("Ukrainian", "uk"),
        new("Japanese", "ja"),
        new("Korean", "ko"),
        new("Chinese (Simplified)", "zh-hans"),
        new("Chinese (Traditional)", "zh-hant"),
        new("Turkce", "tr"),
    ];

    private List<OptionItem> timeZoneOptions =
    [
        new("UTC", "UTC"),
        new("Europe/Berlin", "Europe/Berlin"),
        new("Europe/London", "Europe/London"),
        new("Europe/Paris", "Europe/Paris"),
        new("Europe/Zurich", "Europe/Zurich"),
        new("America/New_York", "America/New_York"),
        new("America/Los_Angeles", "America/Los_Angeles"),
        new("America/Chicago", "America/Chicago"),
        new("America/Denver", "America/Denver"),
        new("America/Sao_Paulo", "America/Sao_Paulo"),
        new("Asia/Tokyo", "Asia/Tokyo"),
        new("Asia/Dubai", "Asia/Dubai"),
        new("Asia/Hong_Kong", "Asia/Hong_Kong"),
        new("Asia/Singapore", "Asia/Singapore"),
        new("Asia/Seoul", "Asia/Seoul"),
        new("Australia/Sydney", "Australia/Sydney"),
        new("Australia/Melbourne", "Australia/Melbourne"),
    ];

    private List<OptionItem> startPageOptions =
    [
        new("Home", "/"),
        new("Wiki overview", "/wiki"),
        new("Wiki categories", "/wiki/categories"),
        new("Create wiki page", "/wiki/create"),
        new("Report center", "/reportviewer"),
        new("Onboarding", "/reportdesigner"),
        new("Account settings", "/Account/Manage"),
    ];

    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            message = "Error: Unable to load the current user.";
            return;
        }

        PopulateInputFromUser(user);
    }

    private async Task OnValidSubmitAsync()
    {
        if (user is null)
        {
            message = "Error: Unable to load the current user.";
            return;
        }

        var expectedTheme = Input.ThemePreference;
        var expectedDensity = Input.DensityPreference;
        var expectedLanguage = Input.PreferredLanguage;
        var expectedTimeZone = Input.TimeZone;
        var expectedStartPage = Input.StartPage;
        var expectedProductUpdates = Input.ReceiveProductUpdates;
        var expectedWeeklyDigest = Input.ReceiveWeeklyDigest;
        var expectedReminderEmails = Input.ReceiveReminderEmails;

        user.ThemePreference = expectedTheme;
        user.DensityPreference = expectedDensity;
        user.PreferredLanguage = expectedLanguage;
        user.TimeZone = expectedTimeZone;
        user.StartPage = expectedStartPage;
        user.ReceiveProductUpdates = expectedProductUpdates;
        user.ReceiveWeeklyDigest = expectedWeeklyDigest;
        user.ReceiveReminderEmails = expectedReminderEmails;

        var updateResult = await UserManager.UpdateAsync(user);
        if (!updateResult.Succeeded)
        {
            message = "Error: Failed to update preferences.";
            return;
        }

        var reloadedUser = await UserManager.FindByIdAsync(user.Id);
        if (reloadedUser is null)
        {
            message = "Error: Preferences were saved, but the user could not be reloaded.";
            return;
        }

        if (!PreferencesMatch(reloadedUser, expectedTheme, expectedDensity, expectedLanguage, expectedTimeZone, expectedStartPage, expectedProductUpdates, expectedWeeklyDigest, expectedReminderEmails))
        {
            message = "Error: Preferences could not be persisted reliably. Please reload and try again.";
            return;
        }

        user = reloadedUser;
        PopulateInputFromUser(user);

        await JsRuntime.InvokeVoidAsync("wikiBlaze.setTheme", user.ThemePreference);
        await JsRuntime.InvokeVoidAsync("wikiBlaze.setDensity", user.DensityPreference);

        message = "Your preferences have been updated";
    }

    private void PopulateInputFromUser(ApplicationUser source)
    {
        Input.ThemePreference = source.ThemePreference ?? ApplicationUser.DefaultThemePreference;
        Input.DensityPreference = source.DensityPreference ?? ApplicationUser.DefaultDensityPreference;
        Input.PreferredLanguage = source.PreferredLanguage ?? ApplicationUser.DefaultPreferredLanguage;
        Input.TimeZone = source.TimeZone ?? "UTC";
        Input.StartPage = string.IsNullOrWhiteSpace(source.StartPage) ? ApplicationUser.DefaultStartPage : source.StartPage;
        Input.ReceiveProductUpdates = source.ReceiveProductUpdates;
        Input.ReceiveWeeklyDigest = source.ReceiveWeeklyDigest;
        Input.ReceiveReminderEmails = source.ReceiveReminderEmails;
    }

    private static bool PreferencesMatch(
        ApplicationUser source,
        string expectedTheme,
        string expectedDensity,
        string? expectedLanguage,
        string? expectedTimeZone,
        string expectedStartPage,
        bool expectedProductUpdates,
        bool expectedWeeklyDigest,
        bool expectedReminderEmails)
    {
        return string.Equals(source.ThemePreference ?? ApplicationUser.DefaultThemePreference, expectedTheme, StringComparison.Ordinal)
            && string.Equals(source.DensityPreference ?? ApplicationUser.DefaultDensityPreference, expectedDensity, StringComparison.Ordinal)
            && string.Equals(source.PreferredLanguage ?? ApplicationUser.DefaultPreferredLanguage, expectedLanguage ?? ApplicationUser.DefaultPreferredLanguage, StringComparison.Ordinal)
            && string.Equals(source.TimeZone ?? "UTC", expectedTimeZone ?? "UTC", StringComparison.Ordinal)
            && string.Equals(string.IsNullOrWhiteSpace(source.StartPage) ? ApplicationUser.DefaultStartPage : source.StartPage, expectedStartPage, StringComparison.Ordinal)
            && source.ReceiveProductUpdates == expectedProductUpdates
            && source.ReceiveWeeklyDigest == expectedWeeklyDigest
            && source.ReceiveReminderEmails == expectedReminderEmails;
    }

    private record OptionItem(string Text, string Value);

    private sealed class InputModel
    {
        [Required]
        public string ThemePreference { get; set; } = ApplicationUser.DefaultThemePreference;

        [Required]
        public string DensityPreference { get; set; } = ApplicationUser.DefaultDensityPreference;

        [MaxLength(80)]
        public string? PreferredLanguage { get; set; }

        [MaxLength(120)]
        public string? TimeZone { get; set; }

        [Required]
        [MaxLength(80)]
        public string StartPage { get; set; } = ApplicationUser.DefaultStartPage;

        public bool ReceiveProductUpdates { get; set; }

        public bool ReceiveWeeklyDigest { get; set; }

        public bool ReceiveReminderEmails { get; set; } = true;
    }
}
