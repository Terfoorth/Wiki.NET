@page "/Account/Manage/Preferences"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Linq
@using Microsoft.AspNetCore.Identity
@using Wiki_Blaze.Data
@using Wiki_Blaze.Services
@inject UserManager<ApplicationUser> UserManager
@inject IJSRuntime JsRuntime

<PageTitle>Preferences</PageTitle>

<div class="block-content">
    <StatusMessage Message="@message" />
    <EditForm Model="Input" FormName="preferences" OnValidSubmit="OnValidSubmitAsync" Context="editContext">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" />
        <DxFormLayout CaptionPosition=@CaptionPosition.Vertical Context="formLayout">
            <DxFormLayoutGroup Caption="Appearance">
                <DxFormLayoutItem Caption="Theme" ColSpanMd="6">
                    <InteractiveServerComboBox Data="@(themeOptions.Cast<object>())"
                                               Name="Input.ThemePreference"
                                               TextFieldName="Text"
                                               ValueFieldName="Value"
                                               @bind-Value="Input.ThemePreference" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Density" ColSpanMd="6">
                    <InteractiveServerComboBox Data="@(densityOptions.Cast<object>())"
                                               Name="Input.DensityPreference"
                                               TextFieldName="Text"
                                               ValueFieldName="Value"
                                               @bind-Value="Input.DensityPreference" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutGroup Caption="Regional settings">
                <DxFormLayoutItem Caption="Preferred language" ColSpanMd="6">
                    <InteractiveServerComboBox Data="@(languageOptions.Cast<object>())"
                                               Name="Input.PreferredLanguage"
                                               TextFieldName="Text"
                                               ValueFieldName="Value"
                                               @bind-Value="Input.PreferredLanguage" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Time zone" ColSpanMd="6">
                    <InteractiveServerComboBox Data="@(timeZoneOptions.Cast<object>())"
                                               Name="Input.TimeZone"
                                               TextFieldName="Text"
                                               ValueFieldName="Value"
                                               @bind-Value="Input.TimeZone" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutGroup Caption="Navigation">
                <DxFormLayoutItem Caption="Start page" ColSpanMd="6">
                    <InteractiveServerComboBox Data="@(startPageOptions.Cast<object>())"
                                               Name="Input.StartPage"
                                               TextFieldName="Text"
                                               ValueFieldName="Value"
                                               @bind-Value="Input.StartPage" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutGroup Caption="Notifications">
                <DxFormLayoutItem ColSpanMd="6">
                    <InteractiveServerCheckbox Name="Input.ReceiveProductUpdates" @bind-Value="Input.ReceiveProductUpdates" LabelText="Product updates" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6">
                    <InteractiveServerCheckbox Name="Input.ReceiveWeeklyDigest" @bind-Value="Input.ReceiveWeeklyDigest" LabelText="Weekly digest" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6">
                    <InteractiveServerCheckbox Name="Input.ReceiveReminderEmails" @bind-Value="Input.ReceiveReminderEmails" LabelText="Reminder emails" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
            <DxFormLayoutItem ColSpanMd="12" BeginRow="true">
                <DxButton CssClass="w-100" SubmitFormOnClick="true" Text="Save"></DxButton>
            </DxFormLayoutItem>
        </DxFormLayout>
    </EditForm>
</div>

@code {
    private ApplicationUser user = default!;
    private string message = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private List<OptionItem> themeOptions =
